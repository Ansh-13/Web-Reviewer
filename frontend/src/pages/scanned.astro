---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Scan a Website | Web-Reviewer">
  <!-- Include Tailwind CDN, Fonts, and Custom Config inside Layout -->
  <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries" is:inline></script>
  <!-- Font: Hanken Grotesk and Material Symbols -->
  <link href="https://fonts.googleapis.com/css2?family=Hanken+Grotesk:wght@300;400;500;600;700&family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet"/>
  
  <script id="tailwind-config" is:inline>
    tailwind.config = {
      darkMode: 'class',
      theme: {
        extend: {
          fontFamily: {
            sans: ['Hanken Grotesk', 'sans-serif'],
          },
          colors: {
            surface: '#101415',
            'surface-bright': '#363a3b',
            'surface-container': '#191c1e',
            primary: '#8b5cf6', // Purple accent
          },
          borderRadius: {
            'custom': '8px',
          }
        }
      }
    }
  </script>

  <style is:inline>
    .glass-card {
      background: rgba(25, 28, 30, 0.6);
      backdrop-filter: blur(12px);
      border: 1px solid rgba(255, 255, 255, 0.1);
      box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.37);
    }
    .status-completed {
      color: #10b981; /* Emerald-500 */
    }
    body {
      background-color: #0b0f10;
      color: #e2e8f0;
    }
    .ring-bg {
      fill: none;
      stroke: rgba(255, 255, 255, 0.05);
      stroke-width: 8px;
    }
    .ring-progress {
      fill: none;
      stroke-width: 8px;
      stroke-linecap: round;
      transform: rotate(-90deg);
      transform-origin: 50% 50%;
    }
    .check-item {
      display: flex;
      align-items: start;
      gap: 16px;
      padding: 16px;
      border-radius: 8px;
      background: rgba(0, 0, 0, 0.2);
      border: 1px solid rgba(255, 255, 255, 0.05);
      margin-bottom: 12px;
      transition: all 0.2s;
    }
    .check-item:hover {
      background: rgba(255, 255, 255, 0.02);
      border-color: rgba(139, 92, 246, 0.2);
    }
    .check-item.pass .check-icon {
      color: #34d399;
    }
    .check-item.fail .check-icon {
      color: #f87171;
    }
  </style>

  <div class="font-sans antialiased min-h-screen flex flex-col w-full">
    <!-- BEGIN: MainHeader -->
    <header class="border-b border-white/10 bg-surface/80 backdrop-blur-md sticky top-0 z-50">
      <div class="max-w-7xl mx-auto px-6 h-16 flex items-center justify-between">
        <div class="flex items-center space-x-10">
          <!-- Brand Logo -->
          <div class="flex items-center space-x-2">
            <span class="text-xl font-bold tracking-tight text-white">Web-Reviewer</span>
          </div>
          <!-- Navigation -->
          <nav class="hidden md:flex items-center space-x-8">
            <a class="text-sm font-medium text-gray-400 hover:text-white transition-colors py-5" href="/dashboard">Dashboard</a>
            <a class="text-sm font-medium text-gray-400 hover:text-white transition-colors py-5" href="#">Reports</a>
          </nav>
        </div>
        <!-- Header Actions -->
        <div class="flex items-center space-x-6">
          <div class="flex items-center space-x-3 border-l border-white/10 pl-2">
            <span class="text-sm font-medium text-gray-300" id="nav-name">...</span>
            <img id="nav-avatar" alt="Profile" class="w-8 h-8 rounded-full border border-primary/50" src="https://lh3.googleusercontent.com/aida-public/AB6AXuAgdeIvGAkArMbSOItIwRl3YTu97_QlgPl5TyaczKu40-fClOapalegQa1Ujk_Ro94vs-UjlxnTJ8m6I8KcCpItVO6T8o98Y6YsUG7UkHrvYVPvTOR1SIhEvvfvrQqAbRcbgxOGSiY7cfC_N4aPVopjs73P90_3C_PvI_xkwaEYpwVxjXWJPLnHuiLiFNkKEByECGFxN1Rm0ydtf_RgjEDpi51eAvnGHZVaYwD50V6Jsg6Le6xGhNnbOA"/>
          </div>
          <button class="nav-btn-logout material-symbols-outlined text-red-400/80 hover:text-red-400 cursor-pointer" id="logout-btn" title="Sign out">logout</button>
        </div>
      </div>
    </header>
    <!-- END: MainHeader -->

    <!-- BEGIN: MainContent -->
    <main class="flex-grow container mx-auto px-6 py-12 flex flex-col items-center max-w-4xl">
      <!-- Loading spinner -->
      <div class="flex flex-col items-center justify-center py-20" id="page-loader">
        <div class="w-10 h-10 border-4 border-white/5 border-t-primary rounded-full animate-spin"></div>
        <p class="text-on-surface-variant text-label-md mt-4">Verifying authentication…</p>
      </div>

      <div class="w-full hidden space-y-10" id="content-area">
        <!-- Hero Header -->
        <div class="text-center">
          <div class="inline-flex items-center px-3 py-1 rounded-full bg-primary/10 text-primary text-xs font-semibold mb-4 border border-primary/20">
            <svg class="w-3 h-3 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path></svg>
            <span id="project-label">Project</span>
          </div>
          <h1 class="text-4xl font-bold text-white mb-3">Scan a Website</h1>
          <p class="text-gray-400 max-w-lg mx-auto">Enter a URL to crawl and analyse. We'll check SEO, performance, and more.</p>
        </div>

        <!-- Scan Card Container -->
        <div class="w-full max-w-2xl mx-auto">
          <div class="glass-card rounded-xl p-10">
            <form id="scan-form" class="space-y-6" autocomplete="off">
              <div>
                <label class="block text-xs font-bold text-gray-400 uppercase tracking-widest mb-3" for="scan-url">Website URL <span class="text-primary">*</span></label>
                <div class="relative">
                  <span class="absolute inset-y-0 left-0 pl-4 flex items-center text-gray-500">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9h18" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path></svg>
                  </span>
                  <input class="block w-full bg-black/30 border border-white/10 rounded-lg py-4 pl-12 pr-4 text-white placeholder-gray-600 focus:outline-none focus:ring-2 focus:ring-primary/50 focus:border-primary transition-all" id="scan-url" placeholder="https://example.com" type="url" required/>
                </div>
                <p class="mt-3 text-xs text-gray-500">Must start with http:// or https://</p>
              </div>

              <!-- Feedback banner -->
              <div class="form-feedback hidden mt-2 text-label-sm p-3 rounded-lg" id="form-feedback">
                <span id="feedback-icon" class="feedback-icon material-symbols-outlined text-[18px]"></span>
                <span id="feedback-msg"></span>
              </div>

              <button type="submit" class="w-full bg-primary hover:bg-primary/90 text-white font-bold py-4 px-6 rounded-lg shadow-lg shadow-primary/20 transition-all flex items-center justify-center space-x-2 group" id="submit-btn">
                <span id="btn-label" class="flex items-center justify-center space-x-2">
                  <svg class="w-5 h-5 group-hover:scale-110 transition-transform btn-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M13 10V3L4 14h7v7l9-11h-7z" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path></svg>
                  <span>Start Scan</span>
                </span>
                <span class="w-5 h-5 border-2 border-white/20 border-t-white rounded-full animate-spin hidden" id="btn-spinner"></span>
              </button>
            </form>
          </div>
        </div>

        <!-- RESULTS CARD -->
        <div class="w-full max-w-2xl mx-auto glass-card rounded-xl p-10 hidden" id="results-card">
          <div class="border-b border-white/5 pb-4 mb-6">
            <h2 class="text-2xl font-bold text-white mb-2">Scan Results</h2>
            <span class="text-sm text-gray-400 hover:text-primary transition-colors cursor-pointer truncate block" id="results-url"></span>
          </div>

          <div class="flex flex-col md:flex-row items-center gap-8 justify-center my-8">
            <div class="relative w-[120px] h-[120px] flex items-center justify-center">
              <svg class="absolute inset-0 w-full h-full" viewBox="0 0 120 120">
                <circle class="ring-bg" cx="60" cy="60" r="52"/>
                <circle class="ring-progress" id="ring-progress" cx="60" cy="60" r="52"/>
              </svg>
              <div class="flex flex-col items-center">
                <span class="text-3xl font-extrabold text-white" id="score-number">—</span>
                <span class="text-[10px] text-gray-500 uppercase tracking-widest">Score</span>
              </div>
            </div>
            <span class="px-6 py-2 rounded-full text-2xl font-extrabold border border-white/10" id="grade-badge">—</span>
          </div>

          <div class="border-t border-b border-white/5 py-4 my-6 text-center">
            <span class="block text-xs text-gray-500 uppercase tracking-wider mb-1">Scan Duration</span>
            <span class="text-lg font-semibold text-white" id="scan-duration">—</span>
          </div>

          <!-- More Details button -->
          <div class="mt-6 flex justify-center">
            <a id="more-details-btn" href="#" target="_blank" class="w-full bg-primary hover:bg-primary/90 text-white font-bold py-4 px-6 rounded-lg shadow-lg shadow-primary/20 transition-all flex items-center justify-center space-x-2 group">
              <span>More Details</span>
              <span class="material-symbols-outlined group-hover:translate-x-1 transition-transform">arrow_forward</span>
            </a>
          </div>
        </div>

        <!-- BEGIN: PreviousScans -->
        <div class="w-full max-w-2xl mx-auto mt-16">
          <div class="flex items-center justify-between mb-6">
            <h2 class="text-xl font-bold text-white flex items-center">
              Previous Scans
              <span class="ml-3 px-2 py-0.5 bg-surface-bright text-xs rounded-full text-gray-300" id="scan-count"></span>
            </h2>
            <button id="sort-scans-btn" class="flex items-center gap-1.5 text-xs font-semibold text-gray-400 hover:text-white px-3 py-1.5 rounded-lg bg-surface-bright/30 border border-white/5 transition-all">
              <span class="material-symbols-outlined text-[16px]">sort</span>
              <span id="sort-label">Latest</span>
            </button>
          </div>

          <div class="space-y-4">
            <!-- Skeleton Loader -->
            <div class="space-y-4" id="history-skeleton">
              <div class="glass-card p-4 rounded-xl flex flex-col gap-2">
                <div class="skeleton-line w70 h-4 bg-white/5 rounded"></div>
              </div>
              <div class="glass-card p-4 rounded-xl flex flex-col gap-2">
                <div class="skeleton-line w60 h-4 bg-white/5 rounded"></div>
              </div>
            </div>

            <!-- Actual Scans List -->
            <div class="space-y-4 hidden" id="history-list"></div>

            <!-- Empty State -->
            <div class="glass-card p-8 rounded-xl text-center hidden" id="history-empty">
              <svg class="w-12 h-12 mx-auto text-gray-600 mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>
              </svg>
              <p class="font-semibold text-white">No scans yet</p>
              <span class="text-xs text-gray-500">Run your first scan above to see results here.</span>
            </div>
          </div>
        </div>
        <!-- END: PreviousScans -->
      </div>
    </main>
    <!-- END: MainContent -->

    <!-- BEGIN: Footer -->
    <footer class="border-t border-white/5 bg-surface-container/50 py-8 mt-auto">
      <div class="max-w-7xl mx-auto px-6 flex flex-col md:flex-row items-center justify-between text-xs text-gray-500">
        <div class="flex items-center space-x-2 mb-4 md:mb-0">
          <span class="font-bold text-gray-400">Web-Reviewer</span>
          <span>© 2024 Web-Reviewer Systems. All rights reserved.</span>
        </div>
        <div class="flex space-x-8">
          <a class="hover:text-white transition-colors" href="#">Privacy Policy</a>
          <a class="hover:text-white transition-colors" href="#">Terms of Service</a>
          <a class="hover:text-white transition-colors" href="#">Help Center</a>
        </div>
      </div>
    </footer>
    <!-- END: Footer -->
  </div>
</Layout>

<!-- ───────── CLIENT-SIDE SCRIPT ───────── -->
<script>
  import { subscribeToAuthState, signOutOfAccount } from '../firebase/auth';

  /* ── DOM refs ── */
  const pageLoader    = document.getElementById('page-loader') as HTMLDivElement;
  const contentArea   = document.getElementById('content-area') as HTMLElement;
  const navAvatar     = document.getElementById('nav-avatar') as HTMLImageElement;
  const navName       = document.getElementById('nav-name') as HTMLSpanElement;
  const logoutBtn     = document.getElementById('logout-btn') as HTMLButtonElement;
  const projectLabel  = document.getElementById('project-label') as HTMLSpanElement;

  const form          = document.getElementById('scan-form') as HTMLFormElement;
  const urlInput      = document.getElementById('scan-url') as HTMLInputElement;
  const feedbackBox   = document.getElementById('form-feedback') as HTMLDivElement;
  const feedbackIcon  = document.getElementById('feedback-icon') as HTMLSpanElement;
  const feedbackMsg   = document.getElementById('feedback-msg') as HTMLSpanElement;
  const submitBtn     = document.getElementById('submit-btn') as HTMLButtonElement;
  const btnLabel      = document.getElementById('btn-label') as HTMLSpanElement;
  const btnSpinner    = document.getElementById('btn-spinner') as HTMLSpanElement;
  const btnIcon       = submitBtn.querySelector('.btn-icon') as SVGElement;

  const resultsCard   = document.getElementById('results-card') as HTMLDivElement;
  const resultsUrl    = document.getElementById('results-url') as HTMLSpanElement;
  const scoreNumber   = document.getElementById('score-number') as HTMLSpanElement;
  const gradeBadge    = document.getElementById('grade-badge') as HTMLSpanElement;
  const scanDuration  = document.getElementById('scan-duration') as HTMLSpanElement;
  const moreDetailsBtn = document.getElementById('more-details-btn') as HTMLAnchorElement;
  const ringProgress  = document.getElementById('ring-progress') as SVGCircleElement;

  let currentToken: string | null = null;
  let fetchedScans: any[] = [];
  let sortLatest = true;

  /* ── Read project name from query params ── */
  const params = new URLSearchParams(window.location.search);
  const projectName = params.get('project') || 'Untitled';

  /* ── Auth gate ── */
  subscribeToAuthState(async (user) => {
    if (!user) { window.location.href = '/login'; return; }

    navName.textContent = user.displayName || user.email || 'User';
    navAvatar.src = user.photoURL || `https://api.dicebear.com/7.x/initials/svg?seed=${encodeURIComponent(user.email || 'user')}`;
    projectLabel.textContent = projectName;

    currentToken = await user.getIdToken();

    pageLoader.classList.add('hidden');
    contentArea.classList.remove('hidden');

    // Fetch previous scans
    fetchPreviousScans();
  });

  /* ── Logout ── */
  logoutBtn.addEventListener('click', async () => {
    try { await signOutOfAccount(); window.location.href = '/login'; }
    catch (e) { console.error('Logout failed', e); }
  });

  /* ── Helpers ── */
  function showFeedback(type: 'success' | 'error' | 'info', msg: string) {
    let styleClass = 'bg-blue-500/10 text-blue-400 border border-blue-500/20';
    let icon = 'info';
    if (type === 'success') {
      styleClass = 'bg-emerald-500/10 text-emerald-400 border border-emerald-500/20';
      icon = 'check_circle';
    } else if (type === 'error') {
      styleClass = 'bg-red-500/10 text-red-400 border border-red-500/20';
      icon = 'cancel';
    }
    feedbackBox.className = `form-feedback ${styleClass} text-label-sm p-3 rounded-lg flex items-center gap-2 mt-2`;
    feedbackIcon.className = 'material-symbols-outlined text-[18px]';
    feedbackIcon.textContent = icon;
    feedbackMsg.textContent = msg;
    feedbackBox.classList.remove('hidden');
  }

  function setLoading(on: boolean) {
    submitBtn.disabled = on;
    btnLabel.classList.toggle('hidden', on);
    btnSpinner.classList.toggle('hidden', !on);
    if (btnIcon) btnIcon.classList.toggle('hidden', on);
  }

  /* ── Grade colour ── */
  function gradeColor(grade: string): string {
    const g = grade.toUpperCase();
    if (g === 'A+' || g === 'A') return '#34d399';
    if (g === 'B') return '#60a5fa';
    if (g === 'C') return '#fbbf24';
    if (g === 'D') return '#fb923c';
    return '#f87171';
  }

  /* ── Render results ── */
  function renderResults(data: any) {
    resultsCard.classList.remove('hidden');

    resultsUrl.textContent = data.url;
    scoreNumber.textContent = data.score ?? '—';
    gradeBadge.textContent = data.grade ?? '—';
    gradeBadge.style.background = gradeColor(data.grade || 'F') + '22';
    gradeBadge.style.color = gradeColor(data.grade || 'F');
    gradeBadge.style.borderColor = gradeColor(data.grade || 'F') + '44';
    scanDuration.textContent = data.scanDurationMs ? `${(data.scanDurationMs / 1000).toFixed(2)}s` : '—';

    // Animate score ring
    const circumference = 2 * Math.PI * 52;
    const score = Math.min(Math.max(data.score || 0, 0), 100);
    const offset = circumference - (score / 100) * circumference;
    ringProgress.style.strokeDasharray = `${circumference}`;
    ringProgress.style.strokeDashoffset = `${circumference}`;
    ringProgress.style.stroke = gradeColor(data.grade || 'F');
    requestAnimationFrame(() => {
      ringProgress.style.transition = 'stroke-dashoffset 1s ease';
      ringProgress.style.strokeDashoffset = `${offset}`;
    });

    if (data.scan_id) {
      moreDetailsBtn.href = `/results?scan_id=${data.scan_id}`;
    } else {
      moreDetailsBtn.href = '#';
    }
  }

  /* ── Submit scan ── */
  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    feedbackBox.classList.add('hidden');
    resultsCard.classList.add('hidden');

    const url = urlInput.value.trim();
    if (!url) { showFeedback('error', 'Please enter a URL.'); return; }
    if (!currentToken) { showFeedback('error', 'Authentication expired. Please reload.'); return; }

    try { new URL(url); } catch { showFeedback('error', 'Enter a valid URL starting with http:// or https://'); return; }

    setLoading(true);
    showFeedback('info', 'Scanning… this may take a minute.');

    try {
      const res = await fetch('http://localhost:3000/api/v1/scan', {
        method: 'POST',
        headers: {
          'Authorization': `Bearer ${currentToken}`,
          'url': url,
          'project_name': projectName,
          'Content-Type': 'application/json',
        },
      });

      if (!res.ok) {
        const body = await res.json().catch(() => null);
        const msg = body?.error || (typeof body === 'string' ? body : 'Scan failed.');
        throw new Error(msg);
      }

      const data = await res.json();
      feedbackBox.classList.add('hidden');
      renderResults(data);

      // Refresh scan history after new scan
      fetchPreviousScans();

    } catch (err: any) {
      showFeedback('error', err.message || 'Could not reach the server.');
    } finally {
      setLoading(false);
    }
  });

  /* ── Fetch Previous Scans ── */
  const historySkeleton = document.getElementById('history-skeleton') as HTMLDivElement;
  const historyList     = document.getElementById('history-list') as HTMLDivElement;
  const historyEmpty    = document.getElementById('history-empty') as HTMLDivElement;
  const scanCount       = document.getElementById('scan-count') as HTMLSpanElement;

  async function fetchPreviousScans() {
    historySkeleton.classList.remove('hidden');
    historyList.classList.add('hidden');
    historyEmpty.classList.add('hidden');

    try {
      if (!currentToken) return;

      const res = await fetch('http://localhost:3000/api/v1/getScan', {
        headers: {
          'Authorization': `Bearer ${currentToken}`,
          'project_name': projectName,
        },
      });

      if (!res.ok) throw new Error('Failed to fetch scans');

      const body = await res.json();
      fetchedScans = body.data || [];

      historySkeleton.classList.add('hidden');

      if (fetchedScans.length === 0) {
        historyEmpty.classList.remove('hidden');
        scanCount.textContent = '';
        return;
      }

      scanCount.textContent = `${fetchedScans.length}`;
      applySortAndRenderScans();
    } catch (err) {
      console.error(err);
      historySkeleton.classList.add('hidden');
      historyEmpty.classList.remove('hidden');
    }
  }

  function applySortAndRenderScans() {
    let sorted = [...fetchedScans];
    if (sortLatest) {
      sorted.sort((a, b) => new Date(b.started_at || 0).getTime() - new Date(a.started_at || 0).getTime());
    } else {
      sorted.sort((a, b) => new Date(a.started_at || 0).getTime() - new Date(b.started_at || 0).getTime());
    }
    renderScanHistory(sorted);
  }

  function statusColor(status: string): { bg: string; text: string; border: string } {
    const s = status.toLowerCase();
    if (s === 'completed' || s === 'done') return { bg: 'rgba(16,185,129,0.1)', text: '#34d399', border: 'rgba(16,185,129,0.2)' };
    if (s === 'pending')   return { bg: 'rgba(59,130,246,0.1)', text: '#60a5fa', border: 'rgba(59,130,246,0.2)' };
    if (s === 'failed')    return { bg: 'rgba(239,68,68,0.1)', text: '#f87171', border: 'rgba(239,68,68,0.2)' };
    return { bg: 'rgba(156,163,175,0.1)', text: '#9ca3af', border: 'rgba(156,163,175,0.2)' };
  }

  function renderScanHistory(scans: { id: string; url: string; status: string }[]) {
    historyList.innerHTML = scans.map((s, i) => {
      const c = statusColor(s.status);
      const isCompleted = s.status.toLowerCase() === 'completed' || s.status.toLowerCase() === 'done';
      const tag = isCompleted ? 'a' : 'div';
      const hrefAttr = isCompleted ? `href="/results?scan_id=${s.id}" target="_blank"` : '';
      const hoverClass = isCompleted ? 'hover:bg-white/5 transition-all cursor-pointer' : '';
      
      return `
        <${tag} ${hrefAttr} class="flex items-center justify-between group p-4 rounded-lg bg-surface-container border border-white/5 ${hoverClass}" style="animation-delay: ${i * 50}ms">
          <div class="flex items-center space-x-4 min-w-0">
            <div class="p-2 rounded bg-primary/10 text-primary flex-shrink-0">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9h18" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path></svg>
            </div>
            <span class="text-sm font-medium text-gray-300 group-hover:text-primary transition-colors underline decoration-primary/30 underline-offset-4 truncate max-w-md" title="${s.url}">${s.url}</span>
          </div>
          <div class="flex items-center space-x-2 flex-shrink-0">
            <span class="text-xs font-semibold px-3 py-1 rounded-full" style="background:${c.bg};color:${c.text};border: 1px solid ${c.border}">${s.status}</span>
          </div>
        </${tag}>
      `;
    }).join('');
    historyList.classList.remove('hidden');
  }

  const sortScansBtn = document.getElementById('sort-scans-btn') as HTMLButtonElement;
  const sortLabel = document.getElementById('sort-label') as HTMLSpanElement;
  if (sortScansBtn && sortLabel) {
    sortScansBtn.addEventListener('click', () => {
      sortLatest = !sortLatest;
      sortLabel.textContent = sortLatest ? 'Latest' : 'Oldest';
      applySortAndRenderScans();
    });
  }
</script>
