---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Scan Website | Web-Reviewer">
  <!-- ───────── NAVBAR ───────── -->
  <nav class="navbar">
    <div class="nav-inner">
      <a href="/dashboard" class="nav-brand">
        <span class="brand-icon">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="url(#bg)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <defs><linearGradient id="bg" x1="0" y1="0" x2="24" y2="24"><stop offset="0%" stop-color="#818cf8"/><stop offset="100%" stop-color="#6366f1"/></linearGradient></defs>
            <circle cx="12" cy="12" r="10"/>
            <path d="M8 12l2 2 4-4"/>
          </svg>
        </span>
        <span class="brand-text">Web-Reviewer</span>
      </a>

      <div class="nav-right">
        <a href="/dashboard" class="nav-link" title="Back to Dashboard">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
          <span>Dashboard</span>
        </a>
        <div class="nav-user" id="nav-user-info">
          <img id="nav-avatar" class="nav-avatar" src="https://www.gravatar.com/avatar/00000000000000000000000000000000?d=mp&f=y" alt="Avatar" />
          <span class="nav-name" id="nav-name">...</span>
        </div>
        <button class="nav-btn-logout" id="logout-btn" title="Sign out">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
        </button>
      </div>
    </div>
  </nav>

  <!-- ───────── PAGE CONTENT ───────── -->
  <main class="scan-main">
    <!-- Loading spinner -->
    <div class="loading-state" id="page-loader">
      <div class="spinner"></div>
      <p>Verifying authentication…</p>
    </div>

    <!-- Scan form (hidden until auth resolves) -->
    <section class="content-wrapper hidden" id="content-area">
      <!-- Project badge -->
      <div class="project-badge" id="project-badge">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/></svg>
        <span id="project-label">Project</span>
      </div>

      <div class="section-header">
        <h1>Scan a Website</h1>
        <p class="section-subtitle">Enter a URL to crawl and analyse. We'll check SEO, performance, and more.</p>
      </div>

      <form class="glass-card" id="scan-form" autocomplete="off">
        <!-- URL -->
        <div class="form-group">
          <label for="scan-url">Website URL <span class="required">*</span></label>
          <div class="input-wrapper">
            <svg class="input-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10A15.3 15.3 0 0 1 12 2z"/></svg>
            <input type="url" id="scan-url" name="url" placeholder="https://example.com" required />
          </div>
          <span class="input-hint">Must start with http:// or https://</span>
        </div>

        <!-- Feedback banner -->
        <div class="form-feedback hidden" id="form-feedback">
          <span class="feedback-icon" id="feedback-icon"></span>
          <span id="feedback-msg"></span>
        </div>

        <!-- Submit -->
        <button type="submit" class="btn btn-primary" id="submit-btn">
          <svg class="btn-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
          <span class="btn-label" id="btn-label">Start Scan</span>
          <span class="btn-spinner hidden" id="btn-spinner"></span>
        </button>
      </form>

      <!-- ── Results Card (shown after scan completes) ── -->
      <div class="glass-card results-card hidden" id="results-card">
        <div class="results-header">
          <h2>Scan Results</h2>
          <span class="results-url" id="results-url"></span>
        </div>

        <div class="score-ring-container">
          <div class="score-ring" id="score-ring">
            <svg viewBox="0 0 120 120">
              <circle class="ring-bg" cx="60" cy="60" r="52"/>
              <circle class="ring-progress" id="ring-progress" cx="60" cy="60" r="52"/>
            </svg>
            <div class="score-value">
              <span class="score-number" id="score-number">—</span>
              <span class="score-label">Score</span>
            </div>
          </div>
          <span class="grade-badge" id="grade-badge">—</span>
        </div>

        <div class="results-meta">
          <div class="meta-item">
            <span class="meta-label">Scan Duration</span>
            <span class="meta-value" id="scan-duration">—</span>
          </div>
        </div>

        <div class="results-summary" id="results-summary"></div>

        <!-- Individual check results -->
        <div class="results-checks" id="results-checks"></div>
      </div>

      <!-- ───────── PREVIOUS SCANS ───────── -->
      <div class="history-section">
        <div class="history-header">
          <h2>Previous Scans</h2>
          <span class="scan-count" id="scan-count"></span>
        </div>

        <!-- skeleton -->
        <div class="history-skeleton" id="history-skeleton">
          <div class="skeleton-card"><div class="skeleton-line w70"></div><div class="skeleton-line w30"></div></div>
          <div class="skeleton-card"><div class="skeleton-line w60"></div><div class="skeleton-line w40"></div></div>
        </div>

        <!-- actual list -->
        <div class="history-list hidden" id="history-list"></div>

        <!-- empty state -->
        <div class="history-empty hidden" id="history-empty">
          <svg width="44" height="44" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
          <p>No scans yet</p>
          <span>Run your first scan above to see results here.</span>
        </div>
      </div>
    </section>
  </main>
</Layout>

<!-- ───────── CLIENT-SIDE SCRIPT ───────── -->
<script>
  import { subscribeToAuthState, signOutOfAccount } from '../firebase/auth';

  /* ── DOM refs ── */
  const pageLoader    = document.getElementById('page-loader') as HTMLDivElement;
  const contentArea   = document.getElementById('content-area') as HTMLElement;
  const navAvatar     = document.getElementById('nav-avatar') as HTMLImageElement;
  const navName       = document.getElementById('nav-name') as HTMLSpanElement;
  const logoutBtn     = document.getElementById('logout-btn') as HTMLButtonElement;
  const projectLabel  = document.getElementById('project-label') as HTMLSpanElement;

  const form          = document.getElementById('scan-form') as HTMLFormElement;
  const urlInput      = document.getElementById('scan-url') as HTMLInputElement;
  const feedbackBox   = document.getElementById('form-feedback') as HTMLDivElement;
  const feedbackIcon  = document.getElementById('feedback-icon') as HTMLSpanElement;
  const feedbackMsg   = document.getElementById('feedback-msg') as HTMLSpanElement;
  const submitBtn     = document.getElementById('submit-btn') as HTMLButtonElement;
  const btnLabel      = document.getElementById('btn-label') as HTMLSpanElement;
  const btnSpinner    = document.getElementById('btn-spinner') as HTMLSpanElement;
  const btnIcon       = submitBtn.querySelector('.btn-icon') as SVGElement;

  const resultsCard   = document.getElementById('results-card') as HTMLDivElement;
  const resultsUrl    = document.getElementById('results-url') as HTMLSpanElement;
  const scoreNumber   = document.getElementById('score-number') as HTMLSpanElement;
  const gradeBadge    = document.getElementById('grade-badge') as HTMLSpanElement;
  const scanDuration  = document.getElementById('scan-duration') as HTMLSpanElement;
  const resultsSummary = document.getElementById('results-summary') as HTMLDivElement;
  const resultsChecks = document.getElementById('results-checks') as HTMLDivElement;
  const ringProgress  = document.getElementById('ring-progress') as SVGCircleElement;

  let currentToken: string | null = null;

  /* ── Read project name from query params ── */
  const params = new URLSearchParams(window.location.search);
  const projectName = params.get('project') || 'Untitled';

  /* ── Auth gate ── */
  subscribeToAuthState(async (user) => {
    if (!user) { window.location.href = '/login'; return; }

    navName.textContent = user.displayName || user.email || 'User';
    navAvatar.src = user.photoURL || `https://api.dicebear.com/7.x/initials/svg?seed=${encodeURIComponent(user.email || 'user')}`;
    projectLabel.textContent = projectName;

    currentToken = await user.getIdToken();

    pageLoader.classList.add('hidden');
    contentArea.classList.remove('hidden');

    // Fetch previous scans (no auth required)
    fetchPreviousScans();
  });

  /* ── Logout ── */
  logoutBtn.addEventListener('click', async () => {
    try { await signOutOfAccount(); window.location.href = '/login'; }
    catch (e) { console.error('Logout failed', e); }
  });

  /* ── Helpers ── */
  function showFeedback(type: 'success' | 'error' | 'info', msg: string) {
    feedbackBox.className = `form-feedback ${type}`;
    feedbackIcon.textContent = type === 'success' ? '✓' : type === 'error' ? '✕' : 'ℹ';
    feedbackMsg.textContent = msg;
  }

  function setLoading(on: boolean) {
    submitBtn.disabled = on;
    btnLabel.classList.toggle('hidden', on);
    btnSpinner.classList.toggle('hidden', !on);
    if (btnIcon) btnIcon.classList.toggle('hidden', on);
  }

  /* ── Grade colour ── */
  function gradeColor(grade: string): string {
    const g = grade.toUpperCase();
    if (g === 'A+' || g === 'A') return '#34d399';
    if (g === 'B') return '#60a5fa';
    if (g === 'C') return '#fbbf24';
    if (g === 'D') return '#fb923c';
    return '#f87171';
  }

  /* ── Render results ── */
  function renderResults(data: any) {
    resultsCard.classList.remove('hidden');

    resultsUrl.textContent = data.url;
    scoreNumber.textContent = data.score ?? '—';
    gradeBadge.textContent = data.grade ?? '—';
    gradeBadge.style.background = gradeColor(data.grade || 'F') + '22';
    gradeBadge.style.color = gradeColor(data.grade || 'F');
    gradeBadge.style.borderColor = gradeColor(data.grade || 'F') + '44';
    scanDuration.textContent = data.scanDurationMs ? `${(data.scanDurationMs / 1000).toFixed(2)}s` : '—';

    // Animate score ring
    const circumference = 2 * Math.PI * 52;
    const score = Math.min(Math.max(data.score || 0, 0), 100);
    const offset = circumference - (score / 100) * circumference;
    ringProgress.style.strokeDasharray = `${circumference}`;
    ringProgress.style.strokeDashoffset = `${circumference}`;
    ringProgress.style.stroke = gradeColor(data.grade || 'F');
    requestAnimationFrame(() => {
      ringProgress.style.transition = 'stroke-dashoffset 1s ease';
      ringProgress.style.strokeDashoffset = `${offset}`;
    });

    // Summary
    if (data.summary) {
      resultsSummary.innerHTML = `<p class="summary-text">${data.summary}</p>`;
    }

    // Individual results
    if (data.results && Array.isArray(data.results)) {
      resultsChecks.innerHTML = data.results.map((r: any) => `
        <div class="check-item ${r.pass ? 'pass' : 'fail'}">
          <span class="check-icon">${r.pass ? '✓' : '✕'}</span>
          <div class="check-body">
            <span class="check-name">${r.name || r.check || 'Check'}</span>
            ${r.message ? `<span class="check-msg">${r.message}</span>` : ''}
          </div>
        </div>
      `).join('');
    }
  }

  /* ── Submit scan ── */
  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    feedbackBox.classList.add('hidden');
    resultsCard.classList.add('hidden');

    const url = urlInput.value.trim();
    if (!url) { showFeedback('error', 'Please enter a URL.'); return; }
    if (!currentToken) { showFeedback('error', 'Authentication expired. Please reload.'); return; }

    try { new URL(url); } catch { showFeedback('error', 'Enter a valid URL starting with http:// or https://'); return; }

    setLoading(true);
    showFeedback('info', 'Scanning… this may take a minute.');

    try {
      const res = await fetch('http://localhost:3000/api/v1/scan', {
        method: 'POST',
        headers: {
          'Authorization': `Bearer ${currentToken}`,
          'url': url,
          'project_name': projectName,
          'Content-Type': 'application/json',
        },
      });

      if (!res.ok) {
        const body = await res.json().catch(() => null);
        const msg = body?.error || (typeof body === 'string' ? body : 'Scan failed.');
        throw new Error(msg);
      }

      const data = await res.json();
      feedbackBox.classList.add('hidden');
      renderResults(data);

      // Refresh scan history after new scan
      fetchPreviousScans();

    } catch (err: any) {
      showFeedback('error', err.message || 'Could not reach the server.');
    } finally {
      setLoading(false);
    }
  });

  /* ── Fetch Previous Scans ── */
  const historySkeleton = document.getElementById('history-skeleton') as HTMLDivElement;
  const historyList     = document.getElementById('history-list') as HTMLDivElement;
  const historyEmpty    = document.getElementById('history-empty') as HTMLDivElement;
  const scanCount       = document.getElementById('scan-count') as HTMLSpanElement;

  async function fetchPreviousScans() {
    historySkeleton.classList.remove('hidden');
    historyList.classList.add('hidden');
    historyEmpty.classList.add('hidden');

    try {
      if (!currentToken) return;

      const res = await fetch('http://localhost:3000/api/v1/getScan', {
        headers: {
          'Authorization': `Bearer ${currentToken}`,
          'project_name': projectName,
        },
      });

      if (!res.ok) throw new Error('Failed to fetch scans');

      const body = await res.json();
      const scans: { url: string; status: string }[] = body.data || [];

      historySkeleton.classList.add('hidden');

      if (scans.length === 0) {
        historyEmpty.classList.remove('hidden');
        scanCount.textContent = '';
        return;
      }

      scanCount.textContent = `${scans.length}`;
      renderScanHistory(scans);
    } catch (err) {
      console.error(err);
      historySkeleton.classList.add('hidden');
      historyEmpty.classList.remove('hidden');
    }
  }

  function statusColor(status: string): { bg: string; text: string; border: string } {
    const s = status.toLowerCase();
    if (s === 'completed' || s === 'done') return { bg: 'rgba(52,211,153,0.12)', text: '#34d399', border: 'rgba(52,211,153,0.25)' };
    if (s === 'pending')   return { bg: 'rgba(251,191,36,0.12)', text: '#fbbf24', border: 'rgba(251,191,36,0.25)' };
    if (s === 'failed')    return { bg: 'rgba(248,113,113,0.12)', text: '#f87171', border: 'rgba(248,113,113,0.25)' };
    return { bg: 'rgba(148,163,184,0.12)', text: '#94a3b8', border: 'rgba(148,163,184,0.25)' };
  }

  function renderScanHistory(scans: { id: string; url: string; status: string }[]) {
    historyList.innerHTML = scans.map((s, i) => {
      const c = statusColor(s.status);
      const isCompleted = s.status.toLowerCase() === 'completed' || s.status.toLowerCase() === 'done';
      const tag = isCompleted ? 'a' : 'div';
      const hrefAttr = isCompleted ? `href="/results?scan_id=${s.id}" target="_blank"` : '';
      const hoverClass = isCompleted ? 'clickable' : '';
      
      return `
        <${tag} ${hrefAttr} class="history-card ${hoverClass}" style="animation-delay: ${i * 50}ms">
          <div class="history-card-icon">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10A15.3 15.3 0 0 1 12 2z"/></svg>
          </div>
          <span class="history-url">${s.url}</span>
          <span class="history-status" style="background:${c.bg};color:${c.text};border-color:${c.border}">${s.status}</span>
        </${tag}>
      `;
    }).join('');
    historyList.classList.remove('hidden');
  }
</script>

<!-- ───────── STYLES ───────── -->
<style>
  /* ── Tokens ── */
  :root {
    --bg-gradient: linear-gradient(145deg, #0b0f1a 0%, #141832 50%, #0f172a 100%);
    --nav-bg: rgba(15, 23, 42, 0.72);
    --card-bg: rgba(30, 41, 59, 0.42);
    --card-border: rgba(255, 255, 255, 0.07);
    --text-primary: #f1f5f9;
    --text-secondary: #94a3b8;
    --text-muted: #64748b;
    --accent: #6366f1;
    --accent-hover: #818cf8;
    --accent-glow: rgba(99, 102, 241, 0.35);
    --success: #34d399;
    --success-bg: rgba(52, 211, 153, 0.12);
    --error: #f87171;
    --error-bg: rgba(248, 113, 113, 0.12);
    --info: #60a5fa;
    --info-bg: rgba(96, 165, 250, 0.10);
    --radius-sm: 10px;
    --radius-md: 16px;
    --radius-lg: 24px;
    --font: 'Inter', 'Segoe UI', system-ui, sans-serif;
  }

  /* ── Navbar ── */
  .navbar {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    background: var(--nav-bg);
    backdrop-filter: blur(18px) saturate(1.4);
    -webkit-backdrop-filter: blur(18px) saturate(1.4);
    border-bottom: 1px solid var(--card-border);
  }

  .nav-inner {
    max-width: 1140px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 28px;
    height: 64px;
  }

  .nav-brand {
    display: flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
    color: var(--text-primary);
  }

  .brand-text {
    font-family: var(--font);
    font-size: 20px;
    font-weight: 700;
    letter-spacing: -0.02em;
    background: linear-gradient(135deg, #c7d2fe 0%, #818cf8 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .nav-right {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .nav-link {
    display: flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font);
    font-size: 13px;
    font-weight: 500;
    color: var(--text-secondary);
    text-decoration: none;
    padding: 6px 12px;
    border-radius: 8px;
    border: 1px solid transparent;
    transition: all 0.2s;
  }

  .nav-link:hover {
    color: var(--text-primary);
    background: rgba(255, 255, 255, 0.06);
    border-color: var(--card-border);
  }

  .nav-user {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .nav-avatar {
    width: 34px;
    height: 34px;
    border-radius: 50%;
    object-fit: cover;
    border: 2px solid rgba(99, 102, 241, 0.4);
  }

  .nav-name {
    font-family: var(--font);
    font-size: 14px;
    font-weight: 500;
    color: var(--text-secondary);
  }

  .nav-btn-logout {
    display: grid;
    place-items: center;
    width: 36px;
    height: 36px;
    border-radius: 10px;
    border: 1px solid rgba(248, 113, 113, 0.2);
    background: rgba(248, 113, 113, 0.08);
    color: #fca5a5;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .nav-btn-logout:hover {
    background: rgba(248, 113, 113, 0.18);
    border-color: rgba(248, 113, 113, 0.4);
    transform: translateY(-1px);
  }

  /* ── Main ── */
  .scan-main {
    min-height: 100vh;
    background: var(--bg-gradient);
    font-family: var(--font);
    color: var(--text-primary);
    display: flex;
    justify-content: center;
    align-items: flex-start;
    padding: 104px 24px 60px;
  }

  /* ── Content wrapper ── */
  .content-wrapper {
    width: 100%;
    max-width: 620px;
    animation: fadeUp 0.5s ease both;
  }

  /* ── Project badge ── */
  .project-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 5px 14px;
    background: rgba(99, 102, 241, 0.12);
    border: 1px solid rgba(99, 102, 241, 0.25);
    border-radius: 20px;
    color: var(--accent-hover);
    font-size: 13px;
    font-weight: 600;
    margin-bottom: 16px;
  }

  .section-header {
    margin-bottom: 28px;
  }

  .section-header h1 {
    font-size: 28px;
    font-weight: 800;
    letter-spacing: -0.03em;
    margin: 0 0 6px;
    background: linear-gradient(135deg, #e0e7ff, #c7d2fe 40%, #818cf8);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .section-subtitle {
    font-size: 15px;
    color: var(--text-secondary);
    margin: 0;
    line-height: 1.55;
  }

  /* ── Glass card ── */
  .glass-card {
    background: var(--card-bg);
    backdrop-filter: blur(20px) saturate(1.3);
    -webkit-backdrop-filter: blur(20px) saturate(1.3);
    border: 1px solid var(--card-border);
    border-radius: var(--radius-lg);
    padding: 36px;
    box-shadow:
      0 4px 30px rgba(0, 0, 0, 0.25),
      inset 0 1px 0 rgba(255, 255, 255, 0.04);
  }

  /* ── Form ── */
  .form-group {
    margin-bottom: 24px;
  }

  .form-group label {
    display: block;
    font-size: 13px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--text-secondary);
    margin-bottom: 8px;
  }

  .required { color: var(--error); }

  .input-wrapper {
    position: relative;
    display: flex;
    align-items: center;
  }

  .input-icon {
    position: absolute;
    left: 14px;
    color: var(--text-muted);
    pointer-events: none;
    transition: color 0.2s;
  }

  .input-wrapper input {
    width: 100%;
    padding: 14px 16px 14px 44px;
    font-family: var(--font);
    font-size: 15px;
    color: var(--text-primary);
    background: rgba(15, 23, 42, 0.55);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: var(--radius-sm);
    outline: none;
    transition: border-color 0.25s, box-shadow 0.25s;
    box-sizing: border-box;
  }

  .input-wrapper input::placeholder { color: var(--text-muted); }

  .input-wrapper input:focus {
    border-color: var(--accent);
    box-shadow: 0 0 0 3px var(--accent-glow);
  }

  .input-wrapper:focus-within .input-icon {
    color: var(--accent-hover);
