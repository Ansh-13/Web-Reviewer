---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Dashboard | Website Reviewer">
  <div class="dashboard-container">
    <div class="glass-card hidden" id="dashboard-card">
      <div class="user-profile">
        <div class="avatar-container">
          <img id="user-avatar" src="https://www.gravatar.com/avatar/00000000000000000000000000000000?d=mp&f=y" alt="Avatar" />
        </div>
        <h1 id="user-name">Loading...</h1>
        <p id="user-email" class="subtitle">...</p>
      </div>

      <div class="info-section">
        <h3>Client Authentication Details (Firebase SDK)</h3>
        <div class="info-grid">
          <div class="info-item">
            <span class="label">User ID (UID)</span>
            <span class="value code" id="firebase-uid">...</span>
          </div>
          <div class="info-item">
            <span class="label">Provider</span>
            <span class="value" id="auth-provider">...</span>
          </div>
        </div>
      </div>

      <div class="info-section">
        <h3>Backend Verification Status (Express API)</h3>
        <div class="status-indicator">
          <span class="indicator-dot" id="status-dot"></span>
          <span id="backend-status">Verifying token with backend...</span>
        </div>
        <div class="info-grid hidden" id="backend-details">
          <div class="info-item">
            <span class="label">Backend Verified UID</span>
            <span class="value code" id="backend-uid">...</span>
          </div>
          <div class="info-item">
            <span class="label">Backend Verified Email</span>
            <span class="value" id="backend-email">...</span>
          </div>
        </div>
      </div>

      <button class="btn btn-logout" id="logout-btn">Log Out</button>
    </div>

    <!-- Central loading spinner -->
    <div class="loading-state" id="page-loader">
      <div class="spinner"></div>
      <p>Verifying authentication...</p>
    </div>
  </div>
</Layout>

<script>
  import { subscribeToAuthState, signOutOfAccount } from '../firebase/auth';

  const card = document.getElementById('dashboard-card') as HTMLDivElement;
  const pageLoader = document.getElementById('page-loader') as HTMLDivElement;
  const avatar = document.getElementById('user-avatar') as HTMLImageElement;
  const nameEl = document.getElementById('user-name') as HTMLHeadingElement;
  const emailEl = document.getElementById('user-email') as HTMLParagraphElement;
  const uidEl = document.getElementById('firebase-uid') as HTMLSpanElement;
  const providerEl = document.getElementById('auth-provider') as HTMLSpanElement;
  
  const statusDot = document.getElementById('status-dot') as HTMLSpanElement;
  const backendStatus = document.getElementById('backend-status') as HTMLSpanElement;
  const backendDetails = document.getElementById('backend-details') as HTMLDivElement;
  const backendUid = document.getElementById('backend-uid') as HTMLSpanElement;
  const backendEmail = document.getElementById('backend-email') as HTMLSpanElement;
  
  const logoutBtn = document.getElementById('logout-btn') as HTMLButtonElement;

  subscribeToAuthState(async (user) => {
    if (!user) {
      // Not logged in -> Redirect to login
      window.location.href = '/login';
      return;
    }

    // Set client-side info
    nameEl.textContent = user.displayName || 'Welcome Reviewer!';
    emailEl.textContent = user.email;
    uidEl.textContent = user.uid;
    avatar.src = user.photoURL || `https://api.dicebear.com/7.x/initials/svg?seed=${encodeURIComponent(user.email || 'user')}`;
    
    const provider = user.providerData[0]?.providerId;
    providerEl.textContent = provider === 'google.com' ? 'Google Sign-In' : 'Email & Password';

    // Show card, hide initial page loader
    pageLoader.classList.add('hidden');
    card.classList.remove('hidden');

    // Fetch and verify token with Express Backend
    try {
      const token = await user.getIdToken();
      const response = await fetch('http://localhost:3000/api/profile', {
        headers: {
          'Authorization': `Bearer ${token}`
        }
      });

      if (!response.ok) {
        throw new Error('Backend authentication verification failed');
      }

      const data = await response.json();
      
      // Update backend status to Success
      statusDot.className = 'indicator-dot success';
      backendStatus.textContent = 'Token verified successfully by Express Backend!';
      backendDetails.classList.remove('hidden');
      backendUid.textContent = data.uid;
      backendEmail.textContent = data.email;

    } catch (error: any) {
      console.error(error);
      statusDot.className = 'indicator-dot error';
      backendStatus.textContent = 'Verification failed: Could not connect to Express server.';
    }
  });

  // Handle Logout
  logoutBtn.addEventListener('click', async () => {
    try {
      await signOutOfAccount();
      window.location.href = '/login';
    } catch (error) {
      console.error('Failed to log out:', error);
    }
  });
</script>

<style>
  /* Premium Dark Theme and Glassmorphic Styling */
  :root {
    --bg-gradient: linear-gradient(135deg, #0f172a 0%, #1e1b4b 100%);
    --card-bg: rgba(30, 41, 59, 0.45);
    --card-border: rgba(255, 255, 255, 0.08);
    --text-primary: #f8fafc;
    --text-secondary: #94a3b8;
    --primary-color: #6366f1;
    --primary-hover: #4f46e5;
    --success-color: #10b981;
    --error-color: #ef4444;
  }

  .dashboard-container {
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: 100vh;
    background: var(--bg-gradient);
    font-family: 'Inter', system-ui, sans-serif;
    color: var(--text-primary);
    padding: 20px;
  }

  .glass-card {
    width: 100%;
    max-width: 520px;
    background: var(--card-bg);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border: 1px solid var(--card-border);
    border-radius: 24px;
    padding: 40px;
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.3);
  }

  .user-profile {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    margin-bottom: 32px;
  }

  .avatar-container {
    width: 96px;
    height: 96px;
    border-radius: 50%;
    overflow: hidden;
    border: 3px solid var(--primary-color);
    box-shadow: 0 0 20px rgba(99, 102, 241, 0.4);
    margin-bottom: 16px;
  }

  .avatar-container img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  h1 {
    font-size: 24px;
    font-weight: 700;
    margin: 0 0 4px 0;
  }

  .subtitle {
    font-size: 14px;
    color: var(--text-secondary);
    margin: 0;
  }

  .info-section {
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    padding: 24px 0;
  }

  .info-section h3 {
    font-size: 13px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--text-secondary);
    margin: 0 0 16px 0;
  }

  .info-grid {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .info-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 14px;
  }

  .info-item .label {
    color: var(--text-secondary);
  }

  .info-item .value {
    font-weight: 500;
    color: var(--text-primary);
  }

  .info-item .value.code {
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    background: rgba(15, 23, 42, 0.5);
    padding: 2px 6px;
    border-radius: 6px;
    font-size: 12px;
    max-width: 240px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  /* Status Indicator */
  .status-indicator {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 14px;
    margin-bottom: 16px;
  }

  .indicator-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background-color: var(--text-secondary);
    box-shadow: 0 0 8px var(--text-secondary);
    animation: pulse 1.5s infinite;
  }

  .indicator-dot.success {
    background-color: var(--success-color);
    box-shadow: 0 0 8px var(--success-color);
    animation: none;
  }

  .indicator-dot.error {
    background-color: var(--error-color);
    box-shadow: 0 0 8px var(--error-color);
    animation: none;
  }

  @keyframes pulse {
    0% { transform: scale(0.9); opacity: 0.6; }
    50% { transform: scale(1.1); opacity: 1; }
    100% { transform: scale(0.9); opacity: 0.6; }
  }

  /* Buttons */
  .btn {
    width: 100%;
    padding: 12px 24px;
    font-size: 15px;
    font-weight: 600;
    border-radius: 12px;
    border: none;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .btn-logout {
    background: rgba(239, 68, 68, 0.15);
    border: 1px solid rgba(239, 68, 68, 0.3);
    color: #fca5a5;
    margin-top: 12px;
  }

  .btn-logout:hover {
    background: rgba(239, 68, 68, 0.25);
    border-color: rgba(239, 68, 68, 0.5);
  }

  /* Page loader */
  .loading-state {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
    font-size: 14px;
    color: var(--text-secondary);
  }

  .spinner {
    width: 40px;
    height: 40px;
    border: 3px solid rgba(255, 255, 255, 0.1);
    border-radius: 50%;
    border-top-color: var(--primary-color);
    animation: spin 0.8s linear infinite;
  }

  @keyframes spin {
    to { transform: rotate(360deg); }
  }

  /* Utils */
  .hidden {
    display: none !important;
  }
</style>
