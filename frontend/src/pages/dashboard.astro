---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Web-Reviewer Dashboard">
  <!-- Include Tailwind CDN, Fonts, and Custom Config inside Layout -->
  <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries" is:inline></script>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@100..900&family=Hanken+Grotesk:wght@100..900&family=Geist:wght@100..900&family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet"/>
  
  <script id="tailwind-config" is:inline>
    tailwind.config = {
      darkMode: "class",
      theme: {
        extend: {
          "colors": {
            "surface-bright": "#363a3b",
            "secondary": "#bec6e0",
            "inverse-on-surface": "#2d3133",
            "secondary-fixed": "#dae2fd",
            "primary": "#d0bcff",
            "background": "#101415",
            "inverse-surface": "#e0e3e5",
            "on-tertiary-fixed-variant": "#3a485c",
            "on-primary": "#3c0091",
            "surface-variant": "#323537",
            "on-error": "#690005",
            "on-primary-container": "#340080",
            "on-surface": "#e0e3e5",
            "on-background": "#e0e3e5",
            "on-secondary-container": "#adb4ce",
            "on-tertiary-container": "#1c2a3d",
            "inverse-primary": "#6d3bd7",
            "surface-dim": "#101415",
            "primary-fixed-dim": "#d0bcff",
            "surface-container-highest": "#323537",
            "on-primary-fixed-variant": "#5516be",
            "error": "#ffb4ab",
            "tertiary-fixed-dim": "#b9c7e0",
            "secondary-container": "#3f465c",
            "surface-container": "#1d2022",
            "surface-container-lowest": "#0b0f10",
            "on-tertiary-fixed": "#0d1c2f",
            "on-primary-fixed": "#23005c",
            "surface-tint": "#d0bcff",
            "secondary-fixed-dim": "#bec6e0",
            "outline": "#958ea0",
            "tertiary-fixed": "#d5e3fd",
            "error-container": "#93000a",
            "on-secondary": "#283044",
            "surface": "#101415",
            "outline-variant": "#494454",
            "surface-container-low": "#191c1e",
            "tertiary-container": "#8392a9",
            "on-error-container": "#ffdad6",
            "surface-container-high": "#272a2c",
            "tertiary": "#b9c7e0",
            "primary-container": "#a078ff",
            "on-secondary-fixed-variant": "#3f465c",
            "primary-fixed": "#e9ddff",
            "on-tertiary": "#233144",
            "on-surface-variant": "#cbc3d7",
            "on-secondary-fixed": "#131b2e"
          },
          "borderRadius": {
            "DEFAULT": "0.25rem",
            "lg": "0.5rem",
            "xl": "0.75rem",
            "full": "9999px"
          },
          "spacing": {
            "sm": "1rem",
            "xl": "4rem",
            "md": "1.5rem",
            "container-max": "1280px",
            "xs": "0.5rem",
            "base": "4px",
            "lg": "2.5rem",
            "gutter": "24px"
          },
          "fontFamily": {
            "headline-md": ["Hanken Grotesk"],
            "body-md": ["Inter"],
            "body-lg": ["Inter"],
            "label-md": ["Geist"],
            "body-sm": ["Inter"],
            "label-sm": ["Geist"],
            "headline-lg": ["Hanken Grotesk"]
          },
          "fontSize": {
            "headline-md": ["24px", {"lineHeight": "1.3", "fontWeight": "600"}],
            "body-md": ["16px", {"lineHeight": "1.5", "fontWeight": "400"}],
            "body-lg": ["18px", {"lineHeight": "1.6", "fontWeight": "400"}],
            "label-md": ["14px", {"lineHeight": "1.2", "letterSpacing": "0.05em", "fontWeight": "500"}],
            "body-sm": ["14px", {"lineHeight": "1.5", "fontWeight": "400"}],
            "label-sm": ["12px", {"lineHeight": "1", "fontWeight": "600"}],
            "headline-lg": ["48px", {"lineHeight": "1.1", "letterSpacing": "-0.02em", "fontWeight": "700"}]
          }
        },
      },
    }
  </script>

  <style is:inline>
    body {
      background-color: #101415;
      color: #e0e3e5;
      overflow-x: hidden;
    }
    .glass-card {
      backdrop-filter: blur(16px);
      background: linear-gradient(135deg, rgba(255, 255, 255, 0.05), rgba(255, 255, 255, 0));
      border: 1px solid rgba(255, 255, 255, 0.1);
      transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }
    .glass-card:hover {
      transform: translateY(-4px);
      border-color: rgba(139, 92, 246, 0.3);
      box-shadow: 0 8px 32px rgba(139, 92, 246, 0.05);
    }
    .primary-glow:hover {
      box-shadow: 0 0 20px rgba(208, 188, 255, 0.3);
    }
    .custom-scrollbar::-webkit-scrollbar {
      width: 6px;
    }
    .custom-scrollbar::-webkit-scrollbar-track {
      background: rgba(255, 255, 255, 0.02);
    }
    .custom-scrollbar::-webkit-scrollbar-thumb {
      background: rgba(255, 255, 255, 0.1);
      border-radius: 10px;
    }
  </style>

  <!-- TopNavBar -->
  <header class="bg-surface/70 dark:bg-surface-container/70 backdrop-blur-md w-full sticky top-0 z-50 border-b border-white/10 shadow-sm">
    <div class="flex justify-between items-center px-md py-xs max-w-container-max mx-auto h-16">
      <div class="flex items-center gap-xl">
        <span class="font-headline-md text-headline-md font-bold text-primary">Web-Reviewer</span>
        <nav class="hidden md:flex items-center gap-md">
          <a class="text-primary font-bold border-b-2 border-primary pb-1 font-body-md text-body-md transition-colors duration-200 cursor-pointer" href="/dashboard">Dashboard</a>
          <a class="text-on-surface-variant font-medium hover:text-primary transition-colors duration-200 font-body-md text-body-md cursor-pointer" href="#">Reports</a>
        </nav>
      </div>
      <div class="flex items-center gap-md">
        <button class="material-symbols-outlined text-on-surface-variant hover:text-primary cursor-pointer active:opacity-80">settings</button>
        <div class="w-8 h-8 rounded-full overflow-hidden border border-primary/20">
          <img id="nav-avatar" alt="User profile avatar" class="w-full h-full object-cover" src="https://lh3.googleusercontent.com/aida-public/AB6AXuDSfJHXVND0YJ5iinjW-EAHOi5OSgIH_WahKHEgb8NdKeiklfuhPCa2lf4sYY-yqo8LWN8Nt7QGc_HjkEELNk_J2DIKn-Acq-BpbDfxfOgVrnYPjy_hbRN--0y6wZTfnjlqF5ZhgZ1eCu7WxO5VMMOzRv5k3FN1vU9BTDNA9tCkFtzrvDZ0TErrx01OZsq8pawJmHorBIHSbbCYz-uaGxHHEIFWt7D6mHwUJujWjNRAdP2qZ66vTzz7Rw"/>
        </div>
        <button class="nav-btn-logout ml-2 material-symbols-outlined text-red-400/80 hover:text-red-400 cursor-pointer" id="logout-btn" title="Sign out">logout</button>
      </div>
    </div>
  </header>

  <main class="max-w-container-max mx-auto px-md py-lg grid grid-cols-12 gap-gutter min-h-[calc(100vh-140px)]">
    <!-- Loader Spinner -->
    <div class="col-span-12 flex flex-col items-center justify-center py-20" id="page-loader">
      <div class="w-10 h-10 border-4 border-white/5 border-t-primary rounded-full animate-spin"></div>
      <p class="text-on-surface-variant text-label-md mt-4">Verifying authentication…</p>
    </div>

    <!-- Main Content Layout (Hidden while loading auth) -->
    <div class="col-span-12 grid grid-cols-12 gap-gutter hidden w-full" id="content-area">
      <!-- Left Sidebar: Create Project -->
      <aside class="col-span-12 lg:col-span-4 xl:col-span-3 space-y-md">
        <div class="glass-card p-md rounded-xl sticky top-24">
          <div class="flex items-center gap-xs mb-md">
            <span class="material-symbols-outlined text-primary" data-weight="fill" style="font-variation-settings: 'FILL' 1;">add_circle</span>
            <h2 class="font-headline-md text-headline-md text-on-surface">New Project</h2>
          </div>
          <p class="text-on-surface-variant font-body-sm mb-lg">Build a new project to keep the track of your seo for a website</p>
          
          <form id="create-project-form" class="space-y-sm" autocomplete="off">
            <div class="space-y-base">
              <label class="font-label-sm text-on-surface-variant ml-1">PROJECT NAME</label>
              <input id="project-name" class="w-full bg-black/40 border border-white/10 rounded-lg px-md py-sm text-body-md focus:outline-none focus:border-primary transition-all placeholder:text-on-surface-variant/40 text-white" placeholder="eg. Portfolio" type="text" required/>
            </div>
            
            <div class="space-y-base">
              <label class="font-label-sm text-on-surface-variant ml-1">DESCRIPTION</label>
              <textarea id="project-desc" rows="3" class="w-full bg-black/40 border border-white/10 rounded-lg px-md py-sm text-body-md focus:outline-none focus:border-primary transition-all placeholder:text-on-surface-variant/40 text-white resize-none" placeholder="Briefly describe what this project is about…" required></textarea>
            </div>

            <!-- Feedback banner -->
            <div class="form-feedback hidden mt-2 text-label-sm p-3 rounded-lg" id="form-feedback">
              <span class="feedback-icon" id="feedback-icon"></span>
              <span id="feedback-msg"></span>
            </div>

            <button type="submit" id="submit-btn" class="w-full bg-primary text-on-primary font-label-md py-md rounded-lg primary-glow transition-all flex items-center justify-center gap-xs mt-lg">
              <span id="btn-label" class="flex items-center justify-center gap-xs">
                <span class="material-symbols-outlined text-[20px]">rocket_launch</span>
                CREATE PROJECT
              </span>
              <span class="w-5 h-5 border-2 border-on-primary/20 border-t-on-primary rounded-full animate-spin hidden" id="btn-spinner"></span>
            </button>
          </form>

          <!-- Quick Stats -->
          <div class="mt-xl pt-xl border-t border-white/5 space-y-md">
            <div class="flex justify-between items-center">
              <span class="text-on-surface-variant font-label-md">Total Projects</span>
              <span class="text-on-surface font-headline-md" id="stat-total-projects">00</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-on-surface-variant font-label-md">Pending Audits</span>
              <span class="text-tertiary font-headline-md" id="stat-pending-audits">00</span>
            </div>
          </div>
        </div>
      </aside>

      <!-- Right Content: Your Projects -->
      <section class="col-span-12 lg:col-span-8 xl:col-span-9 space-y-md">
        <div class="flex justify-between items-end mb-sm">
          <div>
            <h1 class="font-headline-lg text-headline-lg text-on-surface">Your Projects</h1>
            <p class="text-on-surface-variant font-body-md mt-xs">Manage and monitor your active auditing streams.</p>
          </div>
          <div class="flex gap-xs">
            <button class="action-btn filter-btn glass-card px-md py-xs rounded-full flex items-center gap-xs text-label-sm text-on-surface-variant hover:text-on-surface cursor-pointer">
              <span class="material-symbols-outlined text-[18px]">filter_list</span>
              Filter
            </button>
            <button class="action-btn sort-btn glass-card px-md py-xs rounded-full flex items-center gap-xs text-label-sm text-on-surface-variant hover:text-on-surface cursor-pointer">
              <span class="material-symbols-outlined text-[18px]">sort</span>
              Latest
            </button>
          </div>
        </div>

        <!-- Skeleton loader -->
        <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-md" id="projects-skeleton">
          <div class="glass-card p-md rounded-xl flex flex-col justify-between h-[220px]">
            <div class="skeleton-line w60 h-4 bg-white/5 rounded"></div>
            <div class="skeleton-line w40 h-3 bg-white/5 rounded"></div>
          </div>
          <div class="glass-card p-md rounded-xl flex flex-col justify-between h-[220px]">
            <div class="skeleton-line w50 h-4 bg-white/5 rounded"></div>
            <div class="skeleton-line w30 h-3 bg-white/5 rounded"></div>
          </div>
          <div class="glass-card p-md rounded-xl flex flex-col justify-between h-[220px]">
            <div class="skeleton-line w70 h-4 bg-white/5 rounded"></div>
            <div class="skeleton-line w45 h-3 bg-white/5 rounded"></div>
          </div>
        </div>

        <!-- Projects Grid -->
        <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-md hidden" id="projects-list"></div>

        <!-- Empty State -->
        <div class="glass-card p-xl rounded-xl text-center hidden" id="projects-empty">
          <span class="material-symbols-outlined text-primary text-[48px] mb-sm">folder_open</span>
          <p class="font-headline-md text-headline-md text-on-surface">No projects yet</p>
          <span class="text-on-surface-variant text-body-sm block mt-xs">Create your first project on the left to get started.</span>
        </div>

        <!-- Detailed Table View (Recent Activity) -->
        <div class="mt-xl">
          <div class="flex items-center gap-xs mb-md">
            <span class="material-symbols-outlined text-secondary" data-weight="fill" style="font-variation-settings: 'FILL' 1;">analytics</span>
            <h2 class="font-headline-md text-headline-md text-on-surface">Recent Activity</h2>
          </div>
          <div class="glass-card rounded-xl overflow-hidden">
            <table class="w-full text-left border-collapse">
              <thead>
                <tr class="bg-white/5 text-on-surface-variant font-label-sm uppercase tracking-wider">
                  <th class="px-md py-sm font-medium">Project</th>
                  <th class="px-md py-sm font-medium">Owner</th>
                  <th class="px-md py-sm font-medium text-right font-label-sm">Last Updated</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-white/5" id="activity-table-body">
                <!-- Activity Rows dynamically generated -->
              </tbody>
            </table>
          </div>
        </div>
      </section>
    </div>
  </main>

  <!-- Footer -->
  <footer class="bg-surface-container-lowest w-full py-md border-t border-white/5 mt-auto">
    <div class="flex flex-col md:flex-row justify-between items-center px-md max-w-container-max mx-auto gap-md">
      <div class="flex items-center gap-md">
        <span class="text-label-md font-bold text-on-surface">Web-Reviewer</span>
        <span class="font-label-sm text-label-sm text-secondary">© 2024 Web-Reviewer Systems. All rights reserved.</span>
      </div>
      <nav class="flex items-center gap-lg">
        <a class="text-on-surface-variant font-label-sm transition-colors hover:text-on-surface underline-offset-4 hover:underline" href="#">Privacy Policy</a>
        <a class="text-on-surface-variant font-label-sm transition-colors hover:text-on-surface underline-offset-4 hover:underline" href="#">Terms of Service</a>
        <a class="text-on-surface-variant font-label-sm transition-colors hover:text-on-surface underline-offset-4 hover:underline" href="#">Help Center</a>
      </nav>
    </div>
  </footer>
</Layout>

<!-- ───────── CLIENT-SIDE SCRIPT ───────── -->
<script>
  import { subscribeToAuthState, signOutOfAccount } from '../firebase/auth';

  /* ── DOM refs ── */
  const pageLoader      = document.getElementById('page-loader') as HTMLDivElement;
  const contentArea      = document.getElementById('content-area') as HTMLElement;
  const navAvatar        = document.getElementById('nav-avatar') as HTMLImageElement;
  const logoutBtn        = document.getElementById('logout-btn') as HTMLButtonElement;
  const form             = document.getElementById('create-project-form') as HTMLFormElement;
  const nameInput        = document.getElementById('project-name') as HTMLInputElement;
  const descInput        = document.getElementById('project-desc') as HTMLTextAreaElement;
  const feedbackBox      = document.getElementById('form-feedback') as HTMLDivElement;
  const feedbackIcon     = document.getElementById('feedback-icon') as HTMLSpanElement;
  const feedbackMsg      = document.getElementById('feedback-msg') as HTMLSpanElement;
  const submitBtn        = document.getElementById('submit-btn') as HTMLButtonElement;
  const btnLabel         = document.getElementById('btn-label') as HTMLSpanElement;
  const btnSpinner       = document.getElementById('btn-spinner') as HTMLSpanElement;
  const projectsSkeleton = document.getElementById('projects-skeleton') as HTMLDivElement;
  const projectsList     = document.getElementById('projects-list') as HTMLDivElement;
  const projectsEmpty    = document.getElementById('projects-empty') as HTMLDivElement;
  const searchInput      = document.getElementById('search-input') as HTMLInputElement;
  const statTotalProjects= document.getElementById('stat-total-projects') as HTMLSpanElement;
  const statPendingAudits = document.getElementById('stat-pending-audits') as HTMLSpanElement;

  let currentToken: string | null = null;
  let userEmailStr = 'User';
  let allFetchedProjects: any[] = [];
  let currentFilter: 'all' | 'open' | 'inprogress' | 'archived' = 'all';
  let isSortedAlpha = false;

  /* ── Auth gate ── */
  subscribeToAuthState(async (user) => {
    if (!user) { window.location.href = '/login'; return; }

    userEmailStr = user.email || 'User';
    navAvatar.src = user.photoURL || `https://api.dicebear.com/7.x/initials/svg?seed=${encodeURIComponent(user.email || 'user')}`;

    currentToken = await user.getIdToken();

    // Register/sync user profile in backend database
    try {
      await fetch('http://localhost:3000/api/profile', {
        headers: {
          'Authorization': `Bearer ${currentToken}`
        }
      });
    } catch (e) {
      console.error('Failed to sync profile with database:', e);
    }

    pageLoader.classList.add('hidden');
    contentArea.classList.remove('hidden');

    // Fetch existing projects once auth resolves
    fetchProjects();
  });

  /* ── Logout ── */
  logoutBtn.addEventListener('click', async () => {
    try { await signOutOfAccount(); window.location.href = '/login'; }
    catch (e) { console.error('Logout failed', e); }
  });

  /* ── Helpers ── */
  function showFeedback(type: 'success' | 'error', msg: string) {
    feedbackBox.className = `form-feedback ${type === 'success' ? 'bg-emerald-500/10 text-emerald-400 border border-emerald-500/20' : 'bg-red-500/10 text-red-400 border border-red-500/20'} text-label-sm p-3 rounded-lg mt-2`;
    feedbackIcon.textContent = type === 'success' ? '✓ ' : '✕ ';
    feedbackMsg.textContent = msg;
    feedbackBox.classList.remove('hidden');
  }

  function setLoading(on: boolean) {
    submitBtn.disabled = on;
    btnLabel.classList.toggle('hidden', on);
    btnSpinner.classList.toggle('hidden', !on);
  }

  function formatDate(dateStr?: string) {
    if (!dateStr) return 'Recent';
    const date = new Date(dateStr);
    if (isNaN(date.getTime())) return 'Recent';
    return date.toLocaleDateString('en-US', {
      month: 'short',
      day: 'numeric',
      year: 'numeric'
    });
  }

  function getIconName(description: string) {
    const desc = description.toLowerCase();
    if (desc.includes('security') || desc.includes('vulnerability')) return 'security';
    if (desc.includes('performance') || desc.includes('seo') || desc.includes('monitoring')) return 'monitoring';
    if (desc.includes('accessibility') || desc.includes('ui/ux') || desc.includes('interface')) return 'inventory_2';
    return 'data_thresholding';
  }

  function getIconClass(description: string) {
    const desc = description.toLowerCase();
    if (desc.includes('security') || desc.includes('vulnerability')) {
      return 'bg-primary-container/20 text-primary';
    }
    if (desc.includes('performance') || desc.includes('seo') || desc.includes('monitoring')) {
      return 'bg-tertiary-container/20 text-tertiary';
    }
    if (desc.includes('accessibility') || desc.includes('ui/ux') || desc.includes('interface')) {
      return 'bg-on-surface-variant/10 text-on-surface-variant';
    }
    return 'bg-primary-container/20 text-primary';
  }

  /* ── Create Project ── */
  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    feedbackBox.classList.add('hidden');
    const projectName = nameInput.value.trim();
    const description = descInput ? descInput.value.trim() : '';

    if (!projectName) { showFeedback('error', 'Project name is required.'); return; }
    if (!currentToken) { showFeedback('error', 'Authentication expired. Please reload.'); return; }

    setLoading(true);
    try {
      const res = await fetch('http://localhost:3000/api/v1/create', {
        method: 'POST',
        headers: {
          'Authorization': `Bearer ${currentToken}`,
          'project_name': projectName,
          'description': description,
          'Content-Type': 'application/json',
        },
      });

      if (res.status === 409) {
        showFeedback('error', 'A project with that name already exists. Choose another.');
      } else if (!res.ok) {
        const body = await res.json().catch(() => null);
        throw new Error(typeof body === 'string' ? body : 'Something went wrong.');
      } else {
        showFeedback('success', `Project "${projectName}" created! Redirecting…`);
        fetchProjects();
        setTimeout(() => {
          window.location.href = `/scanned?project=${encodeURIComponent(projectName)}`;
        }, 800);
      }
    } catch (err: any) {
      showFeedback('error', err.message || 'Could not reach the server.');
    } finally {
      setLoading(false);
    }
  });

  /* ── Fetch & Render Projects ── */
  async function fetchProjects() {
    projectsSkeleton.classList.remove('hidden');
    projectsList.classList.add('hidden');
    projectsEmpty.classList.add('hidden');

    try {
      if (!currentToken) return;

      const res = await fetch('http://localhost:3000/api/v1/getprojects', {
        headers: { 'Authorization': `Bearer ${currentToken}` },
      });

      if (!res.ok) throw new Error('Failed to load projects');

      const body = await res.json();
      const rawProjects = body.data || [];

      // Fetch scans and project info for each project in parallel
      const projectsWithScans = await Promise.all(
        rawProjects.map(async (p: any) => {
          let scans = [];
          let projectInfo = null;

          try {
            const scanRes = await fetch('http://localhost:3000/api/v1/getScan', {
              headers: { 
                'Authorization': `Bearer ${currentToken}`,
                'project_name': p.name
              }
            });
            if (scanRes.ok) {
              const scanData = await scanRes.json();
              scans = scanData.data || [];
            }
          } catch (e) {
            console.error(`Failed to fetch scans for project ${p.name}`, e);
          }

          if (p.id) {
            try {
              const infoRes = await fetch(`http://localhost:3000/api/project/info?projectid=${p.id}`, {
                headers: { 
                  'Authorization': `Bearer ${currentToken}`
                }
              });
              if (infoRes.ok) {
                projectInfo = await infoRes.json();
              }
            } catch (e) {
              console.error(`Failed to fetch info for project ${p.name}`, e);
            }
          }

          return {
            ...p,
            scans,
            projectInfo
          };
        })
      );

      allFetchedProjects = projectsWithScans;

      projectsSkeleton.classList.add('hidden');

      // Update stats display
      const totalCount = allFetchedProjects.length;
      const pendingCount = allFetchedProjects.filter(p => 
        p.scans && p.scans.some((s: any) => s.status === 'Pending')
      ).length;
      statTotalProjects.textContent = totalCount < 10 ? `0${totalCount}` : `${totalCount}`;
      statPendingAudits.textContent = pendingCount < 10 ? `0${pendingCount}` : `${pendingCount}`;

      applyFiltersAndRender();
      renderRecentActivity(allFetchedProjects, userEmailStr);

    } catch (err) {
      console.error(err);
      projectsSkeleton.classList.add('hidden');
      projectsEmpty.classList.remove('hidden');
    }
  }

  function applyFiltersAndRender() {
    let filtered = [...allFetchedProjects];

    // Search query filter
    const query = searchInput ? searchInput.value.toLowerCase().trim() : '';
    if (query) {
      filtered = filtered.filter(p => p.name.toLowerCase().includes(query));
    }

    // Status filter
    if (currentFilter !== 'all') {
      filtered = filtered.filter(p => {
        const scans = p.scans || [];
        const hasPending = scans.some((s: any) => s.status === 'Pending');
        const hasCompleted = scans.some((s: any) => s.status === 'Completed');
        const isLegacy = p.name.toLowerCase().includes('legacy');

        if (currentFilter === 'inprogress') return hasPending && !isLegacy;
        if (currentFilter === 'archived') return isLegacy;
        return (hasCompleted || scans.length === 0) && !isLegacy; // open / complete
      });
    }

    // Sort order
    if (isSortedAlpha) {
      filtered.sort((a, b) => a.name.localeCompare(b.name));
    } else {
      // Newest first based on creation date or position
      filtered.reverse();
    }

    renderProjectsList(filtered);
  }

  function renderProjectsList(projects: any[]) {
    if (projects.length === 0) {
      projectsEmpty.classList.remove('hidden');
      projectsList.classList.add('hidden');
      return;
    }

    projectsEmpty.classList.add('hidden');
    projectsList.classList.remove('hidden');

    projectsList.innerHTML = projects.map((p, i) => {
      const desc = p.description || 'Security Compliance';
      const iconName = getIconName(desc);
      const iconClass = getIconClass(desc);
      
      let statusBadge = 'Open';
      let badgeClass = 'bg-emerald-500/10 text-emerald-400 border border-emerald-500/20';
      let rightWidget = '';
      let timeAgo = 'Recent';

      const projectScans = p.scans || [];
      const hasPending = projectScans.some((s: any) => s.status === 'Pending');
      const hasCompleted = projectScans.some((s: any) => s.status === 'Completed');
      const latestScan = projectScans.length > 0 ? projectScans[projectScans.length - 1] : null;

      if (latestScan && latestScan.started_at) {
        const msDiff = Date.now() - new Date(latestScan.started_at).getTime();
        const mins = Math.floor(msDiff / 60000);
        const hours = Math.floor(mins / 60);
        const days = Math.floor(hours / 24);

        if (days > 0) timeAgo = `Last scan - ${days}d ago`;
        else if (hours > 0) timeAgo = `Last scan - ${hours}h ago`;
        else if (mins > 0) timeAgo = `Last scan - ${mins}m ago`;
        else timeAgo = 'Last scan - Just now';
      } else if (p.created_at) {
        const msDiff = Date.now() - new Date(p.created_at).getTime();
        const mins = Math.floor(msDiff / 60000);
        const hours = Math.floor(mins / 60);
        const days = Math.floor(hours / 24);

        if (days > 0) timeAgo = `Created - ${days}d ago`;
        else if (hours > 0) timeAgo = `Created - ${hours}h ago`;
        else if (mins > 0) timeAgo = `Created - ${mins}m ago`;
        else timeAgo = 'Created - Just now';
      } else {
        timeAgo = 'No scans yet';
      }

      if (p.name.toLowerCase().includes('legacy')) {
        statusBadge = 'Archived';
        badgeClass = 'bg-white/5 text-on-surface-variant border border-white/10';
        rightWidget = `<span class="text-on-surface-variant text-[11px] font-medium px-2 py-0.5 rounded-full bg-white/5 border border-white/10">Archived</span>`;
      } else if (hasPending) {
        statusBadge = 'In progress';
        badgeClass = 'bg-blue-500/10 text-blue-400 border border-blue-500/20';
        rightWidget = `
          <div class="flex items-center gap-2">
            <span class="text-[11px] text-blue-400 font-medium">Scanning...</span>
            <div class="w-20 h-1.5 bg-white/10 rounded-full overflow-hidden">
              <div class="bg-blue-400 w-[65%] h-full animate-pulse"></div>
            </div>
          </div>
        `;
      } else if (hasCompleted) {
        statusBadge = 'Completed';
        badgeClass = 'bg-emerald-500/10 text-emerald-400 border border-emerald-500/20';
        rightWidget = `
          <div class="flex items-center gap-2">
            <span class="text-[11px] text-emerald-400 font-medium">Done</span>
            <div class="w-20 h-1.5 bg-emerald-500/20 rounded-full overflow-hidden">
              <div class="bg-emerald-400 w-full h-full"></div>
            </div>
          </div>
        `;
      } else {
        statusBadge = 'Ready';
        badgeClass = 'bg-white/5 text-on-surface-variant border border-white/10';
        rightWidget = `
          <div class="flex items-center gap-2">
            <span class="text-[11px] text-on-surface-variant font-medium">Ready</span>
            <div class="w-20 h-1.5 bg-white/10 rounded-full overflow-hidden">
              <div class="bg-white/20 w-0 h-full"></div>
            </div>
          </div>
        `;
      }

      const info = p.projectInfo;
      const scanCount = info?.count ?? (p.scans?.length || 0);
      const seoScore = info?.data?.score;
      const seoGrade = info?.data?.grade;
      const issuesCount = info?.data?.issues;

      return `
        <a href="/scanned?project=${encodeURIComponent(p.name)}" class="project-card-link flex" data-name="${p.name}">
          <div class="glass-card p-md rounded-xl flex flex-col justify-between h-[220px] w-full group cursor-pointer relative overflow-hidden">
            <div>
              <div class="flex justify-between items-start mb-md">
                <div class="w-10 h-10 rounded-lg ${iconClass} flex items-center justify-center shrink-0">
                  <span class="material-symbols-outlined">${iconName}</span>
                </div>
                <div class="flex items-center gap-1.5 flex-wrap justify-end max-w-[75%]">
                  ${seoScore !== null && seoScore !== undefined ? `<span class="px-2 py-0.5 text-[11px] font-bold rounded-md bg-emerald-500/10 text-emerald-400 border border-emerald-500/20">Score: ${seoScore}</span>` : ''}
                  ${seoGrade ? `<span class="px-2 py-0.5 text-[11px] font-bold rounded-md bg-primary/20 text-primary border border-primary/30">Grade: ${seoGrade}</span>` : ''}
                  ${issuesCount !== null && issuesCount !== undefined ? `<span class="px-2 py-0.5 text-[11px] font-bold rounded-md bg-error/10 text-error border border-error/20">${issuesCount} ${issuesCount === 1 ? 'Issue' : 'Issues'}</span>` : ''}
                  <span class="px-2 py-0.5 text-[11px] font-medium rounded-md bg-white/5 text-on-surface-variant border border-white/10">${scanCount} ${scanCount === 1 ? 'Scan' : 'Scans'}</span>
                </div>
              </div>
              <h3 class="font-headline-md text-headline-md text-on-surface mb-xs truncate" title="${p.name}">${p.name}</h3>
              <p class="text-on-surface-variant font-body-sm line-clamp-1">${desc}</p>
            </div>

            <div class="flex items-center justify-between pt-md border-t border-white/5">
              <span class="text-on-surface-variant text-[11px] font-medium flex items-center gap-1 opacity-80">
                <span class="material-symbols-outlined text-[11px]">schedule</span>
                ${timeAgo}
              </span>
            </div>
          </div>
        </a>
      `;
    }).join('') + `
      <div class="glass-card p-md rounded-xl border-dashed flex flex-col items-center justify-center h-[220px] group cursor-pointer hover:bg-white/5" id="quick-add-btn">
        <div class="w-12 h-12 rounded-full border border-dashed border-white/20 flex items-center justify-center text-on-surface-variant group-hover:text-primary group-hover:border-primary transition-all">
          <span class="material-symbols-outlined">add</span>
        </div>
        <p class="mt-md font-label-md text-on-surface-variant group-hover:text-on-surface">Quick Add Template</p>
      </div>
    `;

    // Hook up quick add click handler
    const quickAddBtn = document.getElementById('quick-add-btn');
    if (quickAddBtn) {
      quickAddBtn.addEventListener('click', () => {
        nameInput.focus();
        nameInput.scrollIntoView({ behavior: 'smooth', block: 'center' });
      });
    }
  }

  function renderRecentActivity(projects: any[], userEmail: string) {
    const tableBody = document.getElementById('activity-table-body');
    if (!tableBody) return;

    // Gather all scans from all projects
    const allScans: any[] = [];
    projects.forEach((p: any) => {
      if (p.scans && Array.isArray(p.scans)) {
        p.scans.forEach((s: any) => {
          allScans.push({
            projectName: p.name,
            status: s.status,
            started_at: s.started_at
          });
        });
      }
    });

    if (allScans.length === 0) {
      // Default mockup rows
      tableBody.innerHTML = `
        <tr class="hover:bg-white/5 transition-colors cursor-pointer">
          <td class="px-md py-md font-body-md">Global CDN Review</td>
          <td class="px-md py-md text-on-surface-variant font-body-sm">Alex Rivera</td>
          <td class="px-md py-md text-right text-on-surface-variant font-label-sm">Jun 14, 2024</td>
        </tr>
        <tr class="hover:bg-white/5 transition-colors cursor-pointer">
          <td class="px-md py-md font-body-md">Auth Module Audit</td>
          <td class="px-md py-md text-on-surface-variant font-body-sm">Sarah Chen</td>
          <td class="px-md py-md text-right text-on-surface-variant font-label-sm">Jun 12, 2024</td>
        </tr>
        <tr class="hover:bg-white/5 transition-colors cursor-pointer">
          <td class="px-md py-md font-body-md">Payment Gateway Beta</td>
          <td class="px-md py-md text-on-surface-variant font-body-sm">Marcus Vogt</td>
          <td class="px-md py-md text-right text-on-surface-variant font-label-sm">Jun 10, 2024</td>
        </tr>
      `;
      return;
    }

    // Sort scans by started_at descending (newest first)
    allScans.sort((a, b) => {
      const timeA = a.started_at ? new Date(a.started_at).getTime() : 0;
      const timeB = b.started_at ? new Date(b.started_at).getTime() : 0;
      return timeB - timeA;
    });

    tableBody.innerHTML = allScans.slice(0, 5).map((scan, i) => {
      let statusText = 'Completed';
      let dotClass = 'bg-emerald-400';
      
      if (scan.status === 'Pending') {
        statusText = 'Reviewing';
        dotClass = 'bg-blue-400';
      } else if (scan.status === 'Completed') {
        statusText = 'Completed';
        dotClass = 'bg-emerald-400';
      } else {
        statusText = 'Flagged';
        dotClass = 'bg-error';
      }

      const formattedDate = formatDate(scan.started_at);
      const owner = userEmail.split('@')[0];
      const capitalizedOwner = owner.charAt(0).toUpperCase() + owner.slice(1);
      
      return `
        <tr class="hover:bg-white/5 transition-colors cursor-pointer" onclick="window.location.href='/scanned?project=${encodeURIComponent(scan.projectName)}'">
          <td class="px-md py-md font-body-md">${scan.projectName}</td>
          <td class="px-md py-md text-on-surface-variant font-body-sm">${capitalizedOwner}</td>
          <td class="px-md py-md text-right text-on-surface-variant font-label-sm">${formattedDate}</td>
        </tr>
      `;
    }).join('');
  }

  /* ── Interactive Actions ── */
  if (searchInput) {
    searchInput.addEventListener('input', () => {
      applyFiltersAndRender();
    });
  }

  const sortBtn = document.querySelector('.sort-btn') as HTMLButtonElement;
  if (sortBtn) {
    sortBtn.addEventListener('click', () => {
      isSortedAlpha = !isSortedAlpha;
      sortBtn.innerHTML = `
        <span class="material-symbols-outlined text-[18px]">sort</span>
        ${isSortedAlpha ? 'A-Z' : 'Latest'}
      `;
      applyFiltersAndRender();
    });
  }

  const filterBtn = document.querySelector('.filter-btn') as HTMLButtonElement;
  if (filterBtn) {
    filterBtn.addEventListener('click', () => {
      if (currentFilter === 'all') currentFilter = 'inprogress';
      else if (currentFilter === 'inprogress') currentFilter = 'archived';
      else if (currentFilter === 'archived') currentFilter = 'all';

      filterBtn.innerHTML = `
        <span class="material-symbols-outlined text-[18px]">filter_list</span>
        Filter: ${currentFilter === 'all' ? 'All' : currentFilter === 'inprogress' ? 'In Progress' : currentFilter === 'archived' ? 'Archived' : 'Open'}
      `;
      applyFiltersAndRender();
    });
  }
</script>
