---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Dashboard | Web-Reviewer">
  <!-- ───────── NAVBAR ───────── -->
  <nav class="navbar" id="main-nav">
    <div class="nav-inner">
      <a href="/dashboard" class="nav-brand">
        <span class="brand-icon">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="url(#brand-grad)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <defs><linearGradient id="brand-grad" x1="0" y1="0" x2="24" y2="24"><stop offset="0%" stop-color="#818cf8"/><stop offset="100%" stop-color="#6366f1"/></linearGradient></defs>
            <circle cx="12" cy="12" r="10"/>
            <path d="M8 12l2 2 4-4"/>
          </svg>
        </span>
        <span class="brand-text">Web-Reviewer</span>
      </a>

      <div class="nav-right">
        <div class="nav-user" id="nav-user-info">
          <img id="nav-avatar" class="nav-avatar" src="https://www.gravatar.com/avatar/00000000000000000000000000000000?d=mp&f=y" alt="Avatar" />
          <span class="nav-name" id="nav-name">...</span>
        </div>
        <button class="nav-btn-logout" id="logout-btn" title="Sign out">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
        </button>
      </div>
    </div>
  </nav>

  <!-- ───────── PAGE CONTENT ───────── -->
  <main class="dashboard-main">
    <!-- Loading spinner (shown while auth is resolving) -->
    <div class="loading-state" id="page-loader">
      <div class="spinner"></div>
      <p>Verifying authentication…</p>
    </div>

    <!-- Create-project card (hidden until auth resolves) -->
    <section class="content-wrapper hidden" id="content-area">
      <div class="section-header">
        <h1>Create a New Project</h1>
        <p class="section-subtitle">Give your website review project a name and an optional description to get started.</p>
      </div>

      <form class="glass-card" id="create-project-form" autocomplete="off">
        <!-- Project Name -->
        <div class="form-group">
          <label for="project-name">Project Name <span class="required">*</span></label>
          <div class="input-wrapper">
            <svg class="input-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/></svg>
            <input type="text" id="project-name" name="project_name" placeholder="e.g. My Portfolio Audit" required />
          </div>
        </div>

        <!-- Description -->
        <div class="form-group">
          <label for="project-desc">Description <span class="optional">(optional)</span></label>
          <div class="input-wrapper textarea-wrapper">
            <svg class="input-icon textarea-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="17" y1="10" x2="3" y2="10"/><line x1="21" y1="6" x2="3" y2="6"/><line x1="21" y1="14" x2="3" y2="14"/><line x1="17" y1="18" x2="3" y2="18"/></svg>
            <textarea id="project-desc" name="description" rows="3" placeholder="Briefly describe what this project is about…"></textarea>
          </div>
        </div>

        <!-- Feedback banner -->
        <div class="form-feedback hidden" id="form-feedback">
          <span class="feedback-icon" id="feedback-icon"></span>
          <span id="feedback-msg"></span>
        </div>

        <!-- Submit -->
        <button type="submit" class="btn btn-primary" id="submit-btn">
          <span class="btn-label" id="btn-label">Create Project</span>
          <span class="btn-spinner hidden" id="btn-spinner"></span>
        </button>
      </form>

      <!-- ───────── YOUR PROJECTS ───────── -->
      <div class="projects-section">
        <div class="projects-header">
          <h2>Your Projects</h2>
          <span class="project-count" id="project-count"></span>
        </div>

        <!-- skeleton loader -->
        <div class="projects-skeleton" id="projects-skeleton">
          <div class="skeleton-card"><div class="skeleton-line w60"></div><div class="skeleton-line w40"></div></div>
          <div class="skeleton-card"><div class="skeleton-line w50"></div><div class="skeleton-line w30"></div></div>
          <div class="skeleton-card"><div class="skeleton-line w70"></div><div class="skeleton-line w45"></div></div>
        </div>

        <!-- actual list -->
        <div class="projects-list hidden" id="projects-list"></div>

        <!-- empty state -->
        <div class="projects-empty hidden" id="projects-empty">
          <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/><line x1="12" y1="11" x2="12" y2="17"/><line x1="9" y1="14" x2="15" y2="14"/></svg>
          <p>No projects yet</p>
          <span>Create your first project above to get started.</span>
        </div>
      </div>
    </section>
  </main>
</Layout>

<!-- ───────── CLIENT-SIDE SCRIPT ───────── -->
<script>
  import { subscribeToAuthState, signOutOfAccount } from '../firebase/auth';

  /* ── DOM refs ── */
  const pageLoader      = document.getElementById('page-loader') as HTMLDivElement;
  const contentArea      = document.getElementById('content-area') as HTMLElement;
  const navAvatar        = document.getElementById('nav-avatar') as HTMLImageElement;
  const navName          = document.getElementById('nav-name') as HTMLSpanElement;
  const logoutBtn        = document.getElementById('logout-btn') as HTMLButtonElement;
  const form             = document.getElementById('create-project-form') as HTMLFormElement;
  const nameInput        = document.getElementById('project-name') as HTMLInputElement;
  const descInput        = document.getElementById('project-desc') as HTMLTextAreaElement;
  const feedbackBox      = document.getElementById('form-feedback') as HTMLDivElement;
  const feedbackIcon     = document.getElementById('feedback-icon') as HTMLSpanElement;
  const feedbackMsg      = document.getElementById('feedback-msg') as HTMLSpanElement;
  const submitBtn        = document.getElementById('submit-btn') as HTMLButtonElement;
  const btnLabel         = document.getElementById('btn-label') as HTMLSpanElement;
  const btnSpinner       = document.getElementById('btn-spinner') as HTMLSpanElement;
  const projectsSkeleton = document.getElementById('projects-skeleton') as HTMLDivElement;
  const projectsList     = document.getElementById('projects-list') as HTMLDivElement;
  const projectsEmpty    = document.getElementById('projects-empty') as HTMLDivElement;
  const projectCount     = document.getElementById('project-count') as HTMLSpanElement;

  let currentToken: string | null = null;

  /* ── Auth gate ── */
  subscribeToAuthState(async (user) => {
    if (!user) { window.location.href = '/login'; return; }

    navName.textContent = user.displayName || user.email || 'User';
    navAvatar.src = user.photoURL || `https://api.dicebear.com/7.x/initials/svg?seed=${encodeURIComponent(user.email || 'user')}`;

    currentToken = await user.getIdToken();

    // Register/sync user profile in backend database
    try {
      await fetch('http://localhost:3000/api/profile', {
        headers: {
          'Authorization': `Bearer ${currentToken}`
        }
      });
    } catch (e) {
      console.error('Failed to sync profile with database:', e);
    }

    pageLoader.classList.add('hidden');
    contentArea.classList.remove('hidden');

    // Fetch existing projects once auth resolves
    fetchProjects();
  });

  /* ── Logout ── */
  logoutBtn.addEventListener('click', async () => {
    try { await signOutOfAccount(); window.location.href = '/login'; }
    catch (e) { console.error('Logout failed', e); }
  });

  /* ── Helpers ── */
  function showFeedback(type: 'success' | 'error', msg: string) {
    feedbackBox.className = `form-feedback ${type}`;
    feedbackIcon.textContent = type === 'success' ? '✓' : '✕';
    feedbackMsg.textContent = msg;
  }

  function setLoading(on: boolean) {
    submitBtn.disabled = on;
    btnLabel.classList.toggle('hidden', on);
    btnSpinner.classList.toggle('hidden', !on);
  }

  /* ── Create Project ── */
  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    feedbackBox.classList.add('hidden');
    const projectName = nameInput.value.trim();
    const description = descInput.value.trim();

    if (!projectName) { showFeedback('error', 'Project name is required.'); return; }
    if (!currentToken) { showFeedback('error', 'Authentication expired. Please reload.'); return; }

    setLoading(true);
    try {
      const res = await fetch('http://localhost:3000/api/v1/create', {
        method: 'POST',
        headers: {
          'Authorization': `Bearer ${currentToken}`,
          'project_name': projectName,
          'description': description,
          'Content-Type': 'application/json',
        },
      });

      if (res.status === 409) {
        showFeedback('error', 'A project with that name already exists. Choose another.');
      } else if (!res.ok) {
        const body = await res.json().catch(() => null);
        throw new Error(typeof body === 'string' ? body : 'Something went wrong.');
      } else {
        showFeedback('success', `Project "${projectName}" created! Redirecting…`);
        // refresh the projects list in the background
        fetchProjects();
        setTimeout(() => {
          window.location.href = `/scanned?project=${encodeURIComponent(projectName)}`;
        }, 800);
      }
    } catch (err: any) {
      showFeedback('error', err.message || 'Could not reach the server.');
    } finally {
      setLoading(false);
    }
  });

  /* ── Fetch & Render Projects ── */
  async function fetchProjects() {
    // Show skeleton, hide list / empty
    projectsSkeleton.classList.remove('hidden');
    projectsList.classList.add('hidden');
    projectsEmpty.classList.add('hidden');

    try {
      if (!currentToken) return;

      const res = await fetch('http://localhost:3000/api/v1/getprojects', {
        headers: { 'Authorization': `Bearer ${currentToken}` },
      });

      if (!res.ok) throw new Error('Failed to load projects');

      const body = await res.json();
      const projects: { name: string }[] = body.data || [];

      projectsSkeleton.classList.add('hidden');

      if (projects.length === 0) {
        projectsEmpty.classList.remove('hidden');
        projectCount.textContent = '';
        return;
      }

      projectCount.textContent = `${projects.length}`;
      renderProjects(projects);

    } catch (err) {
      console.error(err);
      projectsSkeleton.classList.add('hidden');
      projectsEmpty.classList.remove('hidden');
    }
  }

  function renderProjects(projects: { name: string }[]) {
    projectsList.innerHTML = projects.map((p, i) => `
      <a href="/scanned?project=${encodeURIComponent(p.name)}" class="project-card" style="animation-delay: ${i * 60}ms">
        <div class="project-card-icon">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/></svg>
        </div>
        <div class="project-card-body">
          <span class="project-card-name">${p.name}</span>
          <span class="project-card-action">Open &rarr;</span>
        </div>
      </a>
    `).join('');
    projectsList.classList.remove('hidden');
  }
</script>

<!-- ───────── STYLES ───────── -->
<style>
  /* ── Tokens ── */
  :root {
    --bg-gradient: linear-gradient(145deg, #0b0f1a 0%, #141832 50%, #0f172a 100%);
    --nav-bg: rgba(15, 23, 42, 0.72);
    --card-bg: rgba(30, 41, 59, 0.42);
    --card-border: rgba(255, 255, 255, 0.07);
    --text-primary: #f1f5f9;
    --text-secondary: #94a3b8;
    --text-muted: #64748b;
    --accent: #6366f1;
    --accent-hover: #818cf8;
    --accent-glow: rgba(99, 102, 241, 0.35);
    --success: #34d399;
    --success-bg: rgba(52, 211, 153, 0.12);
    --error: #f87171;
    --error-bg: rgba(248, 113, 113, 0.12);
    --radius-sm: 10px;
    --radius-md: 16px;
    --radius-lg: 24px;
    --font: 'Inter', 'Segoe UI', system-ui, sans-serif;
  }

  /* ── Navbar ── */
  .navbar {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    background: var(--nav-bg);
    backdrop-filter: blur(18px) saturate(1.4);
    -webkit-backdrop-filter: blur(18px) saturate(1.4);
    border-bottom: 1px solid var(--card-border);
  }

  .nav-inner {
    max-width: 1140px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 28px;
    height: 64px;
  }

  .nav-brand {
    display: flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
    color: var(--text-primary);
  }

  .brand-text {
    font-family: var(--font);
    font-size: 20px;
    font-weight: 700;
    letter-spacing: -0.02em;
    background: linear-gradient(135deg, #c7d2fe 0%, #818cf8 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .nav-right {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .nav-user {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .nav-avatar {
    width: 34px;
    height: 34px;
    border-radius: 50%;
    object-fit: cover;
    border: 2px solid rgba(99, 102, 241, 0.4);
  }

  .nav-name {
    font-family: var(--font);
    font-size: 14px;
    font-weight: 500;
    color: var(--text-secondary);
  }

  .nav-btn-logout {
    display: grid;
    place-items: center;
    width: 36px;
    height: 36px;
    border-radius: 10px;
    border: 1px solid rgba(248, 113, 113, 0.2);
    background: rgba(248, 113, 113, 0.08);
    color: #fca5a5;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .nav-btn-logout:hover {
    background: rgba(248, 113, 113, 0.18);
    border-color: rgba(248, 113, 113, 0.4);
    transform: translateY(-1px);
  }

  /* ── Main ── */
  .dashboard-main {
    min-height: 100vh;
    background: var(--bg-gradient);
    font-family: var(--font);
    color: var(--text-primary);
    display: flex;
    justify-content: center;
    align-items: flex-start;
    padding: 104px 24px 60px;        /* top accounts for fixed nav */
  }

  /* ── Content wrapper ── */
  .content-wrapper {
    width: 100%;
    max-width: 620px;
    animation: fadeUp 0.5s ease both;
  }

  .section-header {
    margin-bottom: 28px;
  }

  .section-header h1 {
    font-size: 28px;
    font-weight: 800;
    letter-spacing: -0.03em;
    margin: 0 0 6px;
    background: linear-gradient(135deg, #e0e7ff, #c7d2fe 40%, #818cf8);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .section-subtitle {
    font-size: 15px;
    color: var(--text-secondary);
    margin: 0;
    line-height: 1.55;
  }

  /* ── Glass card ── */
  .glass-card {
    background: var(--card-bg);
    backdrop-filter: blur(20px) saturate(1.3);
    -webkit-backdrop-filter: blur(20px) saturate(1.3);
    border: 1px solid var(--card-border);
    border-radius: var(--radius-lg);
    padding: 36px;
    box-shadow:
      0 4px 30px rgba(0, 0, 0, 0.25),
      inset 0 1px 0 rgba(255, 255, 255, 0.04);
  }

  /* ── Form ── */
  .form-group {
    margin-bottom: 24px;
  }

  .form-group label {
    display: block;
    font-size: 13px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--text-secondary);
    margin-bottom: 8px;
  }

  .required { color: var(--error); }
  .optional { font-weight: 400; text-transform: none; letter-spacing: normal; color: var(--text-muted); font-size: 12px; }

  .input-wrapper {
    position: relative;
    display: flex;
    align-items: center;
  }

  .input-icon {
    position: absolute;
    left: 14px;
    color: var(--text-muted);
    pointer-events: none;
    transition: color 0.2s;
  }

  .textarea-icon { top: 14px; align-self: flex-start; }

  .input-wrapper input,
  .input-wrapper textarea {
    width: 100%;
    padding: 14px 16px 14px 44px;
    font-family: var(--font);
    font-size: 15px;
    color: var(--text-primary);
    background: rgba(15, 23, 42, 0.55);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: var(--radius-sm);
    outline: none;
    transition: border-color 0.25s, box-shadow 0.25s;
    box-sizing: border-box;
  }

  .input-wrapper textarea {
    resize: vertical;
    min-height: 80px;
  }

  .input-wrapper input::placeholder,
  .input-wrapper textarea::placeholder {
    color: var(--text-muted);
  }

  .input-wrapper input:focus,
  .input-wrapper textarea:focus {
    border-color: var(--accent);
    box-shadow: 0 0 0 3px var(--accent-glow);
  }

  .input-wrapper:focus-within .input-icon {
    color: var(--accent-hover);
  }

  /* ── Feedback banner ── */
  .form-feedback {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 12px 16px;
    border-radius: var(--radius-sm);
    font-size: 14px;
    font-weight: 500;
    margin-bottom: 20px;
    animation: fadeUp 0.3s ease;
  }

  .form-feedback.success {
    background: var(--success-bg);
    color: var(--success);
    border: 1px solid rgba(52, 211, 153, 0.2);
  }

  .form-feedback.error {
    background: var(--error-bg);
    color: var(--error);
    border: 1px solid rgba(248, 113, 113, 0.2);
  }

  .feedback-icon {
    font-size: 16px;
    font-weight: 700;
  }

  /* ── Primary Button ── */
  .btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    width: 100%;
    padding: 14px 24px;
    font-family: var(--font);
    font-size: 15px;
    font-weight: 600;
    border-radius: var(--radius-sm);
    border: none;
    cursor: pointer;
    transition: all 0.25s ease;
  }

  .btn-primary {
    background: linear-gradient(135deg, #6366f1, #4f46e5);
    color: #fff;
    box-shadow: 0 4px 14px var(--accent-glow);
  }

  .btn-primary:hover:not(:disabled) {
    background: linear-gradient(135deg, #818cf8, #6366f1);
    transform: translateY(-2px);
    box-shadow: 0 8px 24px var(--accent-glow);
  }

  .btn-primary:active:not(:disabled) {
    transform: translateY(0);
  }

  .btn-primary:disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }

  /* small spinner inside button */
  .btn-spinner {
    width: 20px;
    height: 20px;
    border: 2.5px solid rgba(255, 255, 255, 0.25);
    border-top-color: #fff;
    border-radius: 50%;
    animation: spin 0.65s linear infinite;
  }

  /* ── Page loader ── */
  .loading-state {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
    padding-top: 30vh;
    font-size: 14px;
    color: var(--text-secondary);
  }

  .spinner {
    width: 42px;
    height: 42px;
    border: 3px solid rgba(255, 255, 255, 0.08);
    border-top-color: var(--accent);
    border-radius: 50%;
    animation: spin 0.75s linear infinite;
  }

  /* ── Animations ── */
  @keyframes spin {
    to { transform: rotate(360deg); }
  }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(16px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* ── Utils ── */
  .hidden {
    display: none !important;
  }

  /* ── Projects Section ── */
  .projects-section {
    margin-top: 48px;
  }

  .projects-header {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 20px;
  }

  .projects-header h2 {
    font-size: 22px;
    font-weight: 700;
    margin: 0;
    background: linear-gradient(135deg, #e0e7ff, #c7d2fe 60%, #818cf8);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .project-count {
    font-size: 12px;
    font-weight: 700;
    color: var(--accent-hover);
    background: rgba(99, 102, 241, 0.15);
    padding: 2px 10px;
    border-radius: 20px;
    min-width: 16px;
    text-align: center;
  }

  .project-count:empty {
    display: none;
  }

  /* ── Project Cards ── */
  .projects-list {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .project-card {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 16px 20px;
    background: var(--card-bg);
    backdrop-filter: blur(12px);
    border: 1px solid var(--card-border);
    border-radius: var(--radius-md);
    text-decoration: none;
    color: var(--text-primary);
    transition: all 0.25s ease;
    animation: fadeUp 0.4s ease both;
  }

  .project-card:hover {
    background: rgba(30, 41, 59, 0.65);
    border-color: rgba(99, 102, 241, 0.3);
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.2);
  }

  .project-card-icon {
    display: grid;
    place-items: center;
    width: 40px;
    height: 40px;
    border-radius: 10px;
    background: rgba(99, 102, 241, 0.12);
    color: var(--accent-hover);
    flex-shrink: 0;
  }

  .project-card-body {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: space-between;
    min-width: 0;
  }

  .project-card-name {
    font-size: 15px;
    font-weight: 600;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .project-card-action {
    font-size: 13px;
    font-weight: 500;
    color: var(--accent-hover);
    white-space: nowrap;
    opacity: 0;
    transform: translateX(-6px);
    transition: all 0.2s ease;
  }

  .project-card:hover .project-card-action {
    opacity: 1;
    transform: translateX(0);
  }

  /* ── Empty State ── */
  .projects-empty {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 40px 20px;
    color: var(--text-muted);
    gap: 8px;
  }

  .projects-empty svg {
