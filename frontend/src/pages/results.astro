---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Scan Results | Web-Reviewer">
  <!-- ───────── NAVBAR ───────── -->
  <nav class="navbar">
    <div class="nav-inner">
      <a href="/dashboard" class="nav-brand">
        <span class="brand-icon">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="url(#bg)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <defs><linearGradient id="bg" x1="0" y1="0" x2="24" y2="24"><stop offset="0%" stop-color="#818cf8"/><stop offset="100%" stop-color="#6366f1"/></linearGradient></defs>
            <circle cx="12" cy="12" r="10"/>
            <path d="M8 12l2 2 4-4"/>
          </svg>
        </span>
        <span class="brand-text">Web-Reviewer</span>
      </a>

      <div class="nav-right">
        <a href="/dashboard" class="nav-link" title="Dashboard">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
          <span>Dashboard</span>
        </a>
        <div class="nav-user" id="nav-user-info">
          <img id="nav-avatar" class="nav-avatar" src="https://www.gravatar.com/avatar/00000000000000000000000000000000?d=mp&f=y" alt="Avatar" />
          <span class="nav-name" id="nav-name">...</span>
        </div>
      </div>
    </div>
  </nav>

  <!-- ───────── PAGE CONTENT ───────── -->
  <main class="results-main">
    <!-- Loading spinner -->
    <div class="loading-state" id="page-loader">
      <div class="spinner"></div>
      <p>Fetching scan details…</p>
    </div>

    <!-- Main Section (hidden until loaded) -->
    <section class="content-wrapper hidden" id="content-area">
      <!-- Info Header -->
      <div class="section-header">
        <h1>Detailed Scan Report</h1>
        <p class="section-subtitle">Audit ID: <span class="audit-id" id="report-id"></span></p>
      </div>

      <!-- ── Results Display Card ── -->
      <div class="glass-card results-card" id="results-card">
        <div class="score-ring-container">
          <div class="score-ring" id="score-ring">
            <svg viewBox="0 0 120 120">
              <circle class="ring-bg" cx="60" cy="60" r="52"/>
              <circle class="ring-progress" id="ring-progress" cx="60" cy="60" r="52"/>
            </svg>
            <div class="score-value">
              <span class="score-number" id="score-number">—</span>
              <span class="score-label">Score</span>
            </div>
          </div>
          <div class="grade-container">
            <span class="grade-badge" id="grade-badge">—</span>
            <span class="grade-label">SEO Grade</span>
          </div>
        </div>

        <!-- Counts grid -->
        <div class="counts-grid">
          <div class="count-card error">
            <span class="count-num" id="count-errors">0</span>
            <span class="count-lbl">Errors</span>
          </div>
          <div class="count-card warning">
            <span class="count-num" id="count-warnings">0</span>
            <span class="count-lbl">Warnings</span>
          </div>
          <div class="count-card pass">
            <span class="count-num" id="count-passed">0</span>
            <span class="count-lbl">Passed</span>
          </div>
        </div>

        <!-- Individual checks lists grouped by status -->
        <div class="checks-group-wrapper">
          <h3>Failed Audits (Errors)</h3>
          <div class="results-checks errors-list" id="errors-checks"></div>

          <h3>Warnings</h3>
          <div class="results-checks warnings-list" id="warnings-checks"></div>

          <h3>Passed Checks</h3>
          <div class="results-checks passed-list" id="passed-checks"></div>
        </div>
      </div>

      <!-- ── AI Insights Card ── -->
      <div class="glass-card ai-card" id="ai-card">
        <div class="ai-header">
          <div class="ai-title-group">
            <svg class="ai-sparkle-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"/>
            </svg>
            <h2>AI Technical Consultant</h2>
          </div>
          <span class="ai-badge">Gemini AI</span>
        </div>
        
        <p class="ai-desc">Get customized explanations and actionable recommendations for your SEO report from our AI consultant.</p>
        
        <!-- Action Button -->
        <button class="ai-btn" id="ai-generate-btn">
          <span id="ai-btn-text">Generate AI Recommendations</span>
          <div class="ai-btn-spinner hidden" id="ai-btn-spinner"></div>
        </button>

        <!-- AI Output Area -->
        <div class="ai-content hidden" id="ai-content-area">
          <div class="ai-markdown" id="ai-insights-output"></div>
        </div>
      </div>

      <!-- ── AI Optimiser Card ── -->
      <div class="glass-card ai-card" id="optimiser-card" style="margin-top: 24px;">
        <div class="ai-header">
          <div class="ai-title-group">
            <svg class="ai-sparkle-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"></polygon>
            </svg>
            <h2>AI Rule Optimiser</h2>
          </div>
          <span class="ai-badge">Gemini AI</span>
        </div>
        
        <p class="ai-desc">Select an issue or warning to generate an optimised fix.</p>
        
        <div class="optimiser-controls">
          <select id="optimiser-rule-select" class="optimiser-select">
            <option value="">Select an issue to optimise...</option>
          </select>
          <button class="ai-btn" id="optimiser-btn" disabled>
            <span id="optimiser-btn-text">Optimise</span>
            <div class="ai-btn-spinner hidden" id="optimiser-btn-spinner"></div>
          </button>
        </div>

        <!-- Optimiser Output Area -->
        <div class="ai-content hidden" id="optimiser-content-area">
          <div class="ai-markdown" id="optimiser-output"></div>
        </div>
      </div>
    </section>
  </main>
</Layout>

<!-- ───────── CLIENT-SIDE SCRIPT ───────── -->
<script>
  import { subscribeToAuthState } from '../firebase/auth';

  /* ── DOM refs ── */
  const pageLoader      = document.getElementById('page-loader') as HTMLDivElement;
  const contentArea      = document.getElementById('content-area') as HTMLElement;
  const navAvatar        = document.getElementById('nav-avatar') as HTMLImageElement;
  const navName          = document.getElementById('nav-name') as HTMLSpanElement;
  const reportId         = document.getElementById('report-id') as HTMLSpanElement;

  const scoreNumber      = document.getElementById('score-number') as HTMLSpanElement;
  const gradeBadge       = document.getElementById('grade-badge') as HTMLSpanElement;
  const ringProgress     = document.getElementById('ring-progress') as SVGCircleElement;

  const countErrors      = document.getElementById('count-errors') as HTMLSpanElement;
  const countWarnings    = document.getElementById('count-warnings') as HTMLSpanElement;
  const countPassed      = document.getElementById('count-passed') as HTMLSpanElement;

  const errorsChecks     = document.getElementById('errors-checks') as HTMLDivElement;
  const warningsChecks   = document.getElementById('warnings-checks') as HTMLDivElement;
  const passedChecks     = document.getElementById('passed-checks') as HTMLDivElement;

  const aiGenerateBtn    = document.getElementById('ai-generate-btn') as HTMLButtonElement;
  const aiBtnText        = document.getElementById('ai-btn-text') as HTMLSpanElement;
  const aiBtnSpinner     = document.getElementById('ai-btn-spinner') as HTMLSpanElement;
  const aiContentArea    = document.getElementById('ai-content-area') as HTMLDivElement;
  const aiInsightsOutput = document.getElementById('ai-insights-output') as HTMLDivElement;

  const optimiserRuleSelect = document.getElementById('optimiser-rule-select') as HTMLSelectElement;
  const optimiserBtn        = document.getElementById('optimiser-btn') as HTMLButtonElement;
  const optimiserBtnText    = document.getElementById('optimiser-btn-text') as HTMLSpanElement;
  const optimiserBtnSpinner = document.getElementById('optimiser-btn-spinner') as HTMLSpanElement;
  const optimiserContentArea= document.getElementById('optimiser-content-area') as HTMLDivElement;
  const optimiserOutput     = document.getElementById('optimiser-output') as HTMLDivElement;

  let currentToken: string | null = null;

  /* ── Read scan_id from query params ── */
  const params = new URLSearchParams(window.location.search);
  const scanId = params.get('scan_id');

  if (!scanId) {
    alert("Scan ID is missing from URL query parameter.");
    window.location.href = "/dashboard";
  }

  /* ── Auth gate ── */
  subscribeToAuthState(async (user) => {
    if (!user) { window.location.href = '/login'; return; }

    navName.textContent = user.displayName || user.email || 'User';
    navAvatar.src = user.photoURL || `https://api.dicebear.com/7.x/initials/svg?seed=${encodeURIComponent(user.email || 'user')}`;

    currentToken = await user.getIdToken();

    // Fetch details
    fetchScanResults();
  });

  /* ── Grade colour helper ── */
  function gradeColor(grade: string): string {
    const g = grade.toUpperCase();
    if (g === 'A+' || g === 'A') return '#34d399';
    if (g === 'B') return '#60a5fa';
    if (g === 'C') return '#fbbf24';
    if (g === 'D') return '#fb923c';
    return '#f87171';
  }

  /* ── Fetch details ── */
  async function fetchScanResults() {
    try {
      if (!currentToken || !scanId) return;

      const res = await fetch('http://localhost:3000/api/v1/getScanResults', {
        headers: {
          'Authorization': `Bearer ${currentToken}`,
          'scan_id': scanId,
        },
      });

      if (!res.ok) throw new Error('Failed to load scan results');

      const body = await res.json();
      
      // Since scan_results matches scan_id, body.data is an array e.g., [{ seo: { score, grade, summary, results } }]
      const scanInfo = body.data?.[0]?.seo;

      if (!scanInfo) {
        throw new Error('No scan results found for this Audit ID.');
      }

      pageLoader.classList.add('hidden');
      contentArea.classList.remove('hidden');

      reportId.textContent = scanId;
      renderScanReport(scanInfo);

    } catch (err: any) {
      console.error(err);
      alert(err.message || "Failed to load scan report details.");
      window.location.href = "/dashboard";
    }
  }

  /* ── Render scan report ── */
  function renderScanReport(seo: any) {
    scoreNumber.textContent = seo.score ?? '—';
    gradeBadge.textContent = seo.grade ?? '—';
    gradeBadge.style.background = gradeColor(seo.grade || 'F') + '22';
    gradeBadge.style.color = gradeColor(seo.grade || 'F');
    gradeBadge.style.borderColor = gradeColor(seo.grade || 'F') + '44';

    // Animate score ring
    const circumference = 2 * Math.PI * 52;
    const score = Math.min(Math.max(seo.score || 0, 0), 100);
    const offset = circumference - (score / 100) * circumference;
    ringProgress.style.strokeDasharray = `${circumference}`;
    ringProgress.style.strokeDashoffset = `${circumference}`;
    ringProgress.style.stroke = gradeColor(seo.grade || 'F');
    requestAnimationFrame(() => {
      ringProgress.style.transition = 'stroke-dashoffset 1s ease';
      ringProgress.style.strokeDashoffset = `${offset}`;
    });

    // Summary counts
    const summary = seo.summary || {};
    countErrors.textContent = summary.errors ?? 0;
    countWarnings.textContent = summary.warnings ?? 0;
    countPassed.textContent = summary.passed ?? 0;

    // Checks results
    const results = seo.results || {};
    const errorsList = results.errors || [];
    const warningsList = results.warnings || [];
    const passedList = results.passed || [];

    // Helper to generate lists html
    const mapChecks = (checks: any[], type: 'error' | 'warning' | 'pass') => {
      if (checks.length === 0) {
        return `<div class="empty-group">No audits in this category</div>`;
      }
      return checks.map(r => `
        <div class="check-item ${type}">
          <span class="check-icon">${type === 'pass' ? '✓' : type === 'error' ? '✕' : '⚠'}</span>
          <div class="check-body">
            <span class="check-name">${r.name || r.check || 'Audit Check'}</span>
            ${r.message ? `<span class="check-msg">${r.message}</span>` : ''}
          </div>
        </div>
      `).join('');
    };

    errorsChecks.innerHTML = mapChecks(errorsList, 'error');
    warningsChecks.innerHTML = mapChecks(warningsList, 'warning');
    passedChecks.innerHTML = mapChecks(passedList, 'pass');

    // Populate Optimiser Dropdown
    let optimiserOptions = '<option value="">Select an issue to optimise...</option>';
    const allIssues = [...errorsList, ...warningsList];
    allIssues.forEach(item => {
      const name = item.name || item.check || 'Audit Check';
      optimiserOptions += `<option value="${name}">${name}</option>`;
    });
    optimiserRuleSelect.innerHTML = optimiserOptions;
  }

  // ── AI generation click handler ──
  aiGenerateBtn.addEventListener('click', async () => {
    if (!currentToken || !scanId) return;

    aiGenerateBtn.disabled = true;
    aiBtnText.textContent = "Analyzing SEO Report...";
    aiBtnSpinner.classList.remove('hidden');
    aiContentArea.classList.add('hidden');

    try {
      const res = await fetch(`http://localhost:3000/api/v1/ai/?scanid=${scanId}`, {
        headers: {
          'Authorization': `Bearer ${currentToken}`
        }
      });

      if (!res.ok) {
        const body = await res.json().catch(() => null);
        const msg = body?.error || (typeof body === 'string' ? body : 'Failed to generate AI insights.');
        throw new Error(msg);
      }

      const result = await res.json();
      const aiText = typeof result.Data === 'string' ? result.Data : (result.Data?.text || result.Data?.candidates?.[0]?.content?.parts?.[0]?.text || '');
      
      if (!aiText) {
        throw new Error("No recommendations generated by AI.");
      }

      // Try to parse JSON from response
      let cleanedText = aiText.trim();
      if (cleanedText.startsWith("```")) {
        cleanedText = cleanedText.replace(/^```(json)?/, "").replace(/```$/, "").trim();
      }

      try {
        const parsedJson = JSON.parse(cleanedText);
        renderAiJsonInsights(parsedJson);
      } catch (jsonErr) {
        // Fallback: render as formatted plain text
        renderAiTextInsights(aiText);
      }

      aiContentArea.classList.remove('hidden');
    } catch (err: any) {
      console.error(err);
      alert(err.message || "Failed to generate AI insights.");
    } finally {
      aiGenerateBtn.disabled = false;
      aiBtnText.textContent = "Regenerate AI Recommendations";
      aiBtnSpinner.classList.add('hidden');
    }
  });

  // ── AI Optimiser events ──
  optimiserRuleSelect.addEventListener('change', () => {
    optimiserBtn.disabled = !optimiserRuleSelect.value;
  });

  optimiserBtn.addEventListener('click', async () => {
    const selectedRule = optimiserRuleSelect.value;
    if (!currentToken || !scanId || !selectedRule) return;

    optimiserBtn.disabled = true;
    optimiserBtnText.textContent = "Optimising...";
    optimiserBtnSpinner.classList.remove('hidden');
    optimiserContentArea.classList.add('hidden');

    try {
      const res = await fetch(`http://localhost:3000/api/v1/optimiser`, {
        method: 'POST',
        headers: {
          'Authorization': `Bearer ${currentToken}`,
          'Content-Type': 'application/json'
        },
        body: JSON.stringify({ scanid: scanId, rule: selectedRule })
      });

      if (!res.ok) {
        const body = await res.json().catch(() => null);
        const msg = body?.error || (typeof body === 'string' ? body : 'Failed to generate optimisation.');
        throw new Error(msg);
      }

      const result = await res.json();
      const aiText = typeof result === 'string' ? result : (result?.candidates?.[0]?.content?.parts?.[0]?.text || JSON.stringify(result));

      renderAiTextInsightsForOptimiser(aiText);
      optimiserContentArea.classList.remove('hidden');
    } catch (err: any) {
      console.error(err);
      alert(err.message || "Failed to generate optimisation.");
    } finally {
      optimiserBtn.disabled = false;
      optimiserBtnText.textContent = "Optimise";
      optimiserBtnSpinner.classList.add('hidden');
    }
  });

  function renderAiTextInsightsForOptimiser(text: string) {
    const paragraphs = text
      .split('\n\n')
      .map(p => {
        const trimmed = p.trim();
        if (!trimmed) return '';
        if (trimmed.startsWith('-') || trimmed.startsWith('*')) {
          const listItems = trimmed
            .split('\n')
            .map(li => `<li>${li.replace(/^[-*]\s*/, '')}</li>`)
            .join('');
          return `<ul>${listItems}</ul>`;
        }
        if (trimmed.startsWith('#')) {
          const level = (trimmed.match(/^#+/) || ['#'])[0].length;
          const cleanText = trimmed.replace(/^#+\s*/, '');
          return `<h${Math.min(level + 2, 6)}>${cleanText}</h${Math.min(level + 2, 6)}>`;
        }
        return `<p>${trimmed.replace(/\n/g, '<br>')}</p>`;
      })
      .filter(Boolean)
      .join('');

    optimiserOutput.innerHTML = `<div class="ai-raw-text">${paragraphs}</div>`;
  }

  function escapeHTML(str: string): string {
    return str
      .replace(/&/g, "&amp;")
      .replace(/</g, "&lt;")
      .replace(/>/g, "&gt;")
      .replace(/"/g, "&quot;")
      .replace(/'/g, "&#039;");
  }

  function renderAiJsonInsights(data: any) {
    let html = '';

    // 1. Render Summary (executiveSummary and overallAssessment)
    if (data.summary && typeof data.summary === 'object') {
      const execSummary = data.summary.executiveSummary || data.summary.executive_summary || '';
      const assessment = data.summary.overallAssessment || data.summary.overall_assessment || '';
      
      if (execSummary || assessment) {
        html += `
          <div class="ai-overall-summary">
            ${execSummary ? `
              <div class="summary-section">
                <h5>Executive Summary</h5>
                <p>${execSummary}</p>
              </div>
            ` : ''}
            ${assessment ? `
              <div class="summary-section" style="margin-top: 14px; padding-top: 14px; border-top: 1px dashed rgba(168, 85, 247, 0.25);">
                <h5 style="color: #c084fc;">Overall Assessment</h5>
                <p>${assessment}</p>
              </div>
            ` : ''}
          </div>
        `;
      }
    } else if (data.summary && typeof data.summary === 'string') {
      html += `
        <div class="ai-overall-summary">
          <h5>Executive Summary</h5>
          <p>${data.summary}</p>
        </div>
      `;
    }

    // 2. Render Top Priorities List
    const priorities = data.topPriorities || data.top_priorities || data.priorities;
    if (priorities && Array.isArray(priorities) && priorities.length > 0) {
      html += `
        <div class="ai-priorities-card">
          <div class="priorities-header">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#fbbf24" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/>
              <line x1="12" y1="9" x2="12" y2="13"/>
              <line x1="12" y1="17" x2="12.01" y2="17"/>
            </svg>
            <h5>Top Action Priorities</h5>
          </div>
          <ul class="priorities-list">
            ${priorities.map(p => `<li>${p}</li>`).join('')}
          </ul>
        </div>
      `;
    }

    // 3. Render Recommendations Grid
    const recommendations = data.recommendations || data.issues || data.results || (Array.isArray(data) ? data : null);

    if (recommendations && Array.isArray(recommendations)) {
      html += `<div class="ai-insights-grid">`;
      recommendations.forEach((item: any, idx: number) => {
        const title = item.title || item.issue || item.check || item.name || `Insight #${idx + 1}`;
        const whyItMatters = item.whyItMatters || item.why_it_matters || item.description || item.explanation || item.message || item.summary || '';
        const actionPlan = item.actionPlan || item.action_plan || item.action || item.recommendation || item.fix || item.solution || '';
        const example = item.example || null;
        const ruleId = item.ruleId || item.rule_id || '';

        html += `
          <div class="ai-insight-card">
            <div class="ai-insight-title-row">
              <span class="ai-insight-number">${idx + 1}</span>
              <div style="display: flex; flex-direction: column; gap: 2px;">
                <h4>${title}</h4>
                ${ruleId ? `<span class="ai-rule-id">${ruleId}</span>` : ''}
              </div>
            </div>
            ${whyItMatters ? `
              <div class="ai-insight-desc">
                <h5>Why it matters:</h5>
                <p>${whyItMatters}</p>
              </div>
            ` : ''}
            ${actionPlan ? `
              <div class="ai-insight-action">
                <h5>Action Plan:</h5>
                <p>${actionPlan}</p>
              </div>
            ` : ''}
            ${example ? `
              <div class="ai-insight-example">
                <h5>Example Code:</h5>
                <pre class="example-pre"><code>${escapeHTML(example)}</code></pre>
              </div>
            ` : ''}
          </div>
        `;
      });
      html += `</div>`;
    }

    // Fallback if formatting resulted in empty HTML
    aiInsightsOutput.innerHTML = html || `<pre class="ai-raw-text">${JSON.stringify(data, null, 2)}</pre>`;
  }

  function renderAiTextInsights(text: string) {
    const paragraphs = text
      .split('\n\n')
      .map(p => {
        const trimmed = p.trim();
        if (!trimmed) return '';
        if (trimmed.startsWith('-') || trimmed.startsWith('*')) {
          const listItems = trimmed
            .split('\n')
            .map(li => `<li>${li.replace(/^[-*]\s*/, '')}</li>`)
            .join('');
          return `<ul>${listItems}</ul>`;
        }
        if (trimmed.startsWith('#')) {
          const level = (trimmed.match(/^#+/) || ['#'])[0].length;
          const cleanText = trimmed.replace(/^#+\s*/, '');
          return `<h${Math.min(level + 2, 6)}>${cleanText}</h${Math.min(level + 2, 6)}>`;
        }
        return `<p>${trimmed.replace(/\n/g, '<br>')}</p>`;
      })
      .filter(Boolean)
      .join('');

    aiInsightsOutput.innerHTML = `<div class="ai-raw-text">${paragraphs}</div>`;
  }
</script>

<!-- ───────── STYLES ───────── -->
<style>
  /* ── Tokens ── */
  :root {
    --bg-gradient: linear-gradient(145deg, #0b0f1a 0%, #141832 50%, #0f172a 100%);
    --nav-bg: rgba(15, 23, 42, 0.72);
    --card-bg: rgba(30, 41, 59, 0.42);
    --card-border: rgba(255, 255, 255, 0.07);
    --text-primary: #f1f5f9;
    --text-secondary: #94a3b8;
    --text-muted: #64748b;
    --accent: #6366f1;
    --accent-hover: #818cf8;
    --accent-glow: rgba(99, 102, 241, 0.35);
    --success: #34d399;
    --success-bg: rgba(52, 211, 153, 0.12);
    --error: #f87171;
    --error-bg: rgba(248, 113, 113, 0.12);
    --info: #60a5fa;
    --info-bg: rgba(96, 165, 250, 0.10);
    --warning: #fbbf24;
    --warning-bg: rgba(251, 191, 36, 0.10);
    --radius-sm: 10px;
    --radius-md: 16px;
    --radius-lg: 24px;
    --font: 'Inter', 'Segoe UI', system-ui, sans-serif;
  }

  /* ── Navbar ── */
  .navbar {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    background: var(--nav-bg);
    backdrop-filter: blur(18px) saturate(1.4);
