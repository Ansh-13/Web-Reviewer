    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s ease;
    box-shadow: 0 4px 12px rgba(168, 85, 247, 0.25);
  }

  .ai-btn:hover:not(:disabled) {
    transform: translateY(-2px);
    box-shadow: 0 6px 16px rgba(168, 85, 247, 0.35);
    background: linear-gradient(135deg, var(--accent-hover) 0%, #b55fe6 100%);
  }

  .ai-btn:disabled {
    background: #1e293b;
    color: var(--text-muted);
    border: 1px solid var(--card-border);
    cursor: not-allowed;
    box-shadow: none;
  }

  .ai-btn-spinner {
    width: 18px;
    height: 18px;
    border: 2px solid rgba(255,255,255,0.3);
    border-top-color: white;
    border-radius: 50%;
    animation: spin 0.6s linear infinite;
  }

  .ai-content {
    margin-top: 24px;
    border-top: 1px solid rgba(255,255,255,0.06);
    padding-top: 24px;
    animation: fadeUp 0.4s ease both;
  }

  .ai-markdown {
    color: var(--text-primary);
  }

  .ai-overall-summary {
    background: rgba(168, 85, 247, 0.05);
    border: 1px solid rgba(168, 85, 247, 0.15);
    border-radius: var(--radius-sm);
    padding: 16px;
    margin-bottom: 20px;
  }

  .summary-section h5 {
    color: #c084fc;
    margin: 0 0 6px 0;
    font-size: 13px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .summary-section p {
    margin: 0;
    font-size: 14px;
    line-height: 1.6;
    color: var(--text-secondary);
  }

  /* ── AI Priorities Card ── */
  .ai-priorities-card {
    background: rgba(251, 191, 36, 0.04);
    border: 1px solid rgba(251, 191, 36, 0.15);
    border-radius: var(--radius-sm);
    padding: 18px;
    margin-bottom: 20px;
    animation: fadeUp 0.4s ease both;
  }

  .priorities-header {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 12px;
  }

  .priorities-header h5 {
    color: #fbbf24;
    margin: 0;
    font-size: 13px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .priorities-list {
    margin: 0;
    padding-left: 20px;
    color: var(--text-secondary);
    font-size: 13.5px;
    line-height: 1.6;
  }

  .priorities-list li {
    margin-bottom: 6px;
  }
  
  .priorities-list li:last-child {
    margin-bottom: 0;
  }

  .ai-rule-id {
    font-family: monospace;
    font-size: 11px;
    color: var(--text-muted);
    background: rgba(255, 255, 255, 0.05);
    padding: 1px 5px;
    border-radius: 4px;
    width: fit-content;
  }

  .ai-insight-desc {
    margin-bottom: 14px;
  }

  .ai-insight-desc h5 {
    margin: 0 0 4px 0;
    font-size: 12px;
    font-weight: 700;
    color: #c084fc;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .ai-insight-desc p {
    margin: 0;
    font-size: 13.5px;
    line-height: 1.6;
    color: var(--text-secondary);
  }

  /* ── AI Example Code ── */
  .ai-insight-example {
    margin-top: 14px;
  }

  .ai-insight-example h5 {
    margin: 0 0 6px 0;
    font-size: 12px;
    font-weight: 700;
    color: var(--info);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .example-pre {
    background: #0f172a;
    border: 1px solid var(--card-border);
    border-radius: 6px;
    padding: 12px;
    margin: 0;
    overflow-x: auto;
  }

  .example-pre code {
    font-family: 'Fira Code', 'Courier New', Courier, monospace;
    font-size: 12px;
    color: #38bdf8;
    line-height: 1.5;
  }

  .ai-insights-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 16px;
  }

  .ai-insight-card {
    background: rgba(15, 23, 42, 0.3);
    border: 1px solid var(--card-border);
    border-radius: var(--radius-sm);
    padding: 18px;
    transition: border-color 0.2s ease;
  }

  .ai-insight-card:hover {
    border-color: rgba(168, 85, 247, 0.3);
  }

  .ai-insight-title-row {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 10px;
  }

  .ai-insight-number {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 24px;
    height: 24px;
    border-radius: 50%;
    background: rgba(168, 85, 247, 0.15);
    color: #c084fc;
    font-size: 12px;
    font-weight: 700;
  }

  .ai-insight-title-row h4 {
    margin: 0;
    font-size: 15px;
    font-weight: 600;
  }

  .ai-insight-desc {
    margin: 0 0 14px 0;
    font-size: 13.5px;
    line-height: 1.6;
    color: var(--text-secondary);
  }

  .ai-insight-action {
    background: rgba(52, 211, 153, 0.04);
    border-left: 3px solid var(--success);
    border-radius: 0 6px 6px 0;
    padding: 10px 14px;
  }

  .ai-insight-action h5 {
    margin: 0 0 4px 0;
    font-size: 12px;
    font-weight: 700;
    color: var(--success);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .ai-insight-action p {
    margin: 0;
    font-size: 13px;
    line-height: 1.5;
    color: var(--text-secondary);
  }

  .ai-raw-text {
    font-size: 14px;
    line-height: 1.6;
    color: var(--text-secondary);
  }

  .ai-raw-text ul {
    margin: 8px 0;
    padding-left: 20px;
  }

  .ai-raw-text li {
    margin: 4px 0;
  }

  .ai-raw-text h3, .ai-raw-text h4, .ai-raw-text h5 {
    color: var(--text-primary);
    margin: 16px 0 8px 0;
  }

  /* ── Keyframes ── */
  @keyframes pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.7; transform: scale(1.05); }
  }

  /* ══════════════════════════════════════════
     REPORT COMPARISON SECTION
  ══════════════════════════════════════════ */

  .compare-card {
    margin-top: 28px;
    position: relative;
    overflow: hidden;
  }

  .compare-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 4px;
    background: linear-gradient(90deg, #6366f1 0%, #38bdf8 50%, #34d399 100%);
  }

  .compare-card-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 12px;
  }

  .compare-title-group {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .compare-icon {
    color: #38bdf8;
    flex-shrink: 0;
  }

  .compare-title-group h2 {
    font-size: 20px;
    font-weight: 700;
    margin: 0;
    color: var(--text-primary);
  }

  .compare-badge {
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 4px 10px;
    border-radius: 99px;
    background: rgba(56, 189, 248, 0.12);
    color: #38bdf8;
    border: 1px solid rgba(56, 189, 248, 0.28);
  }

  .compare-desc {
    font-size: 14px;
    color: var(--text-secondary);
    line-height: 1.5;
    margin: 0 0 20px 0;
  }

  /* ── Skeleton ── */
  .compare-skeleton {
    display: flex;
    flex-direction: column;
    gap: 10px;
    padding: 4px 0 12px;
  }

  .cskel-row {
    height: 52px;
    border-radius: var(--radius-sm);
    background: linear-gradient(90deg, rgba(255,255,255,0.04) 25%, rgba(255,255,255,0.08) 50%, rgba(255,255,255,0.04) 75%);
    background-size: 200% 100%;
    animation: shimmer 1.4s infinite;
  }

  @keyframes shimmer {
    0% { background-position: 200% 0; }
    100% { background-position: -200% 0; }
  }

  /* ── Empty state ── */
  .compare-empty {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
    padding: 28px 16px;
    color: var(--text-muted);
    font-size: 13px;
    text-align: center;
  }

  /* ── Two-column wrapper ── */
  .compare-cols-wrapper {
    margin-bottom: 20px;
  }

  .compare-skeleton-full {
    width: 100%;
  }

  .compare-two-cols {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: 14px;
    align-items: start;
    margin-bottom: 20px;
  }

  .compare-col {
    display: flex;
    flex-direction: column;
    gap: 0;
    border: 1px solid var(--card-border);
    border-radius: var(--radius-md);
    overflow: hidden;
  }

  .compare-col-header {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 10px 14px;
    border-bottom: 1px solid var(--card-border);
    font-size: 12.5px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .scan-a-header {
    background: rgba(56, 189, 248, 0.07);
    color: #38bdf8;
    border-top: 2px solid #38bdf8;
  }

  .scan-b-header {
    background: rgba(168, 85, 247, 0.07);
    color: #c084fc;
    border-top: 2px solid #c084fc;
  }

  .compare-col-label {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 22px;
    height: 22px;
    border-radius: 6px;
    background: rgba(56, 189, 248, 0.18);
    color: #38bdf8;
    font-size: 13px;
    font-weight: 800;
    flex-shrink: 0;
  }

  .scan-b-label {
    background: rgba(168, 85, 247, 0.18);
    color: #c084fc;
  }

  .compare-col-hint {
    margin-left: auto;
    font-size: 10.5px;
    font-weight: 500;
    text-transform: none;
    letter-spacing: 0;
    opacity: 0.6;
    max-width: 90px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .compare-col-list {
    display: flex;
    flex-direction: column;
    gap: 0;
    max-height: 260px;
    overflow-y: auto;
    background: rgba(10, 15, 30, 0.3);
  }

  .compare-col-list::-webkit-scrollbar { width: 4px; }
  .compare-col-list::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.1); border-radius: 2px; }

  /* VS divider */
  .compare-vs-divider {
    display: flex;
    align-items: center;
    justify-content: center;
    padding-top: 36px;
  }

  .compare-vs-divider span {
    font-size: 11px;
    font-weight: 800;
    letter-spacing: 0.12em;
    color: var(--text-muted);
    background: rgba(255,255,255,0.05);
    border: 1px solid var(--card-border);
    border-radius: 99px;
    padding: 5px 10px;
  }

  /* Current-page tag inside a scan row */
  .compare-current-tag {
    display: inline-block;
    font-size: 9.5px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 1px 5px;
    border-radius: 4px;
    background: rgba(99, 102, 241, 0.2);
    color: #818cf8;
    border: 1px solid rgba(99, 102, 241, 0.3);
    vertical-align: middle;
    margin-left: 4px;
  }

  .compare-scan-row {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 13px 16px;
    border-radius: var(--radius-sm);
    border: 1px solid var(--card-border);
    background: rgba(15, 23, 42, 0.35);
    cursor: pointer;
    transition: border-color 0.2s, background 0.2s;
    user-select: none;
  }

  .compare-scan-row:hover {
    border-color: rgba(56, 189, 248, 0.3);
    background: rgba(56, 189, 248, 0.04);
  }

  .compare-scan-row.selected {
    border-color: rgba(56, 189, 248, 0.5);
    background: rgba(56, 189, 248, 0.08);
  }

  .compare-scan-checkbox {
    position: relative;
    flex-shrink: 0;
  }

  .cscan-radio {
    position: absolute;
    opacity: 0;
    width: 0;
    height: 0;
  }

  .custom-radio {
    width: 18px;
    height: 18px;
    border-radius: 50%;
    border: 2px solid rgba(148, 163, 184, 0.4);
    background: transparent;
    transition: border-color 0.2s, background 0.2s;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .compare-scan-row.selected .custom-radio {
    border-color: #38bdf8;
    background: #38bdf8;
    box-shadow: 0 0 0 3px rgba(56, 189, 248, 0.2);
  }

  .compare-scan-row.selected .custom-radio::after {
    content: '';
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: white;
  }

  .compare-scan-info {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 2px;
    overflow: hidden;
  }

  .compare-scan-url {
    font-size: 13.5px;
    font-weight: 500;
    color: var(--text-primary);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .compare-scan-date {
    font-size: 11.5px;
    color: var(--text-muted);
  }

  .compare-scan-badge {
    font-size: 11px;
    font-weight: 600;
    padding: 3px 8px;
    border-radius: 99px;
    background: rgba(52, 211, 153, 0.12);
    color: #34d399;
    border: 1px solid rgba(52, 211, 153, 0.25);
    flex-shrink: 0;
  }

  /* ── Compare Button ── */
  .compare-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    width: 100%;
    padding: 13px;
    border-radius: var(--radius-sm);
    border: none;
    background: linear-gradient(135deg, #0ea5e9 0%, #6366f1 100%);
    color: white;
    font-size: 14px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s ease;
    box-shadow: 0 4px 14px rgba(14, 165, 233, 0.22);
    margin-top: 4px;
  }

  .compare-btn:hover:not(:disabled) {
    transform: translateY(-2px);
    box-shadow: 0 6px 18px rgba(14, 165, 233, 0.32);
  }

  .compare-btn:disabled {
    background: #1e293b;
    color: var(--text-muted);
    border: 1px solid var(--card-border);
    cursor: not-allowed;
    box-shadow: none;
  }

  .compare-btn-spinner {
    width: 17px;
    height: 17px;
    border: 2px solid rgba(255,255,255,0.3);
    border-top-color: white;
    border-radius: 50%;
    animation: spin 0.6s linear infinite;
  }

  /* ── Comparison Result ── */
  .compare-result {
    margin-top: 24px;
    padding-top: 24px;
    border-top: 1px solid rgba(255,255,255,0.06);
    animation: fadeUp 0.4s ease both;
  }

  /* Score delta row */
  .compare-score-delta {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 20px;
    background: rgba(15, 23, 42, 0.45);
    border-radius: var(--radius-md);
    border: 1px solid var(--card-border);
    margin-bottom: 22px;
    flex-wrap: wrap;
  }

  .csd-prev, .csd-curr {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2px;
    flex: 1;
  }

  .csd-label {
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--text-muted);
  }

  .csd-value {
    font-size: 30px;
    font-weight: 800;
    color: var(--text-primary);
  }

  .csd-arrow {
    font-size: 24px;
    font-weight: 700;
  }

  .csd-diff {
    padding: 6px 18px;
    border-radius: 99px;
    border: 1px solid;
    font-size: 15px;
    font-weight: 700;
    letter-spacing: 0.02em;
    white-space: nowrap;
  }

  /* Breakdown grid */
  .compare-breakdown-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 14px;
  }

  .compare-breakdown-col {
    background: rgba(15, 23, 42, 0.3);
    border: 1px solid var(--card-border);
    border-radius: var(--radius-sm);
    overflow: hidden;
  }

  .cbcol-header {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 11px 14px;
    font-size: 12px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    border-bottom: 1px solid var(--card-border);
  }

  .cbcol-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .cbcol-count {
    margin-left: auto;
    font-size: 13px;
    font-weight: 700;
    padding: 1px 8px;
    border-radius: 99px;
  }

  .cbcol-header.fixed   { color: #34d399; border-top: 2px solid #34d399; }
  .cbcol-header.fixed .cbcol-dot   { background: #34d399; }
  .cbcol-header.fixed .cbcol-count { background: rgba(52,211,153,0.15); color: #34d399; }

  .cbcol-header.new     { color: #f87171; border-top: 2px solid #f87171; }
  .cbcol-header.new .cbcol-dot     { background: #f87171; }
  .cbcol-header.new .cbcol-count   { background: rgba(248,113,113,0.15); color: #f87171; }

  .cbcol-header.remaining { color: #fbbf24; border-top: 2px solid #fbbf24; }
  .cbcol-header.remaining .cbcol-dot { background: #fbbf24; }
  .cbcol-header.remaining .cbcol-count { background: rgba(251,191,36,0.15); color: #fbbf24; }

  .cbcol-header.improved { color: #60a5fa; border-top: 2px solid #60a5fa; }
  .cbcol-header.improved .cbcol-dot { background: #60a5fa; }
  .cbcol-header.improved .cbcol-count { background: rgba(96,165,250,0.15); color: #60a5fa; }

  .cbcol-header.worsened { color: #fb923c; border-top: 2px solid #fb923c; }
  .cbcol-header.worsened .cbcol-dot { background: #fb923c; }
  .cbcol-header.worsened .cbcol-count { background: rgba(251,146,60,0.15); color: #fb923c; }

  .cbcol-list {
    padding: 10px 12px;
    display: flex;
    flex-direction: column;
    gap: 6px;
    max-height: 220px;
    overflow-y: auto;
  }

  .cbcol-list::-webkit-scrollbar { width: 4px; }
  .cbcol-list::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.1); border-radius: 2px; }

  .compare-rule-item {
    display: flex;
    align-items: flex-start;
    gap: 8px;
    padding: 7px 8px;
    border-radius: 6px;
    background: rgba(255,255,255,0.02);
    border: 1px solid rgba(255,255,255,0.04);
  }

  .compare-rule-icon {
    font-size: 13px;
    font-weight: 700;
    flex-shrink: 0;
    margin-top: 1px;
  }

  .compare-rule-body {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .compare-rule-name {
    font-size: 12.5px;
    font-weight: 600;
    color: var(--text-primary);
    line-height: 1.3;
  }

  .compare-rule-msg {
    font-size: 11.5px;
    color: var(--text-muted);
    line-height: 1.4;
  }

  .compare-empty-list {
    font-size: 12px;
    color: var(--text-muted);
    padding: 8px;
    text-align: center;
    font-style: italic;
  }

  /* ════════════════════════════════════════════
     RICH COMPARISON RESULT STYLES
  ════════════════════════════════════════════ */

  /* Verdict banner */
  .cr-verdict {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 14px 18px;
    border-radius: var(--radius-sm);
    border: 1px solid;
    margin-bottom: 18px;
    animation: fadeUp 0.3s ease both;
  }
  .cr-verdict-emoji { font-size: 24px; flex-shrink: 0; }
  .cr-verdict-text {
    display: flex;
    flex-direction: column;
    gap: 2px;
    font-size: 14px;
    color: var(--text-primary);
  }
  .cr-verdict-text strong { font-weight: 700; }
  .cr-verdict-text span   { font-size: 12px; color: var(--text-muted); }

  /* Score block */
  .cr-score-block {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 20px;
    background: rgba(15,23,42,0.45);
    border: 1px solid var(--card-border);
    border-radius: var(--radius-md);
    margin-bottom: 16px;
  }
  .cr-score-side {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
  }
  .cr-score-role {
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    color: var(--text-muted);
  }
  .cr-score-num {
    font-size: 42px;
    font-weight: 800;
    line-height: 1;
    color: var(--text-primary);
  }
  .cr-grade-pill {
    font-size: 13px;
    font-weight: 700;
    padding: 3px 12px;
    border-radius: 99px;
    border: 1px solid;
  }
  .cr-score-divider {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
    flex-shrink: 0;
  }
  .cr-delta-val   { font-size: 12px; font-weight: 700; text-align: center; }
  .cr-delta-arrow { font-size: 22px; font-weight: 800; }

  /* Summary pills row */
  .cr-summary-pills {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    margin-bottom: 22px;
  }
  .cr-pill {
    flex: 1;
    min-width: 70px;
    display: flex;
