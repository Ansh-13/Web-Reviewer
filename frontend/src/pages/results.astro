    if (t.includes('title')) return 'short_text';
    if (t.includes('h1') || t.includes('heading')) return 'layers';
    if (t.includes('description')) return 'description';
    if (t.includes('links') || t.includes('internal')) return 'link';
    return 'warning';
  }

