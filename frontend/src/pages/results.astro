---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Scan Results | Web-Reviewer">
  <!-- ───────── NAVBAR ───────── -->
  <nav class="navbar">
    <div class="nav-inner">
      <a href="/dashboard" class="nav-brand">
        <span class="brand-icon">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="url(#bg)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <defs><linearGradient id="bg" x1="0" y1="0" x2="24" y2="24"><stop offset="0%" stop-color="#818cf8"/><stop offset="100%" stop-color="#6366f1"/></linearGradient></defs>
            <circle cx="12" cy="12" r="10"/>
            <path d="M8 12l2 2 4-4"/>
          </svg>
        </span>
        <span class="brand-text">Web-Reviewer</span>
      </a>

      <div class="nav-right">
        <a href="/dashboard" class="nav-link" title="Dashboard">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
          <span>Dashboard</span>
        </a>
        <div class="nav-user" id="nav-user-info">
          <img id="nav-avatar" class="nav-avatar" src="https://www.gravatar.com/avatar/00000000000000000000000000000000?d=mp&f=y" alt="Avatar" />
          <span class="nav-name" id="nav-name">...</span>
        </div>
      </div>
    </div>
  </nav>

  <!-- ───────── PAGE CONTENT ───────── -->
  <main class="results-main">
    <!-- Loading spinner -->
    <div class="loading-state" id="page-loader">
      <div class="spinner"></div>
      <p>Fetching scan details…</p>
    </div>

    <!-- Main Section (hidden until loaded) -->
    <section class="content-wrapper hidden" id="content-area">
      <!-- Info Header -->
      <div class="section-header">
        <h1>Detailed Scan Report</h1>
        <p class="section-subtitle">Audit ID: <span class="audit-id" id="report-id"></span></p>
      </div>

      <!-- ── Results Display Card ── -->
      <div class="glass-card results-card" id="results-card">
        <div class="score-ring-container">
          <div class="score-ring" id="score-ring">
            <svg viewBox="0 0 120 120">
              <circle class="ring-bg" cx="60" cy="60" r="52"/>
              <circle class="ring-progress" id="ring-progress" cx="60" cy="60" r="52"/>
            </svg>
            <div class="score-value">
              <span class="score-number" id="score-number">—</span>
              <span class="score-label">Score</span>
            </div>
          </div>
          <div class="grade-container">
            <span class="grade-badge" id="grade-badge">—</span>
            <span class="grade-label">SEO Grade</span>
          </div>
        </div>

        <!-- Counts grid -->
        <div class="counts-grid">
          <div class="count-card error">
            <span class="count-num" id="count-errors">0</span>
            <span class="count-lbl">Errors</span>
          </div>
          <div class="count-card warning">
            <span class="count-num" id="count-warnings">0</span>
            <span class="count-lbl">Warnings</span>
          </div>
          <div class="count-card pass">
            <span class="count-num" id="count-passed">0</span>
            <span class="count-lbl">Passed</span>
          </div>
        </div>

        <!-- Individual checks lists grouped by status -->
        <div class="checks-group-wrapper">
          <h3>Failed Audits (Errors)</h3>
          <div class="results-checks errors-list" id="errors-checks"></div>

          <h3>Warnings</h3>
          <div class="results-checks warnings-list" id="warnings-checks"></div>

          <h3>Passed Checks</h3>
          <div class="results-checks passed-list" id="passed-checks"></div>
        </div>
      </div>

      <!-- ── Report Comparison Card ── -->
      <div class="glass-card compare-card" id="compare-card">
        <div class="compare-card-top">
          <div class="compare-title-group">
            <svg class="compare-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="17 1 21 5 17 9"/>
              <path d="M3 11V9a4 4 0 0 1 4-4h14"/>
              <polyline points="7 23 3 19 7 15"/>
              <path d="M21 13v2a4 4 0 0 1-4 4H3"/>
            </svg>
            <h2>Compare Reports</h2>
          </div>
          <span class="compare-badge">Diff Analysis</span>
        </div>
        <p class="compare-desc">Select the <strong>Current</strong> scan and a <strong>Previous</strong> scan to compare against — see what improved, regressed, or was fixed.</p>

        <!-- Two-column scan selector -->
        <div class="compare-cols-wrapper" id="compare-cols-wrapper">
          <!-- Skeleton -->
          <div class="compare-skeleton compare-skeleton-full" id="compare-skeleton">
            <div class="cskel-row"></div>
            <div class="cskel-row"></div>
            <div class="cskel-row"></div>
          </div>

          <!-- Empty state -->
          <div class="compare-empty hidden" id="compare-empty">
            <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
            <p>Need at least 2 completed scans in this project to compare.</p>
          </div>

          <!-- Two scan columns -->
          <div class="compare-two-cols hidden" id="compare-two-cols">
            <!-- Column A -->
            <div class="compare-col">
              <div class="compare-col-header scan-a-header">
                <span class="compare-col-label">C</span>
                <span>Current Scan</span>
                <span class="compare-col-hint" id="scan-a-hint">None selected</span>
              </div>
              <div class="compare-col-list" id="scan-a-list"></div>
            </div>

            <!-- Divider -->
            <div class="compare-vs-divider">
              <span>VS</span>
            </div>

            <!-- Column B -->
            <div class="compare-col">
              <div class="compare-col-header scan-b-header">
                <span class="compare-col-label scan-b-label">P</span>
                <span>Previous Scan</span>
                <span class="compare-col-hint" id="scan-b-hint">None selected</span>
              </div>
              <div class="compare-col-list" id="scan-b-list"></div>
            </div>
          </div>
        </div>

        <!-- Compare button -->
        <button class="compare-btn hidden" id="compare-btn" disabled>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="17 1 21 5 17 9"/><path d="M3 11V9a4 4 0 0 1 4-4h14"/><polyline points="7 23 3 19 7 15"/><path d="M21 13v2a4 4 0 0 1-4 4H3"/></svg>
          <span id="compare-btn-text">Compare Selected Scans</span>
          <div class="compare-btn-spinner hidden" id="compare-btn-spinner"></div>
        </button>

        <!-- Comparison Result Output -->
        <div class="compare-result hidden" id="compare-result"></div>
      </div>

      <!-- ── AI Insights Card ── -->
      <div class="glass-card ai-card" id="ai-card">
        <div class="ai-header">
          <div class="ai-title-group">
            <svg class="ai-sparkle-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"/>
            </svg>
            <h2>AI Technical Consultant</h2>
          </div>
          <span class="ai-badge">Gemini AI</span>
        </div>
        
        <p class="ai-desc">Get customized explanations and actionable recommendations for your SEO report from our AI consultant.</p>
        
        <!-- Action Button -->
        <button class="ai-btn" id="ai-generate-btn">
          <span id="ai-btn-text">Generate AI Recommendations</span>
          <div class="ai-btn-spinner hidden" id="ai-btn-spinner"></div>
        </button>

        <!-- AI Output Area -->
        <div class="ai-content hidden" id="ai-content-area">
          <div class="ai-markdown" id="ai-insights-output"></div>
        </div>
      </div>
    </section>
  </main>
</Layout>

<!-- ───────── CLIENT-SIDE SCRIPT ───────── -->
<script>
  import { subscribeToAuthState } from '../firebase/auth';

  /* ── DOM refs ── */
  const pageLoader      = document.getElementById('page-loader') as HTMLDivElement;
  const contentArea      = document.getElementById('content-area') as HTMLElement;
  const navAvatar        = document.getElementById('nav-avatar') as HTMLImageElement;
  const navName          = document.getElementById('nav-name') as HTMLSpanElement;
  const reportId         = document.getElementById('report-id') as HTMLSpanElement;

  const scoreNumber      = document.getElementById('score-number') as HTMLSpanElement;
  const gradeBadge       = document.getElementById('grade-badge') as HTMLSpanElement;
  const ringProgress     = document.getElementById('ring-progress') as SVGCircleElement;

  const countErrors      = document.getElementById('count-errors') as HTMLSpanElement;
  const countWarnings    = document.getElementById('count-warnings') as HTMLSpanElement;
  const countPassed      = document.getElementById('count-passed') as HTMLSpanElement;

  const errorsChecks     = document.getElementById('errors-checks') as HTMLDivElement;
  const warningsChecks   = document.getElementById('warnings-checks') as HTMLDivElement;
  const passedChecks     = document.getElementById('passed-checks') as HTMLDivElement;

  const aiGenerateBtn    = document.getElementById('ai-generate-btn') as HTMLButtonElement;
  const aiBtnText        = document.getElementById('ai-btn-text') as HTMLSpanElement;
  const aiBtnSpinner     = document.getElementById('ai-btn-spinner') as HTMLSpanElement;
  const aiContentArea    = document.getElementById('ai-content-area') as HTMLDivElement;
  const aiInsightsOutput = document.getElementById('ai-insights-output') as HTMLDivElement;

  let currentToken: string | null = null;
  let selectedScanA: string | null = null;  // currscan (Current)
  let selectedScanB: string | null = null;  // prevscan (Previous)

  /* ── Read scan_id from query params ── */
  const params = new URLSearchParams(window.location.search);
  const scanId = params.get('scan_id');

  if (!scanId) {
    alert("Scan ID is missing from URL query parameter.");
    window.location.href = "/dashboard";
  }

  /* ── Auth gate ── */
  subscribeToAuthState(async (user) => {
    if (!user) { window.location.href = '/login'; return; }

    navName.textContent = user.displayName || user.email || 'User';
    navAvatar.src = user.photoURL || `https://api.dicebear.com/7.x/initials/svg?seed=${encodeURIComponent(user.email || 'user')}`;

    currentToken = await user.getIdToken();

    // Fetch details
    fetchScanResults();
    fetchProjectScans();
  });

  /* ── Grade colour helper ── */
  function gradeColor(grade: string): string {
    const g = grade.toUpperCase();
    if (g === 'A+' || g === 'A') return '#34d399';
    if (g === 'B') return '#60a5fa';
    if (g === 'C') return '#fbbf24';
    if (g === 'D') return '#fb923c';
    return '#f87171';
  }

  /* ── Fetch details ── */
  async function fetchScanResults() {
    try {
      if (!currentToken || !scanId) return;

      const res = await fetch('http://localhost:3000/api/v1/getScanResults', {
        headers: {
          'Authorization': `Bearer ${currentToken}`,
          'scan_id': scanId,
        },
      });

      if (!res.ok) throw new Error('Failed to load scan results');

      const body = await res.json();
      
      // Since scan_results matches scan_id, body.data is an array e.g., [{ seo: { score, grade, summary, results } }]
      const scanInfo = body.data?.[0]?.seo;

      if (!scanInfo) {
        throw new Error('No scan results found for this Audit ID.');
      }

      pageLoader.classList.add('hidden');
      contentArea.classList.remove('hidden');

      reportId.textContent = scanId;
      renderScanReport(scanInfo);

    } catch (err: any) {
      console.error(err);
      alert(err.message || "Failed to load scan report details.");
      window.location.href = "/dashboard";
    }
  }

  /* ── Render scan report ── */
  function renderScanReport(seo: any) {
    scoreNumber.textContent = seo.score ?? '—';
    gradeBadge.textContent = seo.grade ?? '—';
    gradeBadge.style.background = gradeColor(seo.grade || 'F') + '22';
    gradeBadge.style.color = gradeColor(seo.grade || 'F');
    gradeBadge.style.borderColor = gradeColor(seo.grade || 'F') + '44';

    // Animate score ring
    const circumference = 2 * Math.PI * 52;
    const score = Math.min(Math.max(seo.score || 0, 0), 100);
    const offset = circumference - (score / 100) * circumference;
    ringProgress.style.strokeDasharray = `${circumference}`;
    ringProgress.style.strokeDashoffset = `${circumference}`;
    ringProgress.style.stroke = gradeColor(seo.grade || 'F');
    requestAnimationFrame(() => {
      ringProgress.style.transition = 'stroke-dashoffset 1s ease';
      ringProgress.style.strokeDashoffset = `${offset}`;
    });

    // Summary counts
    const summary = seo.summary || {};
    countErrors.textContent = summary.errors ?? 0;
    countWarnings.textContent = summary.warnings ?? 0;
    countPassed.textContent = summary.passed ?? 0;

    // Checks results
    const results = seo.results || {};
    const errorsList = results.errors || [];
    const warningsList = results.warnings || [];
    const passedList = results.passed || [];

    // Helper to generate lists html
    const mapChecks = (checks: any[], type: 'error' | 'warning' | 'pass') => {
      if (checks.length === 0) {
        return `<div class="empty-group">No audits in this category</div>`;
      }
      return checks.map(r => `
        <div class="check-item ${type}">
          <span class="check-icon">${type === 'pass' ? '✓' : type === 'error' ? '✕' : '⚠'}</span>
          <div class="check-body">
            <span class="check-name">${r.name || r.check || 'Audit Check'}</span>
            ${r.message ? `<span class="check-msg">${r.message}</span>` : ''}
          </div>
        </div>
      `).join('');
    };

    errorsChecks.innerHTML = mapChecks(errorsList, 'error');
    warningsChecks.innerHTML = mapChecks(warningsList, 'warning');
    passedChecks.innerHTML = mapChecks(passedList, 'pass');
  }

  // ── AI generation click handler ──
  aiGenerateBtn.addEventListener('click', async () => {
    if (!currentToken || !scanId) return;

    aiGenerateBtn.disabled = true;
    aiBtnText.textContent = "Analyzing SEO Report...";
    aiBtnSpinner.classList.remove('hidden');
    aiContentArea.classList.add('hidden');

    try {
      const res = await fetch(`http://localhost:3000/api/v1/ai/?scanid=${scanId}`, {
        headers: {
          'Authorization': `Bearer ${currentToken}`
        }
      });

      if (!res.ok) {
        const body = await res.json().catch(() => null);
        const msg = body?.error || (typeof body === 'string' ? body : 'Failed to generate AI insights.');
        throw new Error(msg);
      }

      const result = await res.json();
      const aiText = typeof result.Data === 'string' ? result.Data : (result.Data?.text || result.Data?.candidates?.[0]?.content?.parts?.[0]?.text || '');
      
      if (!aiText) {
        throw new Error("No recommendations generated by AI.");
      }

      // Try to parse JSON from response
      let cleanedText = aiText.trim();
      if (cleanedText.startsWith("```")) {
        cleanedText = cleanedText.replace(/^```(json)?/, "").replace(/```$/, "").trim();
      }

      try {
        const parsedJson = JSON.parse(cleanedText);
        renderAiJsonInsights(parsedJson);
      } catch (jsonErr) {
        // Fallback: render as formatted plain text
        renderAiTextInsights(aiText);
      }

      aiContentArea.classList.remove('hidden');
    } catch (err: any) {
      console.error(err);
      alert(err.message || "Failed to generate AI insights.");
    } finally {
      aiGenerateBtn.disabled = false;
      aiBtnText.textContent = "Regenerate AI Recommendations";
      aiBtnSpinner.classList.add('hidden');
    }
  });

  function escapeHTML(str: string): string {
    return str
      .replace(/&/g, "&amp;")
      .replace(/</g, "&lt;")
      .replace(/>/g, "&gt;")
      .replace(/"/g, "&quot;")
      .replace(/'/g, "&#039;");
  }

  function renderAiJsonInsights(data: any) {
    let html = '';

    // 1. Render Summary (executiveSummary and overallAssessment)
    if (data.summary && typeof data.summary === 'object') {
      const execSummary = data.summary.executiveSummary || data.summary.executive_summary || '';
      const assessment = data.summary.overallAssessment || data.summary.overall_assessment || '';
      
      if (execSummary || assessment) {
        html += `
          <div class="ai-overall-summary">
            ${execSummary ? `
              <div class="summary-section">
                <h5>Executive Summary</h5>
                <p>${execSummary}</p>
              </div>
            ` : ''}
            ${assessment ? `
              <div class="summary-section" style="margin-top: 14px; padding-top: 14px; border-top: 1px dashed rgba(168, 85, 247, 0.25);">
                <h5 style="color: #c084fc;">Overall Assessment</h5>
                <p>${assessment}</p>
              </div>
            ` : ''}
          </div>
        `;
      }
    } else if (data.summary && typeof data.summary === 'string') {
      html += `
        <div class="ai-overall-summary">
          <h5>Executive Summary</h5>
          <p>${data.summary}</p>
        </div>
      `;
    }

    // 2. Render Top Priorities List
    const priorities = data.topPriorities || data.top_priorities || data.priorities;
    if (priorities && Array.isArray(priorities) && priorities.length > 0) {
      html += `
        <div class="ai-priorities-card">
          <div class="priorities-header">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#fbbf24" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/>
              <line x1="12" y1="9" x2="12" y2="13"/>
              <line x1="12" y1="17" x2="12.01" y2="17"/>
            </svg>
            <h5>Top Action Priorities</h5>
          </div>
          <ul class="priorities-list">
            ${priorities.map(p => `<li>${p}</li>`).join('')}
          </ul>
        </div>
      `;
    }

    // 3. Render Recommendations Grid
    const recommendations = data.recommendations || data.issues || data.results || (Array.isArray(data) ? data : null);

    if (recommendations && Array.isArray(recommendations)) {
      html += `<div class="ai-insights-grid">`;
      recommendations.forEach((item: any, idx: number) => {
        const title = item.title || item.issue || item.check || item.name || `Insight #${idx + 1}`;
        const whyItMatters = item.whyItMatters || item.why_it_matters || item.description || item.explanation || item.message || item.summary || '';
        const actionPlan = item.actionPlan || item.action_plan || item.action || item.recommendation || item.fix || item.solution || '';
        const example = item.example || null;
        const ruleId = item.ruleId || item.rule_id || '';

        html += `
          <div class="ai-insight-card">
            <div class="ai-insight-title-row">
              <span class="ai-insight-number">${idx + 1}</span>
              <div style="display: flex; flex-direction: column; gap: 2px;">
                <h4>${title}</h4>
                ${ruleId ? `<span class="ai-rule-id">${ruleId}</span>` : ''}
              </div>
            </div>
            ${whyItMatters ? `
              <div class="ai-insight-desc">
                <h5>Why it matters:</h5>
                <p>${whyItMatters}</p>
              </div>
            ` : ''}
            ${actionPlan ? `
              <div class="ai-insight-action">
                <h5>Action Plan:</h5>
                <p>${actionPlan}</p>
              </div>
            ` : ''}
            ${example ? `
              <div class="ai-insight-example">
                <h5>Example Code:</h5>
                <pre class="example-pre"><code>${escapeHTML(example)}</code></pre>
              </div>
            ` : ''}
          </div>
        `;
      });
      html += `</div>`;
    }

    // Fallback if formatting resulted in empty HTML
    aiInsightsOutput.innerHTML = html || `<pre class="ai-raw-text">${JSON.stringify(data, null, 2)}</pre>`;
  }

  /* ── Fetch project scans for comparison ── */
  const compareSkeleton  = document.getElementById('compare-skeleton') as HTMLDivElement;
  const compareEmpty     = document.getElementById('compare-empty') as HTMLDivElement;
  const compareTwoCols   = document.getElementById('compare-two-cols') as HTMLDivElement;
  const scanAList        = document.getElementById('scan-a-list') as HTMLDivElement;
  const scanBList        = document.getElementById('scan-b-list') as HTMLDivElement;
  const scanAHint        = document.getElementById('scan-a-hint') as HTMLSpanElement;
  const scanBHint        = document.getElementById('scan-b-hint') as HTMLSpanElement;
  const compareBtn       = document.getElementById('compare-btn') as HTMLButtonElement;
  const compareBtnText   = document.getElementById('compare-btn-text') as HTMLSpanElement;
  const compareBtnSpinner = document.getElementById('compare-btn-spinner') as HTMLDivElement;
  const compareResult    = document.getElementById('compare-result') as HTMLDivElement;

  function buildScanRow(s: { id: string; url: string; started_at: string }, col: 'a' | 'b', isCurrent: boolean) {
    const date = s.started_at
      ? new Date(s.started_at).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric', hour: '2-digit', minute: '2-digit' })
      : 'Unknown date';
    const shortUrl = s.url.replace(/^https?:\/\//, '').replace(/\/$/, '').substring(0, 48);
    const currentTag = isCurrent ? '<span class="compare-current-tag">current page</span>' : '';
    return `
      <label class="compare-scan-row" data-id="${s.id}" data-col="${col}">
        <div class="compare-scan-checkbox">
          <input type="radio" name="compare-scan-${col}" value="${s.id}" id="cscan-${col}-${s.id}" class="cscan-radio cscan-radio-${col}">
          <div class="custom-radio"></div>
        </div>
        <div class="compare-scan-info">
          <span class="compare-scan-url" title="${s.url}">${shortUrl} ${currentTag}</span>
          <span class="compare-scan-date">${date}</span>
        </div>
      </label>
    `;
  }

  function updateCompareBtn() {
    compareBtn.disabled = !(selectedScanA && selectedScanB && selectedScanA !== selectedScanB);
  }

  async function fetchProjectScans() {
    if (!currentToken || !scanId) return;
    try {
      const res = await fetch(`http://localhost:3000/api/v1/getProjectScans?scan_id=${scanId}`, {
        headers: { 'Authorization': `Bearer ${currentToken}` }
      });
      if (!res.ok) throw new Error('Failed to fetch project scans');
      const body = await res.json();
      const scans: { id: string; url: string; status: string; started_at: string }[] = body.data || [];

      compareSkeleton.classList.add('hidden');

      if (scans.length < 2) {
        compareEmpty.classList.remove('hidden');
        return;
      }

      compareTwoCols.classList.remove('hidden');
      compareBtn.classList.remove('hidden');

      // Render both columns with all scans
      scanAList.innerHTML = scans.map(s => buildScanRow(s, 'a', s.id === scanId)).join('');
      scanBList.innerHTML = scans.map(s => buildScanRow(s, 'b', s.id === scanId)).join('');

      // Pre-select current scan as Scan A
      const defaultA = scanAList.querySelector<HTMLInputElement>(`input[value="${scanId}"]`);
      if (defaultA) {
        defaultA.checked = true;
        defaultA.closest('.compare-scan-row')?.classList.add('selected');
        selectedScanA = scanId;
        scanAHint.textContent = 'This page (auto-selected)';
      }

      // Wire Scan A radios
      scanAList.querySelectorAll<HTMLInputElement>('.cscan-radio-a').forEach(radio => {
        radio.addEventListener('change', () => {
          selectedScanA = radio.value;
          scanAList.querySelectorAll('.compare-scan-row').forEach(r => r.classList.remove('selected'));
          radio.closest('.compare-scan-row')?.classList.add('selected');
          const label = radio.closest('.compare-scan-row')?.querySelector('.compare-scan-url')?.textContent?.split(' ')[0] || radio.value.slice(0,8);
          scanAHint.textContent = label + '…';
          updateCompareBtn();
        });
      });

      // Wire Scan B radios
      scanBList.querySelectorAll<HTMLInputElement>('.cscan-radio-b').forEach(radio => {
        radio.addEventListener('change', () => {
          selectedScanB = radio.value;
          scanBList.querySelectorAll('.compare-scan-row').forEach(r => r.classList.remove('selected'));
          radio.closest('.compare-scan-row')?.classList.add('selected');
          const label = radio.closest('.compare-scan-row')?.querySelector('.compare-scan-url')?.textContent?.split(' ')[0] || radio.value.slice(0,8);
          scanBHint.textContent = label + '…';
          updateCompareBtn();
        });
      });

    } catch (err) {
      console.error('Error fetching project scans:', err);
      compareSkeleton.classList.add('hidden');
      compareEmpty.classList.remove('hidden');
    }
  }

  /* ── Handle comparison request ── */
  compareBtn.addEventListener('click', async () => {
    if (!currentToken || !selectedScanA || !selectedScanB) return;
    if (selectedScanA === selectedScanB) {
      alert('Please select two different scans to compare.');
      return;
    }

    compareBtn.disabled = true;
    compareBtnText.textContent = 'Comparing...';
    compareBtnSpinner.classList.remove('hidden');
    compareResult.classList.add('hidden');

    try {
      const res = await fetch(`http://localhost:3000/api/v1/report-comparison?currscan=${selectedScanA}&prevscan=${selectedScanB}`, {
        headers: { 'Authorization': `Bearer ${currentToken}` }
      });
      if (!res.ok) {
        const body = await res.json().catch(() => null);
        throw new Error(body?.error || 'Comparison failed');
      }
      const body = await res.json();
      renderComparisonResult(body.data, body.aiReport);
      compareResult.classList.remove('hidden');
      compareResult.scrollIntoView({ behavior: 'smooth', block: 'start' });
    } catch (err: any) {
      alert(err.message || 'Failed to compare reports.');
    } finally {
      compareBtn.disabled = false;
      compareBtnText.textContent = 'Compare Selected Scans';
      compareBtnSpinner.classList.add('hidden');
    }
  });

  function renderComparisonResult(data: any, aiReport: string | null = null) {
    const scores  = data.scores  || {};
    const meta    = data.meta    || {};
    const summary = data.summary || {};
    const changes = data.changes || {};

    /* ── Parse AI JSON response ── */
    function renderAiReport(aiText: string): string {
      try {
        // Strip out any markdown code block wrappers if the AI wrapped the JSON
        const cleanText = aiText.replace(/```json/gi, '').replace(/```/g, '').trim();
        const parsed = JSON.parse(cleanText);

        const summaryHtml = (parsed.executiveSummary || parsed.executive_summary)
          ? `<div class="cr-ai-exec-summary">${parsed.executiveSummary || parsed.executive_summary}</div>` 
          : '';

        const recsHtml = (parsed.recommendations || []).map((rec: any, i: number) => `
          <div class="cr-ai-rec">
            <div class="cr-ai-rec-header">
              <span class="cr-ai-rec-num">${i + 1}</span>
              <h4 class="cr-ai-h">${rec.issue || 'Recommendation'}</h4>
            </div>
            <p class="cr-ai-p"><strong>Why it matters:</strong> ${rec.explanation || rec.why_it_matters || 'No explanation provided.'}</p>
            <p class="cr-ai-p"><strong>Action:</strong> ${rec.action_plan || rec.action || 'No action plan provided.'}</p>
            ${rec.html_example ? `<pre class="cr-ai-code">${rec.html_example.replace(/</g, '&lt;').replace(/>/g, '&gt;')}</pre>` : ''}
          </div>
        `).join('');

        return `
          ${summaryHtml}
          ${recsHtml ? `<div class="cr-ai-recs">${recsHtml}</div>` : ''}
        `;
      } catch (e) {
        // Fallback if AI didn't return valid JSON
        return `<p class="cr-ai-p">${aiText.replace(/\n/g, '<br>')}</p>`;
      }
    }

    const delta      = scores.delta ?? 0;
    const deltaColor = delta > 0 ? '#34d399' : delta < 0 ? '#f87171' : '#94a3b8';
    const verdictBg  = meta.verdict === 'improved'  ? 'rgba(52,211,153,0.08)'
                     : meta.verdict === 'regressed' ? 'rgba(248,113,113,0.08)'
                     : 'rgba(148,163,184,0.08)';
    const verdictBorder = meta.verdict === 'improved'  ? 'rgba(52,211,153,0.25)'
                        : meta.verdict === 'regressed' ? 'rgba(248,113,113,0.25)'
                        : 'rgba(148,163,184,0.2)';

    /* ── Helper: render a ChangeGroup section ── */
    const renderGroup = (group: any, colorClass: string, accentColor: string, icon: string) => {
      if (!group || group.count === 0) return '';
      const itemsHtml = (group.items || []).map((r: any) => {
        const sd = r.scoreDelta ?? 0;
        const sdColor  = sd > 0 ? '#34d399' : sd < 0 ? '#f87171' : '#94a3b8';
        const sdPrefix = sd > 0 ? '+' : '';
        return `
          <div class="cr-rule-card">
            <div class="cr-rule-head">
              <span class="cr-status-pill ${colorClass}">${r.statusLabel || icon}</span>
              <span class="cr-rule-title">${r.title || r.id || 'Unknown'}</span>
              <span class="cr-category-tag">${r.category || ''}</span>
              ${sd !== 0 ? `<span class="cr-score-delta" style="color:${sdColor}">${sdPrefix}${sd} pts</span>` : ''}
            </div>
            <div class="cr-rule-before-after">
              <div class="cr-ba-col before">
                <span class="cr-ba-label">Before</span>
                <span class="cr-ba-status ${r.before?.passed ? 'pass' : 'fail'}">${r.before?.passed ? '✓ Pass' : '✕ Fail'}</span>
                <span class="cr-ba-msg">${r.before?.message || '—'}</span>
              </div>
              <div class="cr-ba-arrow">→</div>
              <div class="cr-ba-col after">
                <span class="cr-ba-label">After</span>
                <span class="cr-ba-status ${r.after?.passed ? 'pass' : 'fail'}">${r.after?.passed ? '✓ Pass' : '✕ Fail'}</span>
                <span class="cr-ba-msg">${r.after?.message || '—'}</span>
              </div>
            </div>
            ${r.recommendation ? `
              <div class="cr-recommendation">
                <span class="cr-rec-label">💡 Recommendation</span>
                <span class="cr-rec-text">${r.recommendation}</span>
              </div>` : ''}
          </div>
        `;
      }).join('');

      return `
        <div class="cr-group">
          <div class="cr-group-header" style="border-left-color:${accentColor}">
            <span class="cr-group-icon">${icon}</span>
            <span class="cr-group-label">${group.label}</span>
            <span class="cr-group-desc">${group.description}</span>
            <span class="cr-group-count" style="background:${accentColor}20;color:${accentColor}">${group.count}</span>
          </div>
          <div class="cr-group-items">${itemsHtml}</div>
        </div>
      `;
    };

    compareResult.innerHTML = `
      ${aiReport ? `
      <!-- AI Executive Summary -->
      <div class="cr-ai-summary">
        <div class="cr-ai-summary-header">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"/></svg>
          <span>AI Executive Summary</span>
          <span class="cr-ai-badge">Gemini AI</span>
        </div>
        <div class="cr-ai-body">${renderAiReport(aiReport)}</div>
      </div>
      ` : ''}

      <!-- Verdict Banner -->
      <div class="cr-verdict" style="background:${verdictBg};border-color:${verdictBorder}">
        <span class="cr-verdict-emoji">${meta.verdictEmoji || '➖'}</span>
        <div class="cr-verdict-text">
          <strong>${meta.verdictLabel || 'Comparison Complete'}</strong>
          <span>${meta.changedChecks ?? 0} of ${meta.totalChecks ?? 0} checks changed</span>
        </div>
      </div>

      <!-- Score Block -->
      <div class="cr-score-block">
        <div class="cr-score-side">
          <span class="cr-score-role">Current Scan</span>
          <span class="cr-score-num">${scores.current ?? '—'}</span>
          <span class="cr-grade-pill" style="background:rgba(56,189,248,0.15);color:#38bdf8;border-color:rgba(56,189,248,0.3)">${scores.currentGrade ?? '—'}</span>
        </div>
        <div class="cr-score-divider">
          <span class="cr-delta-val" style="color:${deltaColor}">${scores.deltaLabel || '—'}</span>
          <span class="cr-delta-arrow" style="color:${deltaColor}">${delta > 0 ? '▲' : delta < 0 ? '▼' : '●'}</span>
        </div>
        <div class="cr-score-side">
          <span class="cr-score-role">Previous Scan</span>
          <span class="cr-score-num">${scores.previous ?? '—'}</span>
          <span class="cr-grade-pill" style="background:rgba(168,85,247,0.15);color:#c084fc;border-color:rgba(168,85,247,0.3)">${scores.previousGrade ?? '—'}</span>
        </div>
      </div>

      <!-- Summary Pills -->
      <div class="cr-summary-pills">
        <div class="cr-pill fixed">  <span>${summary.fixed     ?? 0}</span><span>Fixed</span></div>
        <div class="cr-pill new">    <span>${summary.newIssues ?? 0}</span><span>New Issues</span></div>
        <div class="cr-pill worse">  <span>${summary.worsened  ?? 0}</span><span>Worsened</span></div>
        <div class="cr-pill better"> <span>${summary.improved  ?? 0}</span><span>Improved</span></div>
        <div class="cr-pill remain"> <span>${summary.remaining ?? 0}</span><span>Remaining</span></div>
      </div>

      <!-- Change Groups -->
      <div class="cr-groups">
        ${renderGroup(changes.fixed,     'pill-fixed',   '#34d399', '✅ Fixed')}
        ${renderGroup(changes.newIssues, 'pill-new',     '#f87171', '🔴 Regressions')}
        ${renderGroup(changes.worsened,  'pill-worse',   '#fb923c', '📉 Worsened')}
        ${renderGroup(changes.improved,  'pill-better',  '#60a5fa', '📈 Improved')}
        ${renderGroup(changes.remaining, 'pill-remain',  '#fbbf24', '⚠️ Remaining')}
      </div>
    `;
  }


  function renderAiTextInsights(text: string) {
    const paragraphs = text
      .split('\n\n')
      .map(p => {
        const trimmed = p.trim();
        if (!trimmed) return '';
        if (trimmed.startsWith('-') || trimmed.startsWith('*')) {
          const listItems = trimmed
            .split('\n')
            .map(li => `<li>${li.replace(/^[-*]\s*/, '')}</li>`)
            .join('');
          return `<ul>${listItems}</ul>`;
        }
        if (trimmed.startsWith('#')) {
          const level = (trimmed.match(/^#+/) || ['#'])[0].length;
          const cleanText = trimmed.replace(/^#+\s*/, '');
          return `<h${Math.min(level + 2, 6)}>${cleanText}</h${Math.min(level + 2, 6)}>`;
        }
        return `<p>${trimmed.replace(/\n/g, '<br>')}</p>`;
      })
      .filter(Boolean)
      .join('');

    aiInsightsOutput.innerHTML = `<div class="ai-raw-text">${paragraphs}</div>`;
  }
</script>

