    const selectedRule = optimiserRuleSelect.value;
    if (!currentToken || !scanId || !selectedRule) return;

    if (optimiserLoaded && selectedRule === currentOptimisedRule) {
      if (optimiserOpen) {
        optimiserContentArea.classList.add('hidden');
        optimiserBtnText.textContent = "Show Output";
        optimiserOpen = false;
      } else {
        optimiserContentArea.classList.remove('hidden');
        optimiserBtnText.textContent = "Close Output";
        optimiserOpen = true;
      }
      return;
    }

    optimiserBtn.disabled = true;
    optimiserBtnText.textContent = "Optimising...";
    optimiserBtnSpinner.classList.remove('hidden');
    optimiserContentArea.classList.add('hidden');

    try {
      const res = await fetch(`http://localhost:3000/api/v1/optimiser`, {
        method: 'POST',
        headers: {
          'Authorization': `Bearer ${currentToken}`,
          'Content-Type': 'application/json'
        },
        body: JSON.stringify({ scanid: scanId, rule: selectedRule })
      });

      if (!res.ok) {
        const body = await res.json().catch(() => null);
        const msg = body?.error || (typeof body === 'string' ? body : 'Failed to generate optimisation.');
        throw new Error(msg);
      }

      const result = await res.json();
      const aiText = typeof result === 'string' ? result : (result?.candidates?.[0]?.content?.parts?.[0]?.text || JSON.stringify(result));

      renderAiTextInsightsForOptimiser(aiText);
      optimiserContentArea.classList.remove('hidden');
      optimiserLoaded = true;
      optimiserOpen = true;
      currentOptimisedRule = selectedRule;
      optimiserBtnText.textContent = "Close Output";
    } catch (err: any) {
      console.error(err);
      alert(err.message || "Failed to generate optimisation.");
    } finally {
      optimiserBtn.disabled = false;
      if (optimiserLoaded && selectedRule === currentOptimisedRule) {
        optimiserBtnText.textContent = optimiserOpen ? "Close Output" : "Show Output";
      } else {
        optimiserBtnText.textContent = "Optimise";
      }
      optimiserBtnSpinner.classList.add('hidden');
    }
  });

  if (closeOptimiserBtn) {
    closeOptimiserBtn.addEventListener('click', () => {
      optimiserContentArea.classList.add('hidden');
      optimiserOpen = false;
      if (optimiserRuleSelect.value === currentOptimisedRule) {
        optimiserBtnText.textContent = "Show Output";
      } else {
        optimiserBtnText.textContent = "Optimise";
      }
    });
  }

  if (closeOptimiserBtnBottom) {
    closeOptimiserBtnBottom.addEventListener('click', () => {
      optimiserContentArea.classList.add('hidden');
      optimiserOpen = false;
      if (optimiserRuleSelect.value === currentOptimisedRule) {
        optimiserBtnText.textContent = "Show Output";
      } else {
        optimiserBtnText.textContent = "Optimise";
      }
    });
  }

  function renderAiTextInsightsForOptimiser(text: string) {
    let cleanText = text.trim();
    if (cleanText.startsWith('```')) {
      cleanText = cleanText.replace(/^```(?:json)?\n?/, '').replace(/\n?```$/, '').trim();
    }
    
    let data: any = null;
    try {
      data = JSON.parse(cleanText);
    } catch (e) {
      const jsonStart = cleanText.indexOf('{');
      const jsonEnd = cleanText.lastIndexOf('}');
      if (jsonStart !== -1 && jsonEnd !== -1 && jsonEnd > jsonStart) {
        try {
          data = JSON.parse(cleanText.substring(jsonStart, jsonEnd + 1));
        } catch (innerError) {
          console.error("Failed relaxed JSON parsing:", innerError);
        }
      }
    }

    const titleText = data?.recommendationTitle || data?.title || 'Optimisation Fix';
    if (data && typeof data === 'object' && titleText) {
      const formatSteps = (steps: any): string => {
        if (!steps) return '';
        if (Array.isArray(steps)) {
          const listItems = steps.map(step => `<li class="text-sm text-slate-300">${escapeHTML(step)}</li>`).join('');
          return `<ol class="list-decimal pl-5 space-y-1">${listItems}</ol>`;
        }
        const stepsStr = String(steps);
        const lines = stepsStr.split('\n').map(line => line.trim()).filter(Boolean);
        if (lines.length > 1) {
          const listItems = lines.map(line => {
            const cleanLine = line.replace(/^\d+[\.\)]\s*/, '').replace(/^[-*+]\s*/, '');
            return `<li class="text-sm text-slate-300">${escapeHTML(cleanLine)}</li>`;
          }).join('');
          return `<ol class="list-decimal pl-5 space-y-1">${listItems}</ol>`;
        }
        return `<p class="text-sm text-slate-300">${escapeHTML(stepsStr)}</p>`;
      };

      const renderAlternatives = (alts: any): string => {
        if (!alts || !Array.isArray(alts) || alts.length === 0) return '';
        const items = alts.map(alt => `
          <div class="flex items-center gap-2 text-sm text-purple-400 font-medium bg-purple-500/5 px-3 py-1.5 rounded-lg border border-purple-500/10">
            <i class="w-4 h-4 text-purple-400 flex-shrink-0" data-lucide="check"></i>
            <span>${escapeHTML(alt)}</span>
          </div>
        `).join('');
        return `<div class="flex flex-wrap gap-2 mt-2">${items}</div>`;
      };

      const renderGeneratedContent = (content: any): string => {
        if (!content) return '';
        if (typeof content === 'string') {
          return `
            <div class="border border-white/5 rounded-lg overflow-hidden bg-black/20 text-xs">
              <div class="flex justify-between items-center bg-white/5 px-4 py-2 border-b border-white/5">
                <span class="font-bold text-slate-400 uppercase tracking-widest text-[9px]">Recommendation</span>
                <button class="text-accent hover:text-white font-semibold uppercase tracking-wider text-[9px] hover:underline" onclick="navigator.clipboard.writeText(this.closest('.border').querySelector('.code-val').innerText); this.innerText='Copied!'; setTimeout(() => this.innerText='Copy', 1500)">Copy</button>
              </div>
              <pre class="p-4 text-emerald-400 font-mono overflow-x-auto code-val">${escapeHTML(content)}</pre>
            </div>
          `;
        }
        if (typeof content === 'object') {
          const rows = Object.entries(content).map(([key, val]) => {
            const formattedKey = key.replace(/_/g, ' ').replace(/\b\w/g, c => c.toUpperCase());
            return `
              <div class="border border-white/5 rounded-lg overflow-hidden bg-black/20 text-xs">
                <div class="flex justify-between items-center bg-white/5 px-4 py-2 border-b border-white/5">
                  <span class="font-bold text-slate-400 uppercase tracking-widest text-[9px]">${escapeHTML(formattedKey)}</span>
                  <button class="text-accent hover:text-white font-semibold uppercase tracking-wider text-[9px] hover:underline" onclick="navigator.clipboard.writeText(this.closest('.border').querySelector('.code-val').innerText); this.innerText='Copied!'; setTimeout(() => this.innerText='Copy', 1500)">Copy</button>
                </div>
                <pre class="p-4 text-emerald-400 font-mono overflow-x-auto code-val">${escapeHTML(String(val))}</pre>
              </div>
            `;
          }).join('');
          return `<div class="space-y-4">${rows}</div>`;
        }
        return '';
      };

      const summaryText = data.summary;
      const reasoningText = data.reasoning;
      const whyItMattersText = data.whyItMatters || data.why;

      optimiserOutput.innerHTML = `
        <div class="glass-card p-6 bg-purple-500/5 border border-purple-500/20 space-y-5">
          <!-- Header -->
          <div class="flex items-center gap-4 border-b border-white/5 pb-4">
            <div class="w-10 h-10 rounded-lg bg-purple-500/10 flex items-center justify-center text-purple-400 flex-shrink-0">
              <i class="w-5 h-5" data-lucide="zap"></i>
            </div>
            <div>
              <span class="text-[10px] text-purple-400 font-bold uppercase tracking-wider">AI Recommendation</span>
              <h4 class="font-bold text-white text-lg">${escapeHTML(titleText)}</h4>
            </div>
          </div>

          <!-- Summary -->
          ${summaryText && summaryText.trim() !== '' ? `
            <div>
              <span class="text-xs uppercase text-slate-500 font-bold block mb-1">Summary</span>
              <p class="text-sm text-slate-300">${escapeHTML(summaryText)}</p>
            </div>
          ` : ''}

          <!-- Reasoning -->
          ${reasoningText && reasoningText.trim() !== '' ? `
            <div>
              <span class="text-xs uppercase text-slate-500 font-bold block mb-1">Reasoning</span>
              <p class="text-sm text-slate-300">${escapeHTML(reasoningText)}</p>
            </div>
          ` : ''}

          <!-- Why It Matters -->
          ${whyItMattersText && whyItMattersText.trim() !== '' ? `
            <div>
              <span class="text-xs uppercase text-slate-500 font-bold block mb-1">Why It Matters</span>
              <p class="text-sm text-slate-300">${escapeHTML(whyItMattersText)}</p>
            </div>
          ` : ''}

          <!-- Steps -->
          ${data.steps ? `
            <div>
              <span class="text-xs uppercase text-slate-500 font-bold block mb-2">Steps to Fix</span>
              ${formatSteps(data.steps)}
            </div>
          ` : ''}

          <!-- Code Recommendations -->
          ${data.generatedContent ? `
            <div>
              <span class="text-xs uppercase text-slate-500 font-bold block mb-2">Optimised Content</span>
              ${renderGeneratedContent(data.generatedContent)}
            </div>
          ` : ''}

          <!-- Alternatives -->
          ${data.alternatives ? `
            <div>
              <span class="text-xs uppercase text-slate-500 font-bold block mb-1">Alternative Options</span>
              ${renderAlternatives(data.alternatives)}
            </div>
          ` : ''}
        </div>
      `;
    } else {
      optimiserOutput.innerHTML = `
        <div class="glass-card p-6 bg-purple-500/5 border border-purple-500/20 text-sm text-slate-300 whitespace-pre-wrap font-mono leading-relaxed">
          ${escapeHTML(text)}
        </div>
      `;
    }
    
    if (window.lucide) {
      window.lucide.createIcons();
    }
  }

  function escapeHTML(str: string): string {
    return str
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;')
      .replace(/'/g, '&#039;');
  }

  /* ── Fetch project scans for comparison ── */
  const compareSkeleton  = document.getElementById('compare-skeleton') as HTMLDivElement;
  const compareEmpty     = document.getElementById('compare-empty') as HTMLDivElement;
  const scanBList        = document.getElementById('scan-b-list') as HTMLDivElement;
  const scanBHint        = document.getElementById('scan-b-hint') as HTMLSpanElement;
  const compareBtn       = document.getElementById('compare-btn') as HTMLButtonElement;
  const compareBtnText   = document.getElementById('compare-btn-text') as HTMLSpanElement;
  const compareBtnSpinner = document.getElementById('compare-btn-spinner') as HTMLDivElement;
  const compareResult    = document.getElementById('compare-result') as HTMLDivElement;
  const compareResultArea = document.getElementById('compare-result-area') as HTMLDivElement;
  const closeCompareBtn   = document.getElementById('close-compare-btn') as HTMLButtonElement;
  const closeCompareBtnBottom = document.getElementById('close-compare-btn-bottom') as HTMLButtonElement;

  let compareLoaded = false;
  let compareOpen = false;
  let currentComparedScan: string | null = null;

  function buildScanRow(s: { id: string; url: string; started_at: string }, col: 'a' | 'b', isCurrent: boolean) {
    const date = s.started_at
      ? new Date(s.started_at).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric', hour: '2-digit', minute: '2-digit' })
      : 'Unknown date';
    const shortUrl = s.url.replace(/^https?:\/\//, '').replace(/\/$/, '').substring(0, 48);
    const currentTag = isCurrent ? '<span class="text-[9px] font-bold text-accent uppercase bg-accent/10 px-1.5 py-0.5 rounded ml-2">Current</span>' : '';
    return `
      <label class="compare-scan-row" data-id="${s.id}" data-col="${col}">
        <div class="flex items-center gap-2">
          <input type="radio" name="compare-scan-${col}" value="${s.id}" id="cscan-${col}-${s.id}" class="w-4 h-4 text-accent bg-black/40 border-white/10 focus:ring-accent focus:ring-offset-0 focus:ring-1">
        </div>
        <div class="flex flex-col min-w-0">
          <span class="text-sm font-semibold text-white truncate flex items-center" title="${s.url}">${shortUrl} ${currentTag}</span>
          <span class="text-xs text-slate-500 font-mono mt-0.5">${date}</span>
        </div>
      </label>
    `;
  }

  function updateCompareBtn() {
    if (selectedScanB && selectedScanB === currentComparedScan && compareLoaded) {
      compareBtn.disabled = false;
      compareBtnText.textContent = compareOpen ? "Close Comparison" : "Show Comparison";
    } else {
      compareBtn.disabled = !selectedScanB;
      compareBtnText.textContent = "Compare Scans";
    }
  }

  async function fetchProjectScans() {
    if (!currentToken || !scanId) return;
    try {
      const res = await fetch(`http://localhost:3000/api/v1/getProjectScans?scan_id=${scanId}`, {
        headers: { 'Authorization': `Bearer ${currentToken}` }
      });
      if (!res.ok) throw new Error('Failed to fetch project scans');
      const body = await res.json();
      const scans: { id: string; url: string; status: string; started_at: string }[] = body.data || [];

      compareSkeleton.classList.add('hidden');

      const otherScans = scans.filter(s => s.id !== scanId);

      if (otherScans.length === 0) {
        compareEmpty.classList.remove('hidden');
        return;
      }

      const compareSingleCol = document.getElementById('compare-single-col') as HTMLDivElement;
      if (compareSingleCol) {
        compareSingleCol.classList.remove('hidden');
      }
      compareBtn.classList.remove('hidden');

      scanBList.innerHTML = otherScans.map(s => buildScanRow(s, 'b', false)).join('');

      // Wire Scan B radios
      scanBList.querySelectorAll<HTMLInputElement>('input[name="compare-scan-b"]').forEach(radio => {
        radio.addEventListener('change', () => {
          selectedScanB = radio.value;
          scanBList.querySelectorAll('.compare-scan-row').forEach(r => r.classList.remove('selected'));
          radio.closest('.compare-scan-row')?.classList.add('selected');
          const label = radio.closest('.compare-scan-row')?.querySelector('.text-sm')?.textContent?.split(' ')[0] || radio.value.slice(0,8);
          scanBHint.textContent = label + '…';
          selectedScanA = scanId; // Always compare with the current scan
          updateCompareBtn();
        });
      });

    } catch (err) {
      console.error('Error fetching project scans:', err);
      compareSkeleton.classList.add('hidden');
      compareEmpty.classList.remove('hidden');
    }
  }

  /* ── Handle comparison request ── */
  compareBtn.addEventListener('click', async () => {
    selectedScanA = scanId; // Ensure A is the current scan
    if (!currentToken || !selectedScanA || !selectedScanB) return;

    if (compareLoaded && selectedScanB === currentComparedScan) {
      if (compareOpen) {
        compareResultArea.classList.add('hidden');
        compareBtnText.textContent = 'Show Comparison';
        compareOpen = false;
      } else {
        compareResultArea.classList.remove('hidden');
        compareBtnText.textContent = 'Close Comparison';
        compareOpen = true;
      }
      return;
    }

    compareBtn.disabled = true;
    compareBtnText.textContent = 'Comparing...';
    compareBtnSpinner.classList.remove('hidden');
    compareResultArea.classList.add('hidden');

    try {
      const res = await fetch(`http://localhost:3000/api/v1/report-comparison?currscan=${selectedScanA}&prevscan=${selectedScanB}`, {
        headers: { 'Authorization': `Bearer ${currentToken}` }
      });
      if (!res.ok) {
        const body = await res.json().catch(() => null);
        throw new Error(body?.error || 'Comparison failed');
      }
      const body = await res.json();
      renderComparisonResult(body.data, body.aiReport);
      compareResultArea.classList.remove('hidden');
      compareResultArea.scrollIntoView({ behavior: 'smooth', block: 'start' });
      compareLoaded = true;
      compareOpen = true;
      currentComparedScan = selectedScanB;
      compareBtnText.textContent = 'Close Comparison';
    } catch (err: any) {
      alert(err.message || 'Failed to compare reports.');
    } finally {
      compareBtn.disabled = false;
      if (compareLoaded && selectedScanB === currentComparedScan) {
        compareBtnText.textContent = compareOpen ? 'Close Comparison' : 'Show Comparison';
      } else {
        compareBtnText.textContent = 'Compare Scans';
      }
      compareBtnSpinner.classList.add('hidden');
    }
  });

  if (closeCompareBtn) {
    closeCompareBtn.addEventListener('click', () => {
      compareResultArea.classList.add('hidden');
      compareOpen = false;
      if (selectedScanB === currentComparedScan) {
        compareBtnText.textContent = 'Show Comparison';
      } else {
        compareBtnText.textContent = 'Compare Scans';
      }
    });
  }

  if (closeCompareBtnBottom) {
    closeCompareBtnBottom.addEventListener('click', () => {
      compareResultArea.classList.add('hidden');
      compareOpen = false;
      if (selectedScanB === currentComparedScan) {
        compareBtnText.textContent = 'Show Comparison';
      } else {
        compareBtnText.textContent = 'Compare Scans';
      }
    });
  }

  function renderComparisonResult(data: any, aiReport: string | null = null) {
    const scores  = data.scores  || {};
    const meta    = data.meta    || {};
    const summary = data.summary || {};
    const changes = data.changes || {};

    function renderAiReport(aiText: string): string {
      try {
        const cleanText = aiText.replace(/```json/gi, '').replace(/```/g, '').trim();
        const parsed = JSON.parse(cleanText);

        const summaryHtml = (parsed.executiveSummary || parsed.executive_summary)
          ? `<div class="text-sm text-slate-300 leading-relaxed">${parsed.executiveSummary || parsed.executive_summary}</div>` 
          : '';

        const recsHtml = (parsed.recommendations || []).map((rec: any, i: number) => `
          <div class="glass-card p-6 bg-white/[0.02] border border-white/5 space-y-4 hover:border-white/10 transition-all">
            <div class="flex items-center gap-3">
              <span class="w-7 h-7 rounded-full bg-accent/25 text-accent flex items-center justify-center text-xs font-bold border border-accent/20">${i + 1}</span>
              <h4 class="font-bold text-white text-base">${escapeHTML(rec.issue || 'Recommendation')}</h4>
            </div>
            <div class="space-y-2 text-sm leading-relaxed">
              <p class="text-slate-300"><span class="text-accent font-semibold">Why it matters:</span> ${escapeHTML(rec.explanation || rec.why_it_matters || 'No explanation provided.')}</p>
              <p class="text-slate-300"><span class="text-accent font-semibold">Action Plan:</span> ${escapeHTML(rec.action_plan || rec.action || 'No action plan provided.')}</p>
            </div>
            ${rec.html_example ? `<pre class="bg-black/40 p-4 rounded-lg overflow-x-auto text-xs text-emerald-400 font-mono border border-white/5 mt-3"><code>${rec.html_example.replace(/</g, '&lt;').replace(/>/g, '&gt;')}</code></pre>` : ''}
          </div>
        `).join('');

        return `
          <div class="space-y-4">
            ${summaryHtml}
            ${recsHtml ? `<div class="grid grid-cols-1 gap-4 mt-4">${recsHtml}</div>` : ''}
          </div>
        `;
      } catch (e) {
        return `<p class="text-sm text-slate-300 leading-relaxed">${aiText.replace(/\n/g, '<br>')}</p>`;
      }
    }

    const delta      = scores.delta ?? 0;
    const deltaColor = delta > 0 ? 'text-emerald-400' : delta < 0 ? 'text-red-400' : 'text-slate-400';
    const verdictBg  = meta.verdict === 'improved'  ? 'bg-emerald-500/10'
                     : meta.verdict === 'regressed' ? 'bg-red-500/10'
                     : 'bg-white/5';
    const verdictBorder = meta.verdict === 'improved'  ? 'border-emerald-500/20'
                        : meta.verdict === 'regressed' ? 'border-red-500/20'
                        : 'border-white/10';

    const renderGroup = (group: any, badgeStyle: string, accentBorder: string, icon: string) => {
      if (!group || group.count === 0) return '';
      const itemsHtml = (group.items || []).map((r: any) => {
        const sd = r.scoreDelta ?? 0;
        const sdColor  = sd > 0 ? 'text-emerald-400 border-emerald-500/20 bg-emerald-500/10' : sd < 0 ? 'text-red-400 border-red-500/20 bg-red-500/10' : 'text-slate-400 border-white/10 bg-white/5';
        const sdPrefix = sd > 0 ? '+' : '';
        return `
          <div class="glass-card p-6 border border-white/5 bg-black/20 space-y-5">
            <div class="flex flex-wrap items-center gap-3">
              <span class="text-[10px] font-bold px-2.5 py-1 rounded-full ${badgeStyle}">${escapeHTML(r.statusLabel || icon)}</span>
              <span class="font-bold text-base text-white">${escapeHTML(r.title || r.id || 'Unknown')}</span>
              <span class="text-xs text-slate-400 font-mono bg-white/5 px-2.5 py-1 rounded border border-white/5">${escapeHTML(r.category || '')}</span>
              ${sd !== 0 ? `<span class="text-xs font-bold px-3 py-1 rounded-full border ${sdColor} ml-auto">${sdPrefix}${sd} pts</span>` : ''}
            </div>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4 border-t border-white/5 pt-4">
              <!-- Before state -->
              <div class="p-4 rounded-xl bg-white/[0.01] border border-white/5 flex flex-col gap-2">
                <span class="text-[10px] uppercase tracking-wider text-slate-500 font-bold flex items-center gap-1.5">
                  <span class="w-1.5 h-1.5 rounded-full bg-slate-500"></span> Before
                </span>
                <span class="text-xs font-semibold ${r.before?.passed ? 'text-emerald-400' : 'text-red-400'}">
                  ${r.before?.passed ? '✓ Passed Check' : '✕ Failed Check'}
                </span>
                <p class="text-sm text-slate-400 leading-relaxed">${escapeHTML(r.before?.message || '—')}</p>
              </div>

              <!-- After state -->
              <div class="p-4 rounded-xl bg-accent/[0.02] border border-accent/15 flex flex-col gap-2">
                <span class="text-[10px] uppercase tracking-wider text-accent font-bold flex items-center gap-1.5">
                  <span class="w-1.5 h-1.5 rounded-full bg-accent"></span> After
                </span>
                <span class="text-xs font-semibold ${r.after?.passed ? 'text-emerald-400' : 'text-red-400'}">
                  ${r.after?.passed ? '✓ Passed Check' : '✕ Failed Check'}
                </span>
                <p class="text-sm text-slate-300 leading-relaxed">${escapeHTML(r.after?.message || '—')}</p>
              </div>
            </div>
            ${r.recommendation ? `
              <div class="bg-black/35 p-4 rounded-xl border border-white/5 text-sm text-slate-300">
                <strong class="text-accent block mb-1">💡 Recommendation</strong>
                <span>${escapeHTML(r.recommendation)}</span>
              </div>` : ''}
          </div>
        `;
      }).join('');

      return `
        <div class="space-y-6">
          <div class="flex items-center gap-3 border-l-4 ${accentBorder} pl-4 py-1">
            <span class="text-base font-bold text-white uppercase tracking-wider">${escapeHTML(group.label)}</span>
            <span class="text-xs text-slate-400 hidden sm:inline">${escapeHTML(group.description)}</span>
            <span class="ml-auto text-xs font-bold px-3 py-1 rounded-full bg-white/5 text-slate-400 border border-white/10">${group.count}</span>
          </div>
          <div class="space-y-4">${itemsHtml}</div>
        </div>
      `;
    };

    compareResult.innerHTML = `
      <div class="space-y-8 animate-fade-in">
        ${aiReport ? `
        <!-- AI Executive Summary -->
        <div class="glass-card p-6 bg-accent/5 border border-accent/20 space-y-4">
          <div class="flex items-center justify-between border-b border-white/5 pb-4">
            <div class="flex items-center gap-2 text-white">
              <i class="w-5 h-5 text-accent animate-pulse" data-lucide="sparkles"></i>
              <span class="font-bold text-lg">AI Executive Summary</span>
            </div>
          </div>
          <div>${renderAiReport(aiReport)}</div>
        </div>
        ` : ''}

        <!-- Verdict Banner -->
        <div class="p-5 rounded-lg border flex items-center gap-4 ${verdictBg} ${verdictBorder}">
          <span class="text-2xl">${escapeHTML(meta.verdictEmoji || '➖')}</span>
          <div class="flex flex-col">
            <strong class="text-white text-base">${escapeHTML(meta.verdictLabel || 'Comparison Complete')}</strong>
            <span class="text-xs text-slate-400">${meta.changedChecks ?? 0} of ${meta.totalChecks ?? 0} checks changed</span>
          </div>
        </div>

        <!-- Score Block -->
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 items-center justify-center text-center py-8 px-6 bg-surface-container/30 rounded-2xl border border-white/10 shadow-xl">
          <div class="flex flex-col items-center gap-2">
            <span class="text-xs uppercase font-semibold text-slate-500 tracking-widest">Current Scan</span>
            <span class="text-4xl font-extrabold text-white tracking-tight">${scores.current ?? '—'}</span>
            <span class="text-xs font-bold bg-accent/20 text-accent px-3 py-1 rounded-full border border-accent/30">${scores.currentGrade ?? '—'}</span>
          </div>
          <div class="flex flex-col items-center justify-center py-4 sm:py-0 border-t border-b sm:border-t-0 sm:border-b-0 border-white/5 gap-1">
            <span class="text-xs font-bold ${deltaColor} uppercase tracking-wider">${scores.deltaLabel || '—'}</span>
            <span class="text-2xl font-black ${deltaColor}">${delta > 0 ? '▲' : delta < 0 ? '▼' : '●'}</span>
          </div>
          <div class="flex flex-col items-center gap-2">
            <span class="text-xs uppercase font-semibold text-slate-500 tracking-widest">Previous Scan</span>
            <span class="text-4xl font-extrabold text-white tracking-tight">${scores.previous ?? '—'}</span>
            <span class="text-xs font-bold bg-purple-500/20 text-purple-400 px-3 py-1 rounded-full border border-purple-500/30">${scores.previousGrade ?? '—'}</span>
          </div>
        </div>

        <!-- Summary Pills -->
        <div class="grid grid-cols-2 sm:grid-cols-5 gap-4">
          <div class="bg-emerald-500/10 border border-emerald-500/20 p-5 rounded-xl text-center flex flex-col gap-2 hover:bg-emerald-500/15 transition-all">
            <span class="text-2xl font-extrabold text-emerald-400">${summary.fixed ?? 0}</span>
            <span class="text-[10px] text-slate-400 uppercase font-bold tracking-wider">Fixed</span>
          </div>
          <div class="bg-red-500/10 border border-red-500/20 p-5 rounded-xl text-center flex flex-col gap-2 hover:bg-red-500/15 transition-all">
            <span class="text-2xl font-extrabold text-red-400">${summary.newIssues ?? 0}</span>
            <span class="text-[10px] text-slate-400 uppercase font-bold tracking-wider">New Issues</span>
          </div>
          <div class="bg-orange-500/10 border border-orange-500/20 p-5 rounded-xl text-center flex flex-col gap-2 hover:bg-orange-500/15 transition-all">
            <span class="text-2xl font-extrabold text-orange-400">${summary.worsened ?? 0}</span>
            <span class="text-[10px] text-slate-400 uppercase font-bold tracking-wider">Worsened</span>
          </div>
          <div class="bg-blue-500/10 border border-blue-500/20 p-5 rounded-xl text-center flex flex-col gap-2 hover:bg-blue-500/15 transition-all">
            <span class="text-2xl font-extrabold text-blue-400">${summary.improved ?? 0}</span>
            <span class="text-[10px] text-slate-400 uppercase font-bold tracking-wider">Improved</span>
          </div>
          <div class="bg-amber-500/10 border border-amber-500/20 p-5 rounded-xl text-center flex flex-col gap-2 hover:bg-amber-500/15 transition-all col-span-2 sm:col-span-1">
            <span class="text-2xl font-extrabold text-amber-400">${summary.remaining ?? 0}</span>
            <span class="text-[10px] text-slate-400 uppercase font-bold tracking-wider">Remaining</span>
          </div>
        </div>

        <!-- Change Groups -->
        <div class="space-y-10 pt-8 border-t border-white/10">
          ${renderGroup(changes.fixed,     'bg-emerald-500/10 text-emerald-400 border border-emerald-500/20', 'border-emerald-500', '✅ Fixed')}
          ${renderGroup(changes.newIssues, 'bg-red-500/10 text-red-400 border border-red-500/20',             'border-red-500',     '🔴 Regression')}
          ${renderGroup(changes.worsened,  'bg-orange-500/10 text-orange-400 border border-orange-500/20',       'border-orange-500',  '📉 Worsened')}
          ${renderGroup(changes.improved,  'bg-blue-500/10 text-blue-400 border border-blue-500/20',           'border-blue-500',    '📈 Improved')}
          ${renderGroup(changes.remaining, 'bg-amber-500/10 text-amber-400 border border-amber-500/20',         'border-amber-500',   '⚠️ Remaining')}
        </div>
      </div>
    `;

    if (window.lucide) {
      window.lucide.createIcons();
    }
  }

  // Accordion Expand/Collapse Logic
  const toggleErrors = document.getElementById('toggle-errors');
  const errorsChecksDiv = document.getElementById('errors-checks');
  const chevronErrors = document.getElementById('chevron-errors');

  const toggleWarnings = document.getElementById('toggle-warnings');
  const warningsChecksDiv = document.getElementById('warnings-checks');
  const chevronWarnings = document.getElementById('chevron-warnings');

  const togglePassed = document.getElementById('toggle-passed');
  const passedChecksDiv = document.getElementById('passed-checks');
  const chevronPassed = document.getElementById('chevron-passed');

  function toggleSection(container: HTMLElement | null, chevron: HTMLElement | null) {
    if (!container || !chevron) return;
    const isHidden = container.classList.contains('hidden');
    if (isHidden) {
      container.classList.remove('hidden');
      chevron.style.transform = 'rotate(0deg)';
    } else {
      container.classList.add('hidden');
      chevron.style.transform = 'rotate(-90deg)';
    }
  }

  if (toggleErrors && errorsChecksDiv && chevronErrors) {
    toggleErrors.addEventListener('click', () => toggleSection(errorsChecksDiv, chevronErrors));
  }
  if (toggleWarnings && warningsChecksDiv && chevronWarnings) {
    toggleWarnings.addEventListener('click', () => toggleSection(warningsChecksDiv, chevronWarnings));
  }
  if (togglePassed && passedChecksDiv && chevronPassed) {
    togglePassed.addEventListener('click', () => toggleSection(passedChecksDiv, chevronPassed));
  }

  // Summary Card Clicking Bindings
  const cardErrorsSummary = document.getElementById('card-errors-summary');
  const cardWarningsSummary = document.getElementById('card-warnings-summary');
  const cardPassedSummary = document.getElementById('card-passed-summary');

  if (cardErrorsSummary) {
    cardErrorsSummary.addEventListener('click', () => {
      if (errorsChecksDiv?.classList.contains('hidden')) {
        toggleSection(errorsChecksDiv, chevronErrors);
      }
      errorsChecksDiv?.scrollIntoView({ behavior: 'smooth', block: 'center' });
    });
  }
  if (cardWarningsSummary) {
    cardWarningsSummary.addEventListener('click', () => {
      if (warningsChecksDiv?.classList.contains('hidden')) {
        toggleSection(warningsChecksDiv, chevronWarnings);
      }
      warningsChecksDiv?.scrollIntoView({ behavior: 'smooth', block: 'center' });
    });
  }
  if (cardPassedSummary) {
    cardPassedSummary.addEventListener('click', () => {
      if (passedChecksDiv?.classList.contains('hidden')) {
        toggleSection(passedChecksDiv, chevronPassed);
      }
      passedChecksDiv?.scrollIntoView({ behavior: 'smooth', block: 'center' });
    });
  }

  // Regenerate AI Recommendations listener
  const regenerateAiBtn = document.getElementById('regenerate-ai-btn');
  if (regenerateAiBtn) {
    regenerateAiBtn.addEventListener('click', () => {
      generateAiRecommendations();
    });
  }
</script>
