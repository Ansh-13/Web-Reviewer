---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Detailed Scan Report | Web-Reviewer">
  <!-- Include Tailwind CDN, Fonts, and Custom Config inside Layout -->
  <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries" is:inline></script>
  <!-- Lucide Icons -->
  <script src="https://unpkg.com/lucide@latest" is:inline></script>
  <link href="https://fonts.googleapis.com/css2?family=Hanken+Grotesk:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet"/>

  <script id="tailwind-config" is:inline>
    tailwind.config = {
      darkMode: 'class',
      theme: {
        extend: {
          fontFamily: {
            sans: ['Hanken Grotesk', 'sans-serif'],
          },
          colors: {
            surface: '#101415',
            'surface-bright': '#363a3b',
            'surface-container': '#191c1e',
            accent: '#8b5cf6', // Purple accent
          }
        }
      }
    }
  </script>

  <style is:inline>
    body {
      background-color: #0b0e0f; /* Deep background for contrast */
      color: #e2e8f0;
    }
    .glass-card {
      background: rgba(255, 255, 255, 0.03);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      border: 1px solid rgba(255, 255, 255, 0.1);
      border-radius: 1rem;
      transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }
    .glass-card:hover {
      border-color: rgba(139, 92, 246, 0.2);
    }
    .progress-ring__circle {
      transition: stroke-dashoffset 0.35s;
      transform: rotate(-90deg);
      transform-origin: 50% 50%;
    }
    /* Comparison styles */
    .compare-scan-row {
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 12px;
      border-radius: 8px;
      border: 1px solid rgba(255, 255, 255, 0.05);
      background: rgba(255, 255, 255, 0.01);
      cursor: pointer;
      transition: all 0.2s;
    }
    .compare-scan-row:hover {
      background: rgba(255, 255, 255, 0.04);
      border-color: rgba(255, 255, 255, 0.1);
    }
    .compare-scan-row.selected {
      background: rgba(139, 92, 246, 0.1);
      border-color: rgba(139, 92, 246, 0.3);
    }
  </style>

  <div class="font-sans antialiased min-h-screen flex flex-col w-full">
    <!-- BEGIN: Navigation -->
    <nav class="sticky top-0 z-50 border-b border-white/10 bg-[#101415]/80 backdrop-blur-md px-6 py-4 flex items-center justify-between">
      <div class="flex items-center gap-2" data-purpose="logo">
        <div class="w-8 h-8 bg-accent rounded-lg flex items-center justify-center">
          <i class="text-white w-5 h-5" data-lucide="check-circle"></i>
        </div>
        <span class="font-bold text-xl tracking-tight">Web-Reviewer</span>
      </div>
      <div class="flex items-center gap-6">
        <div class="hidden md:flex items-center gap-4 text-sm font-medium text-slate-400">
          <a class="hover:text-white transition-colors" href="/dashboard">Dashboard</a>
          <a class="text-white" href="#">Reports</a>
          <a class="hover:text-white transition-colors" href="#">Projects</a>
        </div>
        <div class="flex items-center gap-3 pl-6 border-l border-white/10">
          <div class="text-right hidden sm:block">
            <p class="text-xs font-semibold" id="nav-name">...</p>
            <p class="text-[10px] text-slate-400 uppercase tracking-wider">Premium Plan</p>
          </div>
          <img id="nav-avatar" alt="Avatar" class="w-8 h-8 rounded-full border border-accent/50" src="https://lh3.googleusercontent.com/aida-public/AB6AXuA17btC-1bymAouJQxxXEzMgP7ZDw02s8p6XcrEFbHDVuNOaQRTaaNXNpsBfUmt3RUs6KVTxmt94123Xvl0EGa0Dh4tAGIql3HoyOs8rSBmBp_R0ir8TklMIAHWq2YjZFPtCOtr3w652tli5MoLSaBpU5bbgBiiw2O8exrc0h8fMtuntLowS5MIWnrPXMidf5oUNRUR5iGyO369cyLKKrNHW0fkUxnPqo0bRilDHvFvGgsoJ2Mm42z88w"/>
        </div>
      </div>
    </nav>
    <!-- END: Navigation -->

    <!-- Loader Spinner -->
    <div class="flex flex-col items-center justify-center py-20 flex-grow" id="page-loader">
      <div class="w-10 h-10 border-4 border-white/5 border-t-primary rounded-full animate-spin"></div>
      <p class="text-slate-400 text-sm mt-4">Loading detailed report…</p>
    </div>

    <main class="max-w-5xl mx-auto px-6 py-10 w-full hidden space-y-12" id="content-area">
      <!-- BEGIN: Report Header -->
      <header class="flex flex-col md:flex-row justify-between items-start md:items-end gap-6">
        <div data-purpose="title-section">
          <h1 class="text-4xl font-extrabold text-white mb-3">Detailed Scan Report</h1>
        </div>

        <div class="flex items-center gap-8 glass-card p-6" data-purpose="score-overview">
          <div class="relative flex items-center justify-center">
            <!-- Circular Progress -->
            <svg class="w-24 h-24">
              <circle class="text-white/5" cx="48" cy="48" fill="transparent" r="42" stroke="currentColor" stroke-width="8"></circle>
              <circle class="text-accent progress-ring__circle" id="ring-progress" cx="48" cy="48" fill="transparent" r="42" stroke="currentColor" stroke-dasharray="263.89" stroke-dashoffset="263.89" stroke-linecap="round" stroke-width="8"></circle>
            </svg>
            <div class="absolute inset-0 flex flex-col items-center justify-center">
              <span class="text-2xl font-bold text-white" id="score-number">—</span>
              <span class="text-[10px] text-slate-400 uppercase font-semibold">Score</span>
            </div>
          </div>
          <div class="flex flex-col items-center justify-center px-6 border-l border-white/10">
            <span class="text-5xl font-black" id="grade-badge">—</span>
            <span class="text-[10px] text-slate-400 uppercase mt-1 font-semibold">SEO Grade</span>
          </div>
        </div>
      </header>
      <!-- END: Report Header -->

      <!-- BEGIN: Summary Cards -->
      <section class="grid grid-cols-1 sm:grid-cols-3 gap-6">
        <!-- Errors -->
        <div class="glass-card p-6 border-l-4 border-red-500 flex justify-between items-center hover:bg-white/5 hover:border-white/20 transition-all cursor-pointer" id="card-errors-summary">
          <div>
            <p class="text-sm text-slate-400 font-medium">Critical Errors</p>
            <p class="text-3xl font-bold mt-1 text-white" id="count-errors">0</p>
          </div>
          <div class="w-12 h-12 rounded-full bg-red-500/10 flex items-center justify-center text-red-500">
            <i data-lucide="alert-circle"></i>
          </div>
        </div>
        <!-- Warnings -->
        <div class="glass-card p-6 border-l-4 border-amber-500 flex justify-between items-center hover:bg-white/5 hover:border-white/20 transition-all cursor-pointer" id="card-warnings-summary">
          <div>
            <p class="text-sm text-slate-400 font-medium">Warnings</p>
            <p class="text-3xl font-bold mt-1 text-amber-500" id="count-warnings">0</p>
          </div>
          <div class="w-12 h-12 rounded-full bg-amber-500/10 flex items-center justify-center text-amber-500">
            <i data-lucide="alert-triangle"></i>
          </div>
        </div>
        <!-- Passed -->
        <div class="glass-card p-6 border-l-4 border-emerald-500 flex justify-between items-center hover:bg-white/5 hover:border-white/20 transition-all cursor-pointer" id="card-passed-summary">
          <div>
            <p class="text-sm text-slate-400 font-medium">Passed Checks</p>
            <p class="text-3xl font-bold mt-1 text-emerald-500" id="count-passed">0</p>
          </div>
          <div class="w-12 h-12 rounded-full bg-emerald-500/10 flex items-center justify-center text-emerald-500">
            <i data-lucide="check-circle-2"></i>
          </div>
        </div>
      </section>
      <!-- END: Summary Cards -->

      <!-- BEGIN: Findings Section -->
      <div class="space-y-8">
        <!-- FAILED CATEGORY -->
        <section data-purpose="failed-audits">
          <h2 class="text-lg font-semibold mb-4 flex items-center justify-between text-red-400 cursor-pointer select-none group border-b border-white/5 pb-2" id="toggle-errors">
            <span class="flex items-center gap-2">
              <i class="w-5 h-5" data-lucide="x-circle"></i>
              Failed Audits (Errors)
            </span>
            <i class="w-5 h-5 text-slate-500 group-hover:text-red-400 transition-transform duration-300" data-lucide="chevron-down" id="chevron-errors"></i>
          </h2>
          <div class="space-y-4 transition-all duration-300" id="errors-checks"></div>
        </section>

        <!-- WARNINGS CATEGORY -->
        <section data-purpose="warnings-audits">
          <h2 class="text-lg font-semibold mb-4 flex items-center justify-between text-amber-400 cursor-pointer select-none group border-b border-white/5 pb-2" id="toggle-warnings">
            <span class="flex items-center gap-2">
              <i class="w-5 h-5" data-lucide="alert-triangle"></i>
              Warnings Found
            </span>
            <i class="w-5 h-5 text-slate-500 group-hover:text-amber-400 transition-transform duration-300" data-lucide="chevron-down" id="chevron-warnings"></i>
          </h2>
          <div class="space-y-4 transition-all duration-300" id="warnings-checks"></div>
        </section>

        <!-- PASSED CATEGORY -->
        <section data-purpose="passed-audits">
          <h2 class="text-lg font-semibold mb-4 flex items-center justify-between text-emerald-400 cursor-pointer select-none group border-b border-white/5 pb-2" id="toggle-passed">
            <span class="flex items-center gap-2">
              <i class="w-5 h-5" data-lucide="check-circle-2"></i>
              Passed Checks
            </span>
            <i class="w-5 h-5 text-slate-500 group-hover:text-emerald-400 transition-transform duration-300" data-lucide="chevron-down" id="chevron-passed"></i>
          </h2>
          <div class="glass-card divide-y divide-white/5 transition-all duration-300" id="passed-checks"></div>
        </section>
      </div>
      <!-- END: Findings Section -->

      <!-- ── AI Insights Card ── -->
      <div class="glass-card p-8 bg-surface-container/20" id="ai-card">
        <div class="flex justify-between items-start mb-6">
          <div class="flex items-center gap-2">
            <i class="text-accent w-5 h-5 animate-pulse" data-lucide="sparkles"></i>
            <h2 class="text-xl font-bold text-white">AI Technical Consultant</h2>
          </div>
        </div>
        
        <p class="text-slate-400 text-sm mb-6">Get customized explanations and actionable recommendations for your SEO report from our AI consultant.</p>
        
        <button class="w-full bg-accent hover:bg-accent/90 text-white font-bold py-4 px-6 rounded-lg transition-all flex items-center justify-center gap-2" id="ai-generate-btn">
          <span id="ai-btn-text">Generate AI Recommendations</span>
          <span class="w-4 h-4 border-2 border-white/20 border-t-white rounded-full animate-spin hidden" id="ai-btn-spinner"></span>
        </button>

        <!-- AI Output Area -->
        <div class="hidden mt-6" id="ai-content-area">
          <div class="flex justify-between items-center border-t border-white/10 pt-6 mb-4">
            <span class="text-xs uppercase font-bold tracking-wider text-slate-400">Analysis Output</span>
            <button id="regenerate-ai-btn" class="flex items-center gap-1.5 text-xs font-semibold text-slate-400 hover:text-white px-2.5 py-1.5 rounded-lg bg-white/5 border border-white/5 transition-all">
              <i class="w-3.5 h-3.5" data-lucide="refresh-cw"></i>
              <span>Regenerate Output</span>
            </button>
          </div>
          <div class="prose prose-invert max-w-none text-slate-300 text-sm leading-relaxed" id="ai-insights-output"></div>
          <div class="flex justify-end mt-6 pt-6 border-t border-white/5">
            <button id="close-ai-btn" class="flex items-center gap-2 text-xs font-bold uppercase tracking-wider text-slate-400 hover:text-white px-4 py-2.5 rounded-lg bg-white/5 border border-white/10 hover:border-white/20 transition-all">
              <i class="w-3.5 h-3.5" data-lucide="x"></i>
              <span>Close Output</span>
            </button>
          </div>
        </div>
      </div>

      <!-- ── AI Optimiser Card ── -->
      <div class="glass-card p-8 bg-surface-container/20 animate-fade-in" id="optimiser-card">
        <div class="flex justify-between items-start mb-6">
          <div class="flex items-center gap-2">
            <i class="text-accent w-5 h-5" data-lucide="zap"></i>
            <h2 class="text-xl font-bold text-white">AI Rule Optimiser</h2>
          </div>
        </div>
        
        <p class="text-slate-400 text-sm mb-6">Select an issue or warning to generate an optimised fix.</p>
        
        <div class="flex flex-col sm:flex-row gap-4">
          <select id="optimiser-rule-select" class="flex-1 bg-black/40 border border-white/10 rounded-lg px-4 py-3 text-sm focus:outline-none focus:border-accent text-white">
            <option value="">Select an issue to optimise...</option>
          </select>
          <button class="bg-accent hover:bg-accent/90 text-white font-bold py-3 px-6 rounded-lg transition-all flex items-center justify-center gap-2 disabled:opacity-50 disabled:cursor-not-allowed" id="optimiser-btn" disabled>
            <span id="optimiser-btn-text">Optimise</span>
            <span class="w-4 h-4 border-2 border-white/20 border-t-white rounded-full animate-spin hidden" id="optimiser-btn-spinner"></span>
          </button>
        </div>

        <!-- Optimiser Output Area -->
        <div class="hidden mt-6" id="optimiser-content-area">
          <div class="flex justify-between items-center border-t border-white/10 pt-6 mb-4">
            <span class="text-xs uppercase font-bold tracking-wider text-slate-400">Optimisation Output</span>
            <button id="close-optimiser-btn" class="flex items-center gap-1.5 text-xs font-semibold text-slate-400 hover:text-white px-2.5 py-1.5 rounded-lg bg-white/5 border border-white/5 transition-all">
              <i class="w-3.5 h-3.5" data-lucide="x"></i>
              <span>Close Output</span>
            </button>
          </div>
          <div id="optimiser-output"></div>
          <div class="flex justify-end mt-6 pt-6 border-t border-white/5">
            <button id="close-optimiser-btn-bottom" class="flex items-center gap-2 text-xs font-bold uppercase tracking-wider text-slate-400 hover:text-white px-4 py-2.5 rounded-lg bg-white/5 border border-white/10 hover:border-white/20 transition-all">
              <i class="w-3.5 h-3.5" data-lucide="x"></i>
              <span>Close Output</span>
            </button>
          </div>
        </div>
      </div>

      <!-- ── Report Comparison Card ── -->
      <div class="glass-card p-8 bg-surface-container/20" id="compare-card">
        <div class="flex justify-between items-start mb-6">
          <div class="flex items-center gap-2">
            <i class="text-accent w-5 h-5" data-lucide="git-compare"></i>
            <h2 class="text-xl font-bold text-white">Compare Reports</h2>
          </div>
          <span class="text-[10px] bg-accent/20 text-accent font-bold px-2 py-0.5 rounded uppercase tracking-wider">Diff Analysis</span>
        </div>
        <p class="text-slate-400 text-sm mb-6">Select a previous scan to compare against this current scan — see what improved, regressed, or was fixed.</p>

        <!-- Scan selector -->
        <div class="space-y-4" id="compare-cols-wrapper">
          <!-- Skeleton -->
          <div class="space-y-3" id="compare-skeleton">
            <div class="h-10 bg-white/5 rounded animate-pulse"></div>
            <div class="h-10 bg-white/5 rounded animate-pulse"></div>
          </div>

          <!-- Empty state -->
          <div class="text-center text-slate-500 py-6 italic hidden" id="compare-empty">
            <i class="w-8 h-8 mx-auto text-slate-600 mb-2" data-lucide="help-circle"></i>
            <p>No other completed scans in this project to compare against.</p>
          </div>

          <!-- Previous Scans list -->
          <div class="hidden" id="compare-single-col">
            <div class="text-xs uppercase font-bold text-slate-400 flex justify-between items-center mb-2">
              <span class="flex items-center gap-1.5">Select Previous Scan</span>
              <span class="text-[10px] text-slate-500 font-mono" id="scan-b-hint">None selected</span>
            </div>
            <div class="max-h-60 overflow-y-auto space-y-2 pr-1" id="scan-b-list"></div>
          </div>
        </div>

        <!-- Compare button -->
        <button class="w-full bg-accent hover:bg-accent/90 text-white font-bold py-4 px-6 rounded-lg transition-all flex items-center justify-center gap-2 mt-6 hidden" id="compare-btn" disabled>
          <i class="w-4 h-4" data-lucide="git-compare"></i>
          <span id="compare-btn-text">Compare Scans</span>
          <span class="w-4 h-4 border-2 border-white/20 border-t-white rounded-full animate-spin hidden" id="compare-btn-spinner"></span>
        </button>

        <!-- Comparison Result Output Area -->
        <div class="hidden mt-8 border-t border-white/10 pt-8" id="compare-result-area">
          <div class="flex justify-between items-center mb-6">
            <span class="text-xs uppercase font-bold tracking-wider text-slate-400">Comparison Output</span>
            <button id="close-compare-btn" class="flex items-center gap-1.5 text-xs font-semibold text-slate-400 hover:text-white px-2.5 py-1.5 rounded-lg bg-white/5 border border-white/5 transition-all">
              <i class="w-3.5 h-3.5" data-lucide="x"></i>
              <span>Close Output</span>
            </button>
          </div>
          <div id="compare-result"></div>
          <div class="flex justify-end mt-8 pt-6 border-t border-white/5">
            <button id="close-compare-btn-bottom" class="flex items-center gap-2 text-xs font-bold uppercase tracking-wider text-slate-400 hover:text-white px-4 py-2.5 rounded-lg bg-white/5 border border-white/10 hover:border-white/20 transition-all">
              <i class="w-3.5 h-3.5" data-lucide="x"></i>
              <span>Close Output</span>
            </button>
          </div>
        </div>
      </div>

      <footer class="mt-20 pt-10 border-t border-white/5 text-center text-slate-500 text-xs">
        <p>© 2024 Web-Reviewer SEO Analytics. All rights reserved.</p>
      </footer>
    </main>
  </div>
</Layout>

<!-- ───────── CLIENT-SIDE SCRIPT ───────── -->
<script>
  import { subscribeToAuthState } from '../firebase/auth';

  /* ── DOM refs ── */
  const pageLoader      = document.getElementById('page-loader') as HTMLDivElement;
  const contentArea      = document.getElementById('content-area') as HTMLElement;
  const navAvatar        = document.getElementById('nav-avatar') as HTMLImageElement;
  const navName          = document.getElementById('nav-name') as HTMLSpanElement;

  const scoreNumber      = document.getElementById('score-number') as HTMLSpanElement;
  const gradeBadge       = document.getElementById('grade-badge') as HTMLSpanElement;
  const ringProgress     = document.getElementById('ring-progress') as SVGCircleElement;

  const countErrors      = document.getElementById('count-errors') as HTMLSpanElement;
  const countWarnings    = document.getElementById('count-warnings') as HTMLSpanElement;
  const countPassed      = document.getElementById('count-passed') as HTMLSpanElement;

  const errorsChecks     = document.getElementById('errors-checks') as HTMLDivElement;
  const warningsChecks   = document.getElementById('warnings-checks') as HTMLDivElement;
  const passedChecks     = document.getElementById('passed-checks') as HTMLDivElement;

  const aiGenerateBtn    = document.getElementById('ai-generate-btn') as HTMLButtonElement;
  const aiBtnText        = document.getElementById('ai-btn-text') as HTMLSpanElement;
  const aiBtnSpinner     = document.getElementById('ai-btn-spinner') as HTMLSpanElement;
  const aiContentArea    = document.getElementById('ai-content-area') as HTMLDivElement;
  const aiInsightsOutput = document.getElementById('ai-insights-output') as HTMLDivElement;
  const closeAiBtn       = document.getElementById('close-ai-btn') as HTMLButtonElement;

  const optimiserRuleSelect = document.getElementById('optimiser-rule-select') as HTMLSelectElement;
  const optimiserBtn        = document.getElementById('optimiser-btn') as HTMLButtonElement;
  const optimiserBtnText    = document.getElementById('optimiser-btn-text') as HTMLSpanElement;
  const optimiserBtnSpinner = document.getElementById('optimiser-btn-spinner') as HTMLSpanElement;
  const optimiserContentArea= document.getElementById('optimiser-content-area') as HTMLDivElement;
  const optimiserOutput     = document.getElementById('optimiser-output') as HTMLDivElement;
  const closeOptimiserBtn   = document.getElementById('close-optimiser-btn') as HTMLButtonElement;
  const closeOptimiserBtnBottom = document.getElementById('close-optimiser-btn-bottom') as HTMLButtonElement;

  let currentToken: string | null = null;
  let selectedScanA: string | null = null;  // currscan (Current)
  let selectedScanB: string | null = null;  // prevscan (Previous)
  let scannedUrl: string = '';
  let aiLoaded = false;
  let aiLoading = false;
  let aiOpen = false;
  let optimiserLoaded = false;
  let optimiserOpen = false;
  let currentOptimisedRule: string | null = null;

  /* ── Read scan_id from query params ── */
  const params = new URLSearchParams(window.location.search);
  const scanId = params.get('scan_id');

  if (!scanId) {
    alert("Scan ID is missing from URL query parameter.");
    window.location.href = "/dashboard";
  }

  /* ── Auth gate ── */
  subscribeToAuthState(async (user) => {
    if (!user) { window.location.href = '/login'; return; }

    navName.textContent = user.displayName || user.email || 'User';
    navAvatar.src = user.photoURL || `https://api.dicebear.com/7.x/initials/svg?seed=${encodeURIComponent(user.email || 'user')}`;

    currentToken = await user.getIdToken();

    // Fetch details
    fetchScanResults();
    fetchProjectScans();
  });

  /* ── Grade color helper ── */
  function gradeColor(grade: string): string {
    const g = grade.toUpperCase();
    if (g === 'A+' || g === 'A') return '#34d399';
    if (g === 'B') return '#60a5fa';
    if (g === 'C') return '#fbbf24';
    if (g === 'D') return '#fb923c';
    return '#f87171';
  }

  /* ── Get icon name based on check title ── */
  function getCheckIconName(title: string): string {
    const t = title.toLowerCase();
    if (t.includes('canonical')) return 'link';
    if (t.includes('title')) return 'type';
    if (t.includes('h1') || t.includes('heading')) return 'heading';
    if (t.includes('description') || t.includes('meta')) return 'file-text';
    if (t.includes('internal link') || t.includes('links')) return 'external-link';
    if (t.includes('structured') || t.includes('json-ld')) return 'database';
    if (t.includes('thin') || t.includes('word') || t.includes('words')) return 'feather';
    if (t.includes('og:') || t.includes('twitter') || t.includes('social')) return 'share-2';
    if (t.includes('image') || t.includes('alt')) return 'maximize';
    if (t.includes('robot') || t.includes('robots')) return 'bot';
    if (t.includes('viewport') || t.includes('mobile')) return 'smartphone';
    if (t.includes('lang') || t.includes('hreflang')) return 'languages';
    return 'check-circle';
  }

  /* ── Fetch details ── */
  async function fetchScanResults() {
    try {
      if (!currentToken || !scanId) return;

      const res = await fetch('http://localhost:3000/api/v1/getScanResults', {
        headers: {
          'Authorization': `Bearer ${currentToken}`,
          'scan_id': scanId,
        },
      });

      if (!res.ok) throw new Error('Failed to load scan results');

      const body = await res.json();
      const scanInfo = body.data?.[0]?.seo;

      if (!scanInfo) {
        throw new Error('No scan results found for this Audit ID.');
      }

      pageLoader.classList.add('hidden');
      contentArea.classList.remove('hidden');

      renderScanReport(scanInfo);

    } catch (err: any) {
      console.error(err);
      alert(err.message || "Failed to load scan report details.");
      window.location.href = "/dashboard";
    }
  }

  /* ── Render scan report ── */
  function renderScanReport(seo: any) {
    scannedUrl = seo.url || '';
    scoreNumber.textContent = seo.score ?? '—';
    gradeBadge.textContent = seo.grade ?? '—';
    
    const color = gradeColor(seo.grade || 'F');
    if (seo.grade === 'C') {
      gradeBadge.className = 'text-5xl font-black text-amber-400';
    } else if (seo.grade === 'A+' || seo.grade === 'A') {
      gradeBadge.className = 'text-5xl font-black text-emerald-400';
    } else if (seo.grade === 'B') {
      gradeBadge.className = 'text-5xl font-black text-blue-400';
    } else if (seo.grade === 'D') {
      gradeBadge.className = 'text-5xl font-black text-orange-400';
    } else {
      gradeBadge.className = 'text-5xl font-black text-red-400';
    }

    // Animate score ring
    const circumference = 2 * Math.PI * 42; // Radius is 42
    const score = Math.min(Math.max(seo.score || 0, 0), 100);
    const offset = circumference - (score / 100) * circumference;
    ringProgress.style.strokeDasharray = `${circumference}`;
    ringProgress.style.strokeDashoffset = `${circumference}`;
    ringProgress.style.stroke = color;
    requestAnimationFrame(() => {
      ringProgress.style.transition = 'stroke-dashoffset 1s ease';
      ringProgress.style.strokeDashoffset = `${offset}`;
    });

    // Summary counts
    const summary = seo.summary || {};
    countErrors.textContent = summary.errors ?? 0;
    countWarnings.textContent = summary.warnings ?? 0;
    countPassed.textContent = summary.passed ?? 0;

    // Checks results
    const results = seo.results || {};
    const errorsList = results.errors || [];
    const warningsList = results.warnings || [];
    const passedList = results.passed || [];

    // Helper to generate lists html
    const mapChecks = (checks: any[], type: 'error' | 'warning' | 'pass') => {
      if (checks.length === 0) {
        if (type === 'error') {
          return `<div class="glass-card p-8 text-center text-slate-500 italic">No critical audits failed in this category.</div>`;
        }
        if (type === 'warning') {
          return `<div class="glass-card p-8 text-center text-slate-500 italic">No warnings found in this category.</div>`;
        }
        return `<div class="p-6 text-center text-slate-500 italic">No passed checks.</div>`;
      }

      if (type === 'pass') {
        return checks.map(r => {
          const title = r.title || r.name || r.check || 'Audit Check';
          const icon = getCheckIconName(title);
          return `
            <div class="p-4 flex items-center justify-between">
              <div class="flex items-center gap-3">
                <i class="w-4 h-4 text-emerald-500" data-lucide="${icon}"></i>
                <span class="text-sm text-slate-300 font-medium">${escapeHTML(title)}</span>
              </div>
              <span class="text-[10px] bg-emerald-500/10 text-emerald-500 px-2 py-0.5 rounded font-bold uppercase">PASSED</span>
            </div>
          `;
        }).join('');
      }

      return checks.map(r => {
        const title = r.title || r.name || r.check || 'Audit Check';
        const msg = r.message || '';
        const icon = getCheckIconName(title);
        
        let cardBorder = 'border-white/10';
        let titleColor = 'text-white';
        let iconColor = 'text-amber-500';
        let bgStyle = '';

        if (type === 'error') {
          cardBorder = 'border-red-500/20';
          titleColor = 'text-red-100';
          iconColor = 'text-red-500';
        } else {
          // Check if it is a critical highlight warning
          if (title.toLowerCase().includes('multiple h1') || title.toLowerCase().includes('duplicate')) {
            cardBorder = 'border-accent/30';
            bgStyle = 'bg-accent/5';
            iconColor = 'text-accent';
          } else {
            cardBorder = 'border-white/10';
            iconColor = 'text-amber-500';
          }
        }

        // Generate custom recommendation boxes for prominent failures
        let recommendationBox = '';
        if (type === 'error' || title.toLowerCase().includes('h1') || title.toLowerCase().includes('title') || title.toLowerCase().includes('canonical') || title.toLowerCase().includes('description')) {
          let recText = 'Ensure only the main page title uses the H1 tag to provide a clear hierarchy for search engine crawlers.';
          if (title.toLowerCase().includes('canonical')) {
            recText = 'Add a rel="canonical" link header/element pointing to the preferred version of the URL to prevent indexing duplicate pages.';
          } else if (title.toLowerCase().includes('title')) {
            recText = 'Expand your page title to satisfy the 30-60 characters range, summarizing key page topics clearly.';
          } else if (title.toLowerCase().includes('description')) {
            recText = 'Write a meta description between 120 and 160 characters long that summarizes page content and contains target keywords.';
          } else if (type === 'error') {
            recText = 'Address this critical failure immediately to avoid ranking downgrades or search crawler blocks.';
          }

          recommendationBox = `
            <div class="mt-4 p-4 rounded-lg bg-black/40 border border-white/5" data-purpose="recommendation">
              <p class="text-xs uppercase tracking-widest ${type === 'error' ? 'text-red-400' : 'text-accent'} font-bold mb-2">Recommendation</p>
              <p class="text-sm text-slate-300">${recText}</p>
            </div>
          `;
        }

        return `
          <article class="glass-card ${cardBorder} overflow-hidden ${bgStyle}">
            <div class="p-6">
              <div class="flex items-start gap-4">
                <i class="w-5 h-5 ${iconColor} mt-1 flex-shrink-0" data-lucide="${icon}"></i>
                <div class="flex-1">
                  <h3 class="font-bold text-lg mb-1 ${titleColor}">${escapeHTML(title)}</h3>
                  <p class="text-slate-400 text-sm leading-relaxed">${escapeHTML(msg)}</p>
                  ${recommendationBox}
                </div>
              </div>
            </div>
          </article>
        `;
      }).join('');
    };

    errorsChecks.innerHTML = mapChecks(errorsList, 'error');
    warningsChecks.innerHTML = mapChecks(warningsList, 'warning');
    passedChecks.innerHTML = mapChecks(passedList, 'pass');

    if (window.lucide) {
      window.lucide.createIcons();
    }

    // Populate Optimiser Dropdown
    let optimiserOptions = '<option value="">Select an issue to optimise...</option>';
    const allIssues = [...errorsList, ...warningsList];
    allIssues.forEach(item => {
      const title = item.title || item.name || item.check || 'Audit Check';
      const id = item.id || title;
      optimiserOptions += `<option value="${id}">${title}</option>`;
    });
    optimiserRuleSelect.innerHTML = optimiserOptions;
  }

  // ── AI generation handler ──
  async function generateAiRecommendations() {
    if (!currentToken || !scanId || aiLoading) return;

    aiLoading = true;
    aiGenerateBtn.disabled = true;
    aiBtnText.textContent = "Analyzing SEO Report...";
    aiBtnSpinner.classList.remove('hidden');
    
    // Show loading skeleton inside output area
    aiInsightsOutput.innerHTML = `
      <div class="flex flex-col items-center justify-center py-10">
        <div class="w-8 h-8 border-4 border-white/5 border-t-accent rounded-full animate-spin"></div>
        <p class="text-xs text-slate-400 mt-3 font-semibold">AI is analyzing SEO vectors...</p>
      </div>
    `;
    aiContentArea.classList.remove('hidden');

    try {
      const res = await fetch(`http://localhost:3000/api/v1/ai/?scanid=${scanId}`, {
        headers: {
          'Authorization': `Bearer ${currentToken}`
        }
      });

      if (!res.ok) {
        const body = await res.json().catch(() => null);
        const msg = body?.error || (typeof body === 'string' ? body : 'Failed to generate AI insights.');
        throw new Error(msg);
      }

      const result = await res.json();
      const aiText = typeof result.Data === 'string' ? result.Data : (result.Data?.text || result.Data?.candidates?.[0]?.content?.parts?.[0]?.text || '');
      
      if (!aiText) {
        throw new Error("No recommendations generated by AI.");
      }

      let cleanedText = aiText.trim();
      if (cleanedText.startsWith("```")) {
        cleanedText = cleanedText.replace(/^```(json)?/, "").replace(/```$/, "").trim();
      }

      try {
        const parsedJson = JSON.parse(cleanedText);
        renderAiJsonInsights(parsedJson);
      } catch (jsonErr) {
        renderAiTextInsights(aiText);
      }

      aiLoaded = true;
      aiOpen = true;
      aiBtnText.textContent = "Close Recommendations";
    } catch (err: any) {
      console.error(err);
      aiInsightsOutput.innerHTML = `
        <div class="p-4 bg-red-500/10 border border-red-500/20 rounded-lg text-xs text-red-400">
          Error: ${err.message || "Failed to generate AI insights."}
        </div>
      `;
      aiBtnText.textContent = "Retry AI Recommendations";
    } finally {
      aiLoading = false;
      aiGenerateBtn.disabled = false;
      aiBtnSpinner.classList.add('hidden');
    }
  }

  aiGenerateBtn.addEventListener('click', () => {
    if (!aiLoaded) {
      generateAiRecommendations();
    } else {
      if (aiOpen) {
        aiContentArea.classList.add('hidden');
        aiBtnText.textContent = "Show Recommendations";
        aiOpen = false;
      } else {
        aiContentArea.classList.remove('hidden');
        aiBtnText.textContent = "Close Recommendations";
        aiOpen = true;
      }
    }
  });

  if (closeAiBtn) {
    closeAiBtn.addEventListener('click', () => {
      aiContentArea.classList.add('hidden');
      aiBtnText.textContent = "Show Recommendations";
      aiOpen = false;
    });
  }

